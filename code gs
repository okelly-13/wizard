function _getSubmittedCases(ss) {
  var cache = CacheService.getScriptCache(); var cached = cache.get(SUBMITTED_CACHE_KEY);
  if (cached) { try { return JSON.parse(cached); } catch (_) {} }
  var submittedCases = {}; var resultsSheet = ss.getSheetByName(SHEET_NAME_RCA);
  if (resultsSheet) {
    var data = resultsSheet.getDataRange().getValues();
    if (data.length >= 2) {
      var headers = data[0].map(function(h) { return (h || '').toString().toLowerCase().trim(); });
      var colIdx = headers.indexOf('case id'); var targetCol = colIdx > -1 ? colIdx : 3;
      for (var r = 1; r < data.length; r++) { var v = data[r][targetCol]; if (v) submittedCases[v.toString().trim()] = true; }
    }
  }
  cache.put(SUBMITTED_CACHE_KEY, JSON.stringify(submittedCases), 60); return submittedCases;
}

function _idxOf(headers, candidates) {
  var hLower = headers.map(function(h) { return String(h || '').toLowerCase().trim(); });
  for (var i = 0; i < candidates.length; i++) { var c = candidates[i].toLowerCase(); var idx = hLower.indexOf(c); if (idx >= 0) return idx; }
  for (var j = 0; j < candidates.length; j++) { var c2 = candidates[j].toLowerCase(); var idx2 = -1; for (var k = 0; k < hLower.length; k++) { if (hLower[k].indexOf(c2) > -1) { idx2 = k; break; } } if (idx2 >= 0) return idx2; }
  return -1;
}

function getPendingCases() {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheet = ss.getSheetByName(FEED_SHEET_NAME) || ss.getSheetByName('Daily Input');
    if (!sheet) throw new Error('Input sheet not found');

    var data = sheet.getDataRange().getValues();
    var headers = data[0].map(function(h) { return (h || '').toString().toLowerCase().trim(); });
    var submittedCases = _getSubmittedCases(ss); var currentUser = Session.getActiveUser().getEmail() || '';
    var pendingCases = [], analytics = { total: 0, retail: 0, business: 0, proactive: 0, lockedByOthers: 0, criticalDefects: 0, slaBreached: 0, appealsPending: 0, defects: {}, teams: {}, agencies: {} };
    var cache = CacheService.getScriptCache();

    var colIdCase = _idxOf(headers, ['case reference id', 'case id']); var colIdAnalyst = _idxOf(headers, ['employee name', 'analyst']); var colIdQcName = _idxOf(headers, ['qc name', 'qc reviewer']);
    var colIdRevDate = _idxOf(headers, ['review done date', 'review date']); var colIdWorkDate = _idxOf(headers, ['work done date', 'work date']); var colIdTaskType = _idxOf(headers, ['task type name', 'task type']);
    var colIdSubteam = _idxOf(headers, ['subteam', 'team']); var colIdAgency = _idxOf(headers, ['agency']); var colIdEntity = _idxOf(headers, ['entity name', 'entity']); var colIdProdLine = _idxOf(headers, ['production line', 'line']);
    var colIdDefect = _idxOf(headers, ['defect', 'outcome defect']); var colIdComment = _idxOf(headers, ['comment', 'comments', 'qc findings']); var colIdBatchId = _idxOf(headers, ['batch id', 'batch']);
    var colIdQcLink = _idxOf(headers, ['qc link', 'qc url']); var colIdBoLink = _idxOf(headers, ['bo link', 'bo url', 'back office']); var colIdAppeal = _idxOf(headers, ['appeal', 'appeal flag']); var colIdReviewResult = _idxOf(headers, ['review result', 'result']);
    var colIdLob = _idxOf(headers, ['lob', 'line of business']); var colIdEmpEmail = _idxOf(headers, ['employee email', 'analyst email']); var colIdEntityReg = _idxOf(headers, ['entity region', 'region']); var colIdLmEmail = _idxOf(headers, ['line manager', 'lm email', 'manager email']);
    var colIdRecs = _idxOf(headers, ['recs', 'recommendations']); var colIdAppealOut = _idxOf(headers, ['appeal outcome']); var colIdEntityRegG = _idxOf(headers, ['entity region grouped', 'region grouped']); var colIdIsProb = _idxOf(headers, ['is probation', 'probation']);
    var colIdRemed = _idxOf(headers, ['remediation required', 'remediation']); var colIdWasAppealed = _idxOf(headers, ['was appealed', 'appealed']);

    var now = new Date(); var slaThresholdDays = 5;

    for (var i = 1; i < data.length; i++) {
      var row = data[i]; var caseId = colIdCase >= 0 ? String(row[colIdCase] || '').trim() : '';
      if (!caseId || submittedCases[caseId]) continue;

      var lockVal = cache.get('lock_' + caseId) || '';
      var rawDefect = colIdDefect >= 0 ? String(row[colIdDefect] || '').toUpperCase() : '';
      var finalDefect = 'None';
      if (rawDefect === 'CRITICAL' || rawDefect === 'OUTCOME') finalDefect = 'Critical';
      else if (rawDefect === 'MAJOR') finalDefect = 'Major'; else if (rawDefect === 'MINOR') finalDefect = 'Minor';

      var taskTypeRaw = colIdTaskType >= 0 ? String(row[colIdTaskType] || '') : '';
      var product = taskTypeRaw.toUpperCase().indexOf('BUSINESS') > -1 ? 'BUSINESS' : 'RETAIL';
      var team = colIdSubteam >= 0 ? (row[colIdSubteam] || 'Unknown') : 'Unknown';
      var agency = colIdAgency >= 0 ? (row[colIdAgency] || 'Unknown') : 'Unknown';
      var slaBreached = false;
      try { var rd = colIdRevDate >= 0 ? row[colIdRevDate] : null; if (rd instanceof Date) { slaBreached = ((now - rd) / 86400000) > slaThresholdDays; } } catch (e2) {}

      var appealRaw = colIdAppeal >= 0 ? String(row[colIdAppeal] || '').toLowerCase().trim() : ''; var isAppeal = appealRaw === 'appeal';
      var commentText = colIdComment >= 0 ? String(row[colIdComment] || '') : ''; var hashtags = commentText.match(/#[\w_]+/g) || [];

      pendingCases.push({
        rowNum: i + 1, caseId: caseId, lockedBy: lockVal, isLockedByMe: lockVal === currentUser, analyst: colIdAnalyst >= 0 ? row[colIdAnalyst] : '', qcName: colIdQcName >= 0 ? row[colIdQcName] : '',
        reviewDoneDate: _fmtDate(colIdRevDate >= 0 ? row[colIdRevDate] : ''), workDoneDate: _fmtDate(colIdWorkDate >= 0 ? row[colIdWorkDate] : ''), taskType: taskTypeRaw.replace(/^FIU_/i, ''), entityName: colIdEntity >= 0 ? row[colIdEntity] : '', agency: agency,
        productionLine: colIdProdLine >= 0 ? (row[colIdProdLine] || 'Unknown') : 'Unknown', team: team, product: product, details: colIdComment >= 0 ? row[colIdComment] : '', defect: finalDefect, proactive: (colIdBatchId >= 0 && row[colIdBatchId] === '0') ? 'Yes' : 'No',
        slaBreached: slaBreached, qcLink: colIdQcLink >= 0 ? (row[colIdQcLink] || '') : '', boLink: colIdBoLink >= 0 ? (row[colIdBoLink] || '') : '', hashtags: hashtags, isAppeal: isAppeal, reviewResult: colIdReviewResult >= 0 ? String(row[colIdReviewResult] || '') : '',
        lob: colIdLob >= 0 ? String(row[colIdLob] || '') : '', empEmail: colIdEmpEmail >= 0 ? String(row[colIdEmpEmail] || '') : '', entityRegion: colIdEntityReg >= 0 ? String(row[colIdEntityReg] || '') : '', batchId: colIdBatchId >= 0 ? String(row[colIdBatchId] || '') : '',
        lmEmail: colIdLmEmail >= 0 ? String(row[colIdLmEmail] || '') : '', recs: colIdRecs >= 0 ? String(row[colIdRecs] || '') : '', appealOutcome: colIdAppealOut >= 0 ? String(row[colIdAppealOut] || '') : '', entityRegionGrouped: colIdEntityRegG >= 0 ? String(row[colIdEntityRegG] || '') : '',
        isProbation: colIdIsProb >= 0 ? String(row[colIdIsProb] || '') : '', remediationRequired: colIdRemed >= 0 ? String(row[colIdRemed] || '') : '', wasAppealed: colIdWasAppealed >= 0 ? String(row[colIdWasAppealed] || '') : ''
      });

      analytics.total++; if (product === 'BUSINESS') analytics.business++; else analytics.retail++;
      if (finalDefect === 'Critical') analytics.criticalDefects++; if (colIdBatchId >= 0 && row[colIdBatchId] === '0') analytics.proactive++;
      if (lockVal && lockVal !== currentUser) analytics.lockedByOthers++; if (slaBreached) analytics.slaBreached++; if (isAppeal) analytics.appealsPending++;
      analytics.defects[finalDefect] = (analytics.defects[finalDefect] || 0) + 1; analytics.teams[team] = (analytics.teams[team] || 0) + 1; analytics.agencies[agency] = (analytics.agencies[agency] || 0) + 1;
    }
    analytics.appealTrackerUrl = PropertiesService.getScriptProperties().getProperty('APPEAL_TRACKER_URL') || '';
    return { success: true, cases: pendingCases, count: pendingCases.length, analytics: analytics };
  } catch (e) { return { success: false, error: e.toString() }; }
}

