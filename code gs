    count(stats.byConductor, row[colIdx.conductor]); count(stats.byQcReviewer, row[colIdx.qcReviewer]); count(stats.byTeam, row[colIdx.team]); count(stats.byAnalyst, row[colIdx.analyst]); count(stats.byAgency, row[colIdx.agency]);
