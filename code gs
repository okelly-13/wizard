      var idCol = fLower.indexOf('case reference id') > -1 ? fLower.indexOf('case reference id') : fLower.indexOf('case id');
      var defCol = fLower.indexOf('defect') > -1 ? fLower.indexOf('defect') : fLower.indexOf('outcome defect');
