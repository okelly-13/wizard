function _matchesMultiSelect(cellVal, filterVal) {
  if (!filterVal) return true;
  if (!cellVal)  return false;
  const targets  = String(filterVal).toLowerCase().split(',').map(s => s.trim()).filter(Boolean);
  const cellItems = String(cellVal).toLowerCase().split(/[,;|]/).map(s => s.trim());
  return targets.some(t => cellItems.includes(t));
}
