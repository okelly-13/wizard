function exportActionsToJiraCsv() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('RCA Action Items');
  if (!sheet) return { success: true, csv: '', count: 0 };
  const data = sheet.getDataRange().getValues();
  const rows = [['Summary','Description','Priority','Labels','Issue Type']];
  for (let i = 1; i < data.length; i++) {
    if (data[i][8] !== 'Open') continue;
    const ctx = data[i][7] || '{}';
    rows.push([
      data[i][2],
      data[i][3] + '\n\nRCA Context:\n' + ctx,
      data[i][5],
      'RCA-Action;' + data[i][4],
      'Improvement'
    ]);
  }
  const esc = (v) => { const s=String(v); return /[",\n]/.test(s)?'"'+s.replace(/"/g,'""')+'"':s; };
  const csv = rows.map(r => r.map(esc).join(',')).join('\n');
  return { success: true, csv, count: rows.length - 1 };
}
