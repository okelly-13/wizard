function writeMigrationReport() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('RCA Results');
  if (!sheet) return;

  const currentHeaders = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  const numCols = currentHeaders.length;
  const currentNorm = currentHeaders.map(_normalize);
  const values = sheet.getRange(2, 1, sheet.getLastRow() - 1, numCols).getValues();

  const versions = [];
  Object.entries(OLD_VERSIONS).filter(([_, h]) => Array.isArray(h) && h.length > 0)
    .forEach(([key, headers]) => versions.push({ key, schema: headers.map(_normalize) }));

  const report = [['Row #', 'Detected Version', 'Old Case ID', 'New Case ID', 'Status']];
  values.forEach((row, idx) => {
    const rowNum = idx + 2;
    if (row.every(c => c === '' || c === null)) return;
    const det = _detectVersion(row, versions);
    const mapping = _buildMapping(det.version.schema, currentNorm);
    const newRow = _applyMapping(row, mapping, numCols);
    const oldId = _findCaseId(row, det.version.schema);
    const newId = _findCaseId(newRow, currentNorm);
    const status = (!oldId || oldId === newId) ? 'OK' : 'MISMATCH';
    report.push([rowNum, det.key, oldId, newId, status]);
  });

  const name = `RCA Migration Report ${Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd HHmm')}`;
  const rs = ss.insertSheet(name);
  rs.getRange(1, 1, report.length, 5).setValues(report);
  const hdr = rs.getRange(1, 1, 1, 5);
  hdr.setFontWeight('bold').setBackground('#5B47E0').setFontColor('#FFFFFF');
  rs.setFrozenRows(1);
  rs.autoResizeColumns(1, 5);
  console.log(`Report written: ${name}`);
}

