function migrateRcaResults() {
  const hasUi = _hasUi();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('RCA Results');
  if (!sheet) {
    _log(hasUi, 'Error', '❌ Sheet "RCA Results" not found.');
    return { success: false };
  }

  const providedVersions = Object.entries(OLD_VERSIONS).filter(([_, h]) => Array.isArray(h) && h.length > 0);
  if (providedVersions.length === 0) {
    _log(hasUi, 'Config needed', '⚠️ OLD_VERSIONS is empty.');
    return { success: false };
  }

  // Backup
  const stamp = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd HHmm');
  const backupName = `RCA Results BACKUP ${stamp}`;
  const backup = sheet.copyTo(ss);
  backup.setName(backupName);
  ss.setActiveSheet(backup);
  ss.moveActiveSheet(1);
  SpreadsheetApp.flush();

  // Read current schema
  const currentHeaders = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  const numCols = currentHeaders.length;
  const currentNorm = currentHeaders.map(_normalize);

  // Build version registry
  const versions = [];
  providedVersions.forEach(([key, headers]) => {
    versions.push({ key, schema: headers.map(_normalize), raw: headers });
  });

  // Read data
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) {
    _log(hasUi, 'Empty sheet', 'No data rows to migrate.');
    return { success: false };
  }
  const values = sheet.getRange(2, 1, lastRow - 1, numCols).getValues();

  // Process rows
  const plan = [];
  const stats = { totalRows: values.length, byVersion: {}, unmapped: [], aliasUsed: {}, errors: [] };

  values.forEach((row, idx) => {
    const rowNum = idx + 2;
    if (row.every(c => c === '' || c === null)) {
      stats.byVersion['__empty__'] = (stats.byVersion['__empty__'] || 0) + 1;
      return;
    }

    const detection = _detectVersion(row, versions);
    stats.byVersion[detection.key] = (stats.byVersion[detection.key] || 0) + 1;

    const mapping = _buildMapping(detection.version.schema, currentNorm);

    // Track alias usage
    detection.version.schema.forEach((oldH, oldIdx) => {
      if (HEADER_ALIASES[oldH]) {
        stats.aliasUsed[oldH] = (stats.aliasUsed[oldH] || 0) + 1;
      }
    });

    // Track unmapped columns
    const unmappedOld = detection.version.schema
      .map((h, i) => ({ idx: i, name: detection.version.raw[i] }))
      .filter(({ idx, name }) => mapping.every(src => src !== idx) && name);
    if (unmappedOld.length > 0) {
      stats.unmapped.push({ row: rowNum, version: detection.key, columns: unmappedOld.map(u => u.name) });
    }

    const newRow = _applyMapping(row, mapping, numCols);
    const oldCaseId = _findCaseId(row, detection.version.schema);
    const newCaseId = _findCaseId(newRow, currentNorm);

    plan.push({ rowNum, version: detection.key, confidence: detection.confidence, oldCaseId, newCaseId, newRow });
  });

  // Preview
  const preview = _formatPreview(stats, plan);

  if (hasUi) {
    const response = SpreadsheetApp.getUi().alert(
      'Migration Preview', preview + `\n\nApply?\n(Backup: "${backupName}")`,
      SpreadsheetApp.getUi().ButtonSet.YES_NO);
    if (response !== SpreadsheetApp.getUi().Button.YES) {
      SpreadsheetApp.getUi().alert('Cancelled', 'No changes. Backup preserved.', SpreadsheetApp.getUi().ButtonSet.OK);
      return { success: false };
    }
  } else {
    console.log('=== MIGRATION PREVIEW (editor run) ===\n' + preview);
    console.log(`Backup: ${backupName}`);
  }

  // Apply
  const BATCH = 50;
  for (let i = 0; i < plan.length; i += BATCH) {
    plan.slice(i, i + BATCH).forEach(item => {
      sheet.getRange(item.rowNum, 1, 1, numCols).setValues([item.newRow]);
    });
    SpreadsheetApp.flush();
  }

  // Summary
  const summary = [
    `✅ Migrated ${plan.length} rows.`,
    `📦 Backup: "${backupName}"`,
    '',
    'Versions detected:',
    ...Object.entries(stats.byVersion).map(([v, c]) => `  ${v}: ${c}`),
    '',
    `Aliases resolved: ${Object.keys(stats.aliasUsed).length} distinct renames`,
    stats.unmapped.length ? `\n⚠️ ${stats.unmapped.length} rows had unmapped columns.` : ''
  ].filter(Boolean).join('\n');

  _log(hasUi, '✅ Migration complete', summary);

  // Detailed logs
  console.log('=== ALIAS USAGE ===');
  Object.entries(stats.aliasUsed).sort((a, b) => b[1] - a[1]).forEach(([k, v]) => {
    console.log(`  ${k} → ${HEADER_ALIASES[k]}  (used ${v} times)`);
  });

  if (stats.unmapped.length > 0) {
    console.log('=== UNMAPPED COLUMNS ===');
    stats.unmapped.forEach(u => console.log(`Row ${u.row} (${u.version}): ${u.columns.join(', ')}`));
  }

  return { success: true, migrated: plan.length, stats };
}

// ─── MIGRATION HELPERS ───
function _hasUi() {
  try { SpreadsheetApp.getUi(); return true; }
  catch (e) { return false; }
}

function _log(hasUi, title, message) {
  if (hasUi) SpreadsheetApp.getUi().alert(title, message, SpreadsheetApp.getUi().ButtonSet.OK);
  else { console.log(`[${title}]`); console.log(message); console.log('---'); }
}

function _normalize(s) {
  return String(s || '')
    .toLowerCase()
    .trim()
    .replace(/^if\s+a\s+.+?,\s*(was|is|were|are|did)\s+/i, '')
    .replace(/^(was|is|did|are)\s+/i, '')
    .replace(/\?$/, '')
    .replace(/$[^)]*$/g, '')        // ← FIXED: strips "(days)", "(Full vs Short)", etc.
    .replace(/\b(correctly|identified|checked)\b/g, '')
    .replace(/[\/\-]+/g, ' ')
    .replace(/[^\w\s]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function _detectVersion(row, versions) {
  let best = { key: '__unknown__', version: null, confidence: -1 };
  versions.forEach(v => {
    const score = _scoreRow(row, v.schema);
    if (score > best.confidence) best = { key: v.key, version: v, confidence: score };
  });
  return best;
}

function _scoreRow(row, schema) {
  let score = 0;
  const n = Math.min(row.length, schema.length);
  for (let i = 0; i < n; i++) {
    const cell = row[i];
    const h = schema[i] || '';
    if (cell === '' || cell === null) continue;
    if (h.includes('email'))    { if (typeof cell === 'string' && /@/.test(cell)) score += 3; }
    else if (h.includes('date')){ if (cell instanceof Date || /\d{4}-\d{2}-\d{2}/.test(cell)) score += 3; }
    else if (h.includes('link') || h.includes('url')) { if (/^https?:\/\//.test(cell)) score += 3; }
    else if (/(flag|appeal|accept|probation|remediation|was appealed)/.test(h)) {
      if (cell === true || cell === false || cell === 'TRUE' || cell === 'FALSE') score += 2;
    }
    else if (/(count|cycle|score)/.test(h)) { if (!isNaN(parseFloat(cell))) score += 1; }
    else if (typeof cell === 'string' && cell.length > 0) score += 0.1;
  }
  return score;
}

function _buildMapping(oldSchema, newSchema) {
  const mapping = new Array(newSchema.length).fill(-1);

  oldSchema.forEach((oldHeader, oldIdx) => {
    if (!oldHeader) return;

    // Step 1: Try alias lookup first (most reliable for known renames)
    let resolved = HEADER_ALIASES[oldHeader] || oldHeader;

    // Step 2: Exact match against current schema
    let newIdx = newSchema.indexOf(resolved);

    // Step 3: Fuzzy fallback — contains match (only for headers long enough to avoid false positives)
    if (newIdx < 0) {
      newIdx = newSchema.findIndex(h => h && h.includes(resolved) && resolved.length > 4);
    }
    if (newIdx < 0 && resolved !== oldHeader) {
      newIdx = newSchema.findIndex(h => h && h.includes(oldHeader) && oldHeader.length > 4);
    }

    // Assign only if not already taken
    if (newIdx > -1 && mapping[newIdx] === -1) {
      mapping[newIdx] = oldIdx;
    }
  });

  return mapping;
}

function _applyMapping(row, mapping, numCols) {
  const newRow = new Array(numCols).fill('');
  mapping.forEach((oldIdx, newIdx) => {
    if (oldIdx > -1 && oldIdx < row.length) newRow[newIdx] = row[oldIdx];
  });
  return newRow;
}

function _findCaseId(row, schema) {
  for (const c of ['case id', 'case reference id', 'uar id']) {
    const i = schema.indexOf(c);
    if (i > -1 && row[i]) return String(row[i]).trim();
  }
  return '';
}

function _formatPreview(stats, plan) {
  const lines = [];
  lines.push(`Total rows: ${stats.totalRows}`);
  lines.push('');
  lines.push('Detected versions:');
  Object.entries(stats.byVersion).forEach(([v, c]) => lines.push(`  • ${v}: ${c} rows`));
  if (stats.unmapped.length > 0) {
    lines.push('');
    lines.push(`⚠️ ${stats.unmapped.length} rows have unmapped columns:`);
    stats.unmapped.slice(0, 5).forEach(u => {
      lines.push(`   Row ${u.row} (${u.version}): ${u.columns.join(', ')}`);
    });
    if (stats.unmapped.length > 5) lines.push(`   ...and ${stats.unmapped.length - 5} more (see Logs)`);
  }
  lines.push('');
  lines.push('Sample case ID survival (first 3):');
  plan.slice(0, 3).forEach(p => {
    const ok = p.oldCaseId === p.newCaseId ? '✓' : '✗';
    lines.push(`  Row ${p.rowNum} [${p.version}] ${ok} ${p.oldCaseId || '(none)'} → ${p.newCaseId || '(none)'}`);
  });
  return lines.join('\n');
}

