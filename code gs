function verifyMigrationSetup() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('RCA Results');
  if (!sheet) { console.log('❌ No RCA Results sheet'); return; }

  const liveHeaders = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  const liveNorm    = liveHeaders.map(_normalize);
  const schemaNorm  = CURRENT_SCHEMA.map(_normalize);

  let problems = 0;

  if (liveHeaders.length !== CURRENT_SCHEMA.length) {
    console.log(`❌ Column count mismatch — sheet has ${liveHeaders.length}, CURRENT_SCHEMA has ${CURRENT_SCHEMA.length}`);
    problems++;
  } else {
    console.log(`✓ Column count: ${CURRENT_SCHEMA.length}`);
  }

  liveNorm.forEach((norm, i) => {
    if (!schemaNorm.includes(norm)) {
      console.log(`❌ Live header [${i+1}] "${liveHeaders[i]}" (→ "${norm}") not in CURRENT_SCHEMA`);
      problems++;
    }
  });

  schemaNorm.forEach((norm, i) => {
    if (!liveNorm.includes(norm)) {
      console.log(`❌ CURRENT_SCHEMA [${i+1}] "${CURRENT_SCHEMA[i]}" (→ "${norm}") not in live sheet`);
      problems++;
    }
  });

  Object.entries(HEADER_ALIASES).forEach(([oldN, newN]) => {
    if (liveNorm.indexOf(newN) === -1) {
      console.log(`❌ Alias "${oldN}" → "${newN}" — target not found in live sheet`);
      problems++;
    }
  });

  const v31 = OLD_VERSIONS['v_31may'];
  if (Array.isArray(v31)) {
    const v31Norm = v31.map(_normalize);
    const mapping = _buildMapping(v31Norm, liveNorm);
    const unmapped = v31
      .map((h, i) => ({ name: h, norm: v31Norm[i], idx: i }))
      .filter(({ norm, idx }) => mapping.every(src => src !== idx) && norm);
    if (unmapped.length === 0) {
      console.log(`✓ All ${v31.length} v_31may columns map to current schema`);
    } else {
      console.log(`⚠️ ${unmapped.length} v_31may columns would be unmapped:`);
      unmapped.forEach(u => console.log(`     "${u.name}" (→ "${u.norm}")`));
      problems += unmapped.length;
    }
  }

  console.log('---');
  if (problems === 0) {
    console.log('✅ Migration setup is VALID — safe to run migrateRcaResults()');
  } else {
    console.log(`❌ Found ${problems} issue(s) — fix before migrating`);
  }
  return problems === 0;
}

function exportRcaToCsv(filters) {
  const t0 = Date.now();
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('RCA Results');
    if (!sheet) return _meta({ success: false, error: 'RCA Results sheet not found' }, t0);

    const data = sheet.getDataRange().getValues();
    if (data.length < 2) return _meta({ success: true, csv: '', rowCount: 0 }, t0);

    const headers = data[0].map(h => (h || '').toString());
    const colIdx  = _buildRcaColumnIndex(headers);

    const filtered = data.slice(1).filter(row => _matchesRcaFilters(row, colIdx, filters || {}));

    const escapeCsv = (v) => {
      const s = String(v == null ? '' : v);
      return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
    };

    const rows = [headers.map(escapeCsv).join(',')];
    filtered.forEach(row => rows.push(row.map(escapeCsv).join(',')));

    return _meta({ success: true, csv: rows.join('\n'), rowCount: filtered.length }, t0);
  } catch (e) {
    return _meta({ success: false, error: e.message }, t0);
  }
}

