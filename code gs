function logCustomOption(field, value) {
  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet(); var sheet = ss.getSheetByName('CustomOptions');
    if (!sheet) { sheet = ss.insertSheet('CustomOptions'); sheet.appendRow(['Timestamp', 'Field', 'Value', 'Submitted By']); sheet.getRange(1, 1, 1, 4).setFontWeight('bold').setFrozenRows(1); }
    sheet.appendRow([new Date(), field, value, Session.getActiveUser().getEmail()]);
  } catch (e) { Logger.log('logCustomOption error: ' + e); }
}

