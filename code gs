// LOCK & PING
// ============================================================
function ping() { return { success: true, user: Session.getActiveUser().getEmail() || 'anonymous', version: '6.4' }; }

function lockCase(caseId) {
  var lock = LockService.getScriptLock();
  try {
    lock.waitLock(5000);
    var cache = CacheService.getScriptCache(); var key = 'lock_' + caseId; var owner = Session.getActiveUser().getEmail() || 'anonymous';
    var existing = cache.get(key);
    if (existing && existing !== owner) return { success: false, lockedBy: existing, caseId: caseId };
    cache.put(key, owner, LOCK_TTL); return { success: true, lockedBy: owner, caseId: caseId };
  } catch (e) { return { success: false, error: e.toString() }; }
  finally { try { lock.releaseLock(); } catch (_) {} }
}
function refreshLock(caseId) { return lockCase(caseId); }
function unlockCase(caseId) { try { CacheService.getScriptCache().remove('lock_' + caseId); return { success: true }; } catch (e) { return { success: false, error: e.toString() }; } }

