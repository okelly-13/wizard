    var data = sheet.getDataRange().getValues(); var hLower = data[0].map(function(h) { return String(h || '').toLowerCase().trim(); });
    var colIdx = _buildRcaColumnIndex(hLower); var filtered = data.slice(1).filter(function(row) { return _matchesRcaFilters(row, colIdx, filters || {}); });
    
