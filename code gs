function _matchesRcaFilters(row, colIdx, filters) {
  if (!filters) return true;

  const inDateRange = (val, from, to) => {
    if (!from && !to) return true;
    if (!val) return false;
    const d = new Date(val);
    if (isNaN(d.getTime())) return false;
    if (from && d < new Date(from)) return false;
    if (to   && d > new Date(to + 'T23:59:59')) return false;
    return true;
  };

  // Date range — apply to user-selected date column
  const dateField = filters.dateField || 'timestamp';
  const dateCol =
      dateField === 'reviewDate' ? colIdx.reviewDate
    : dateField === 'workDate'   ? colIdx.workDate
    : colIdx.timestamp;
  if (!inDateRange(dateCol > -1 ? row[dateCol] : null, filters.dateFrom, filters.dateTo)) return false;

  // Categorical exact-match filters
  const checks = [
    ['conductor',   colIdx.conductor,   filters.conductor],
    ['qcReviewer',  colIdx.qcReviewer,  filters.qcReviewer],
    ['analyst',     colIdx.analyst,     filters.analyst],
    ['team',        colIdx.team,        filters.team],
    ['agency',      colIdx.agency,      filters.agency],
    ['product',     colIdx.product,     filters.product],
    ['country',     colIdx.country,     filters.country],
    ['authority',   colIdx.authority,   filters.authority],
    ['origin',      colIdx.origin,      filters.origin],
    ['taskType',    colIdx.taskType,    filters.taskType],
    ['lob',         colIdx.lob,         filters.lob],
    ['errorSource', colIdx.errorSource, filters.errorSource],
    ['rcaAgree',    colIdx.rcaAgree,    filters.rcaAgree]
  ];
  for (const [, idx, val] of checks) {
    if (val && idx > -1 && String(row[idx] || '').trim() !== val) return false;
  }

  // Multi-select filters (comma-separated cells)
  if (filters.typology && colIdx.typology > -1 &&
      !_matchesMultiSelect(row[colIdx.typology], filters.typology)) return false;
  if (filters.tag && colIdx.tag > -1 &&
      !_matchesMultiSelect(row[colIdx.tag], filters.tag)) return false;

  // Boolean flags (only filter if explicitly set)
  if (filters.flagToTL     !== undefined && filters.flagToTL     !== '' && _toBool(row[colIdx.flagToTL])     !== filters.flagToTL)     return false;
  if (filters.toBeAppealed !== undefined && filters.toBeAppealed !== '' && _toBool(row[colIdx.toBeAppealed]) !== filters.toBeAppealed) return false;
  if (filters.failAccepted !== undefined && filters.failAccepted !== '' && _toBool(row[colIdx.failAccepted]) !== filters.failAccepted) return false;

  // Full-text search across key fields
  if (filters.search) {
    const s = filters.search.toLowerCase();
    const haystack = [
      colIdx.caseId, colIdx.conductor, colIdx.qcReviewer, colIdx.analyst,
      colIdx.rcaComments, colIdx.rcaUpdate, colIdx.rcaSysFailTxt
    ].filter(i => i > -1).map(i => String(row[i] || '').toLowerCase()).join(' | ');
    if (!haystack.includes(s)) return false;
  }

  return true;
}

function _classifyDefect(row, colIdx) {
  const outcome = colIdx.rcaOutcome > -1 ? String(row[colIdx.rcaOutcome] || '').trim() : '';
  if (outcome === 'No') return 'Critical';
  if (outcome === 'Yes') return 'None';
  return 'Unknown';
}

function _toBool(v) {
  return v === true || v === 'TRUE' || v === 'Yes' || v === 'true';
}

function _aggregateRcaResults(rows, colIdx) {
  const now = new Date();
  const weekAgo  = new Date(now.getTime() - 7  * 86400000);
  const monthAgo = new Date(now.getTime() - 30 * 86400000);

  const stats = _emptyRcaAnalytics();
  const dailyTrend = {}, weeklyTrend = {}, monthlyTrend = {};

  // New accumulators for extended analytics
  const dailyDefects = {};
  const failureReasons = {};
  const analystMatrix = {};
  const phaseMonthMatrix = {};

  const phaseFailure = {
    p2Baseline:   { pass: 0, fail: 0, total: 0, failRate: 0 },
    p2Osint:      { pass: 0, fail: 0, total: 0, failRate: 0 },
    p3Baseline:   { pass: 0, fail: 0, total: 0, failRate: 0 },
    p3Module:     { pass: 0, fail: 0, total: 0, failRate: 0 },
    p4ShortFull:  { pass: 0, fail: 0, total: 0, failRate: 0 },
    p4CorrectAll: { pass: 0, fail: 0, total: 0, failRate: 0 },
    p5Decision:   { pass: 0, fail: 0, total: 0, failRate: 0 }
  };
  const typologyCounts = {};
  const tagCounts      = {};
  const systemicVsHuman = { humanOnly: 0, systemOnly: 0, both: 0, neither: 0, unknown: 0 };
  let agreeYes = 0, agreeNo = 0, agreeOther = 0;
  let defectSum = 0, defectCount = 0;
  const cycleWeekly = {};
  const cycleMonthly = {};

  rows.forEach(row => {
    const ts = colIdx.timestamp > -1 ? new Date(row[colIdx.timestamp]) : null;
    const isValidDate = ts && !isNaN(ts.getTime());

    let weekKey  = null;
    let monthKey = null;

    if (isValidDate) {
      stats.total++;
      if (ts >= weekAgo)  stats.thisWeek++;
      if (ts >= monthAgo) stats.thisMonth++;

      const dayKey = _dateKey(ts);
      dailyTrend[dayKey] = (dailyTrend[dayKey] || 0) + 1;

      weekKey = _isoWeekKey(ts);
      weeklyTrend[weekKey] = (weeklyTrend[weekKey] || 0) + 1;
      if (!cycleWeekly[weekKey]) cycleWeekly[weekKey] = { w2q: [], q2r: [] };

      monthKey = ts.getFullYear() + '-' + String(ts.getMonth() + 1).padStart(2, '0');
      monthlyTrend[monthKey] = (monthlyTrend[monthKey] || 0) + 1;
      if (!cycleMonthly[monthKey]) cycleMonthly[monthKey] = { w2q: [], q2r: [] };
    }

    const bump = (obj, key) => { if (key) obj[key] = (obj[key] || 0) + 1; };
    bump(stats.byDefect,     _classifyDefect(row, colIdx));
    bump(stats.byProduct,    colIdx.product    > -1 ? String(row[colIdx.product]    || '').trim() : '');
    bump(stats.byConductor,  colIdx.conductor  > -1 ? String(row[colIdx.conductor]  || '').trim() : '');
    bump(stats.byQcReviewer, colIdx.qcReviewer > -1 ? String(row[colIdx.qcReviewer] || '').trim() : '');
    bump(stats.byAnalyst,    colIdx.analyst    > -1 ? String(row[colIdx.analyst]    || '').trim() : '');
    bump(stats.byTeam,       colIdx.team       > -1 ? String(row[colIdx.team]       || '').trim() : '');
    bump(stats.byAgency,     colIdx.agency     > -1 ? String(row[colIdx.agency]     || '').trim() : '');
    bump(stats.byAuthority,  colIdx.authority  > -1 ? String(row[colIdx.authority]  || '').trim() : '');
    bump(stats.byCountry,    colIdx.country    > -1 ? String(row[colIdx.country]    || '').trim() : '');
    bump(stats.byOrigin,     colIdx.origin     > -1 ? String(row[colIdx.origin]     || '').trim() : '');
    bump(stats.byTaskType,   colIdx.taskType   > -1 ? String(row[colIdx.taskType]   || '').trim() : '');
    bump(stats.byErrorSource,colIdx.errorSource> -1 ? String(row[colIdx.errorSource]|| '').trim() : '');

    const qcAgree = colIdx.rcaAgree > -1 ? String(row[colIdx.rcaAgree] || '').trim() : '';
    bump(stats.byQcAgree, qcAgree);

    if (/^yes/i.test(qcAgree))         agreeYes++;
    else if (/^no/i.test(qcAgree))     agreeNo++;
    else if (qcAgree)                  agreeOther++;

    const trackPhase = (key, val) => {
      if (!val) return;
      if (val === 'Yes') phaseFailure[key].pass++;
      else if (val === 'No') phaseFailure[key].fail++;
    };
    trackPhase('p2Baseline',   _safeStr(row, colIdx.p2Baseline));
    trackPhase('p2Osint',      _safeStr(row, colIdx.p2Osint));
    trackPhase('p3Baseline',   _safeStr(row, colIdx.p3Baseline));
    trackPhase('p3Module',     _safeStr(row, colIdx.p3Module));
    trackPhase('p4ShortFull',  _safeStr(row, colIdx.p4ShortFull));
    trackPhase('p4CorrectAll', _safeStr(row, colIdx.p4CorrectAll));
    trackPhase('p5Decision',   _safeStr(row, colIdx.p5Decision));

    if (colIdx.typology > -1) {
      String(row[colIdx.typology] || '').split(/[,;|]/).map(s => s.trim()).filter(Boolean)
        .forEach(t => { typologyCounts[t] = (typologyCounts[t] || 0) + 1; });
    }
    if (colIdx.tag > -1) {
      String(row[colIdx.tag] || '').split(/[,;|]/).map(s => s.trim()).filter(Boolean)
        .forEach(t => { tagCounts[t] = (tagCounts[t] || 0) + 1; });
    }

    const errSrc = _safeStr(row, colIdx.errorSource);
    const sysFail = _safeStr(row, colIdx.rcaSysFail);
    const isHuman  = /performance/i.test(errSrc);
    const isSystem = /process|product/i.test(errSrc) || /yes/i.test(sysFail);
    if (isHuman && isSystem)      systemicVsHuman.both++;
    else if (isHuman)             systemicVsHuman.humanOnly++;
    else if (isSystem)            systemicVsHuman.systemOnly++;
    else if (!errSrc && !sysFail) systemicVsHuman.neither++;
    else                          systemicVsHuman.unknown++;

    const score = parseFloat(row[colIdx.binaryDefectScore]);
    if (!isNaN(score)) { defectSum += score; defectCount++; }

    const d = _classifyDefect(row, colIdx);
    if (d === 'Critical') stats.criticalCount++;
    if (qcAgree.includes('Appealing'))   stats.flagged.toBeAppealed++;
    if (_toBool(row[colIdx.flagToTL]))   stats.flagged.flagToTL++;
    if (_toBool(row[colIdx.failAccepted])) stats.flagged.failAccepted++;

    // ── NEW: Daily defect severity stacking ──
    if (isValidDate) {
      const dk = _dateKey(ts);
      if (!dailyDefects[dk]) dailyDefects[dk] = { Critical:0, Major:0, Minor:0, None:0, Unknown:0 };
      dailyDefects[dk][d]++;
    }

    // ── NEW: Failure reason Pareto ──
    const failTexts = [
      _safeStr(row, colIdx.p2BaselineFail), _safeStr(row, colIdx.p2OsintFail),
      _safeStr(row, colIdx.p3BaselineFail), _safeStr(row, colIdx.p3ModuleFail),
      _safeStr(row, colIdx.p5ActionError), _safeStr(row, colIdx.p5JurisTxt),
      _safeStr(row, colIdx.p5ExcepTxt), _safeStr(row, colIdx.p5BizTxt),
      _safeStr(row, colIdx.p6EddTxt), _safeStr(row, colIdx.p6JurisTxt),
      _safeStr(row, colIdx.p6TemplateTxt), _safeStr(row, colIdx.p6DanteTxt),
      _safeStr(row, colIdx.p6TagsTxt), _safeStr(row, colIdx.p6AlertsTxt),
      _safeStr(row, colIdx.p6OffboardTxt), _safeStr(row, colIdx.p6SuspectsTxt),
      _safeStr(row, colIdx.p6RefundsTxt), _safeStr(row, colIdx.rcaSysFailTxt)
    ];
    failTexts.forEach(txt => {
      if (!txt || txt.toLowerCase() === 'other') return;
      const key = txt.length > 55 ? txt.slice(0, 53) + '…' : txt;
      failureReasons[key] = (failureReasons[key] || 0) + 1;
    });

    // ── NEW: Analyst performance matrix ──
    const an = colIdx.analyst > -1 ? String(row[colIdx.analyst] || '').trim() : '';
    if (an) {
      if (!analystMatrix[an]) analystMatrix[an] = { name: an, count: 0, defectSum: 0, cycleSum: 0, cycleCount: 0 };
      analystMatrix[an].count++;
      const sc = parseFloat(row[colIdx.binaryDefectScore]);
      if (!isNaN(sc)) analystMatrix[an].defectSum += sc;
      const c1 = parseFloat(row[colIdx.cycleWorkToQc]);
      const c2 = parseFloat(row[colIdx.cycleQcToRca]);
      if (!isNaN(c1)) { analystMatrix[an].cycleSum += c1; analystMatrix[an].cycleCount++; }
      if (!isNaN(c2)) { analystMatrix[an].cycleSum += c2; analystMatrix[an].cycleCount++; }
    }

    // ── NEW: Phase × Month heatmap ──
    if (monthKey) {
      if (!phaseMonthMatrix[monthKey]) phaseMonthMatrix[monthKey] = { p2:0, p2t:0, p3:0, p3t:0, p4:0, p4t:0, p5:0, p5t:0, p6:0, p6t:0, p7:0, p7t:0 };
      const trackHeat = (ph, val) => {
        if (!val) return;
        if (val === 'Yes' || val === 'N/A') { phaseMonthMatrix[monthKey][ph+'t']++; }
        else if (val === 'No') { phaseMonthMatrix[monthKey][ph+'t']++; phaseMonthMatrix[monthKey][ph]++; }
      };
      trackHeat('p2', _safeStr(row, colIdx.p2Baseline));
      trackHeat('p3', _safeStr(row, colIdx.p3Baseline));
      trackHeat('p4', _safeStr(row, colIdx.p4ShortFull));
      trackHeat('p5', _safeStr(row, colIdx.p5Decision));
      trackHeat('p6', _safeStr(row, colIdx.p6Template));
      const p7AnyDefect = ['p7Vague','p7BrokenStrings','p7UpstreamFlags','p7ExtEnquiry'].some(k => {
        const v = _safeStr(row, colIdx[k]);
        return v.includes('Defect');
      }) ? 'No' : 'Yes';
      trackHeat('p7', p7AnyDefect);
    }

    // Cycle times
    const w2q = parseFloat(row[colIdx.cycleWorkToQc]);
    const q2r = parseFloat(row[colIdx.cycleQcToRca]);
    if (!isNaN(w2q)) {
      stats.cycleTime.workToQc.push(w2q);
      if (isValidDate && weekKey) {
        cycleWeekly[weekKey].w2q.push(w2q);
        if (monthKey) cycleMonthly[monthKey].w2q.push(w2q);
      }
    }
    if (!isNaN(q2r)) {
      stats.cycleTime.qcToRca.push(q2r);
      if (isValidDate && weekKey) {
        cycleWeekly[weekKey].q2r.push(q2r);
        if (monthKey) cycleMonthly[monthKey].q2r.push(q2r);
      }
    }
  });

  // ── NEW: Assemble extended analytics ──
  stats.trendDailyByDefect = Object.entries(dailyDefects)
    .sort((a,b) => a[0].localeCompare(b[0]))
    .map(([date, o]) => ({ date, Critical:o.Critical||0, Major:o.Major||0, Minor:o.Minor||0, None:o.None||0, Unknown:o.Unknown||0 }));

  stats.paretoFailures = Object.entries(failureReasons).sort((a,b) => b[1]-a[1]).slice(0, 15);

  stats.analystMatrix = Object.values(analystMatrix)
    .filter(a => a.count >= 2)
    .map(a => ({
      name: a.name,
      count: a.count,
      avgScore: +(a.defectSum / a.count).toFixed(2),
      avgCycle: a.cycleCount ? +(a.cycleSum / a.cycleCount).toFixed(1) : 0
    }));

  stats.phaseHeatmap = Object.entries(phaseMonthMatrix)
    .sort((a,b) => a[0].localeCompare(b[0]))
    .slice(-12)
    .map(([month, o]) => {
      const pct = (k) => o[k+'t'] ? +(o[k]/o[k+'t']*100).toFixed(1) : 0;
      return { month, p2: pct('p2'), p3: pct('p3'), p4: pct('p4'), p5: pct('p5'), p6: pct('p6'), p7: pct('p7') };
    });

  stats.cycleHistogramW2Q = buildHistogram(stats.cycleTime.workToQc, 7);
  stats.cycleHistogramQ2R = buildHistogram(stats.cycleTime.qcToRca, 7);

  // ── Derived metrics ──
  if (stats.cycleTime.workToQc.length) {
    stats.cycleTime.avgWorkToQc = stats.cycleTime.workToQc.reduce((a, b) => a + b, 0) / stats.cycleTime.workToQc.length;
  }
  if (stats.cycleTime.qcToRca.length) {
    stats.cycleTime.avgQcToRca = stats.cycleTime.qcToRca.reduce((a, b) => a + b, 0) / stats.cycleTime.qcToRca.length;
  }

  Object.keys(phaseFailure).forEach(k => {
    const ph = phaseFailure[k];
    ph.total = ph.pass + ph.fail;
    ph.failRate = ph.total > 0 ? +(ph.fail / ph.total * 100).toFixed(1) : 0;
  });

  const totalAgreed = agreeYes + agreeNo;
  stats.agreementRate   = totalAgreed > 0 ? +(agreeYes / totalAgreed * 100).toFixed(1) : 0;
  stats.agreementBreakdown = { yes: agreeYes, no: agreeNo, other: agreeOther };
  stats.avgDefectScore  = defectCount > 0 ? +(defectSum / defectCount).toFixed(2) : 0;
  stats.phaseFailure    = phaseFailure;
  stats.topTypologies   = _topN(typologyCounts, 10);
  stats.topRiskTags     = _topN(tagCounts, 10);
  stats.systemicVsHuman = systemicVsHuman;

  if (stats.total > 0) {
    stats.criticalRate = +((stats.criticalCount / stats.total) * 100).toFixed(1);
    stats.flagRate     = +((stats.flagged.flagToTL / stats.total) * 100).toFixed(1);
    stats.appealRate   = +((stats.flagged.toBeAppealed / stats.total) * 100).toFixed(1);
    if (stats.thisMonth > 0) stats.avgPerDay = +(stats.thisMonth / 30).toFixed(1);
  }

  stats.trendDaily = Object.entries(dailyTrend).sort((a, b) => a[0].localeCompare(b[0])).map(([date, count]) => ({ date, count }));
  stats.trendWeekly = Object.entries(weeklyTrend).sort((a, b) => a[0].localeCompare(b[0])).slice(-26).map(([week, count]) => ({ week, count }));
  stats.trendMonthly = Object.entries(monthlyTrend).sort((a, b) => a[0].localeCompare(b[0])).slice(-12).map(([month, count]) => ({ month, count }));

  stats.cycleTimeTrendWeekly = Object.entries(cycleWeekly).sort((a, b) => a[0].localeCompare(b[0])).slice(-26).map(([week, v]) => ({
    week,
    avgWorkToQc: v.w2q.length ? +(v.w2q.reduce((a, b) => a + b, 0) / v.w2q.length).toFixed(2) : null,
    avgQcToRca:  v.q2r.length ? +(v.q2r.reduce((a, b) => a + b, 0) / v.q2r.length).toFixed(2) : null
  }));
  stats.cycleTimeTrendMonthly = Object.entries(cycleMonthly).sort((a, b) => a[0].localeCompare(b[0])).slice(-12).map(([month, v]) => ({
    month,
    avgWorkToQc: v.w2q.length ? +(v.w2q.reduce((a, b) => a + b, 0) / v.w2q.length).toFixed(2) : null,
    avgQcToRca:  v.q2r.length ? +(v.q2r.reduce((a, b) => a + b, 0) / v.q2r.length).toFixed(2) : null
  }));

  stats.topConductors  = _topN(stats.byConductor, 10);
  stats.topQcReviewers = _topN(stats.byQcReviewer, 10);
  stats.topAnalysts    = _topN(stats.byAnalyst, 10);
  stats.topTeams       = _topN(stats.byTeam, 10);
  stats.topAgencies    = _topN(stats.byAgency, 10);
  stats.topAuthorities = _topN(stats.byAuthority, 10);
  stats.topCountries   = _topN(stats.byCountry, 10);

  return stats;
}

