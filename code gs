// ─────────────────────────────────────────────────────────────
// 2. CONSTANTS
// ─────────────────────────────────────────────────────────────
const FEED_SHEET_NAME     = 'Daily Input Feed';
const FEED_REFRESH_KEY    = 'feed_last_refresh';
const SUBMITTED_CACHE_KEY = 'submitted_case_ids_v1';
const SUBMITTED_CACHE_TTL = 300;   // 5 minutes
const HEADER_CACHE_KEY    = 'daily_input_headers_v1';
const HEADER_CACHE_TTL    = 60;    // 1 minute
const LOCK_TTL            = 1800;  // 30 minutes

// ─────────────────────────────────────────────────────────────
// 3. HEALTH CHECK / PING
// ─────────────────────────────────────────────────────────────
function ping() {
  return {
    success: true,
    now: new Date().toISOString(),
    user: Session.getActiveUser().getEmail() || 'anonymous',
    version: '4.2'
  };
}

// ─────────────────────────────────────────────────────────────
// 4. CASE LOCKING
// ─────────────────────────────────────────────────────────────
function lockCase(caseId) {
  const t0 = Date.now();
  try {
    const cache = CacheService.getScriptCache();
    const key   = 'lock_' + caseId;
    const owner = Session.getActiveUser().getEmail() || 'anonymous';
    const existing = cache.get(key);
    if (existing && existing !== owner) {
      return _meta({ success: false, lockedBy: existing, caseId }, t0);
    }
    cache.put(key, owner, LOCK_TTL);
    return _meta({ success: true, lockedBy: owner, caseId }, t0);
  } catch (e) {
    return _meta({ success: false, error: e.message }, t0);
  }
}

function refreshLock(caseId) {
  const t0 = Date.now();
  try {
    const cache = CacheService.getScriptCache();
    const key   = 'lock_' + caseId;
    const owner = Session.getActiveUser().getEmail() || 'anonymous';
    const existing = cache.get(key);
    if (existing === owner) {
      cache.put(key, owner, LOCK_TTL);
      return _meta({ success: true }, t0);
    }
    return _meta({ success: false, lockedBy: existing || null }, t0);
  } catch (e) {
    return _meta({ success: false, error: e.message }, t0);
  }
}

function unlockCase(caseId) {
  const t0 = Date.now();
  try {
    const cache = CacheService.getScriptCache();
    const key   = 'lock_' + caseId;
    const owner = Session.getActiveUser().getEmail() || 'anonymous';
    const existing = cache.get(key);
    if (!existing || existing === owner) {
      cache.remove(key);
      return _meta({ success: true }, t0);
    }
    return _meta({ success: false }, t0);
  } catch (e) {
    return _meta({ success: false, error: e.message }, t0);
  }
}

// ─────────────────────────────────────────────────────────────
// 5. SUBMITTED-CASE CACHE (RCA Results lookup)
// ─────────────────────────────────────────────────────────────
function _getSubmittedCases(ss) {
  const cache = CacheService.getScriptCache();
  const cached = cache.get(SUBMITTED_CACHE_KEY);
  if (cached) {
    try {
      return { set: new Set(JSON.parse(cached)), cached: true };
    } catch (e) {
      cache.remove(SUBMITTED_CACHE_KEY); // evict poison
    }
  }

  const submittedCases = new Set();
  const resultsSheet   = ss.getSheetByName('RCA Results');
  if (!resultsSheet) return { set: submittedCases, cached: false, missing: true };

  const data = resultsSheet.getDataRange().getValues();
  let colIdx = 3;
  if (data.length > 0) {
    const headers = data[0].map(h => (h || '').toString().toLowerCase().trim());
    const idx = headers.indexOf('case id');
    if (idx > -1) colIdx = idx;
  }
  for (let r = 1; r < data.length; r++) {
    const v = data[r][colIdx];
    if (v) submittedCases.add(v.toString().trim());
  }

  try {
    const s = JSON.stringify([...submittedCases]);
    if (s.length < 90000) cache.put(SUBMITTED_CACHE_KEY, s, SUBMITTED_CACHE_TTL);
  } catch (e) { /* not critical */ }
  return { set: submittedCases, cached: false };
}

function _invalidateSubmittedCache() {
  CacheService.getScriptCache().remove(SUBMITTED_CACHE_KEY);
}

// ─────────────────────────────────────────────────────────────
// 6. HEADER CACHE
// ─────────────────────────────────────────────────────────────
function _getInputHeaders(sheet) {
  const cache = CacheService.getScriptCache();
  const cached = cache.get(HEADER_CACHE_KEY);
  if (cached) {
    try { return { headers: JSON.parse(cached), cached: true }; }
    catch (e) { /* fall through */ }
  }
  const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn())
                       .getDisplayValues()[0]
                       .map(h => (h || '').toString().toLowerCase().trim());
  try { cache.put(HEADER_CACHE_KEY, JSON.stringify(headers), HEADER_CACHE_TTL); }
  catch (e) { /* not critical */ }
  return { headers, cached: false };
}

// ─────────────────────────────────────────────────────────────
// 7. FEED SHEET — pre-computed mirror of Daily Input
// ─────────────────────────────────────────────────────────────
function refreshFeedSheet() {
  const t0 = Date.now();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const src = ss.getSheetByName('Daily Input');
  if (!src) throw new Error('Daily Input sheet not found');

  const lastRow = src.getLastRow();
  const lastCol = src.getLastColumn();
  if (lastRow < 2) return { rows: 0, duration: Date.now() - t0 };

  const data = src.getRange(1, 1, lastRow, lastCol).getDisplayValues();

  let feed = ss.getSheetByName(FEED_SHEET_NAME);
  const isNew = !feed;
  if (isNew) feed = ss.insertSheet(FEED_SHEET_NAME);
  else feed.clearContents();

  feed.getRange(1, 1, data.length, data[0].length).setValues(data);
  feed.setFrozenRows(1);
  CacheService.getScriptCache().put(FEED_REFRESH_KEY, String(Date.now()), 24 * 3600);

  return { isNewSheet: isNew, rows: data.length, cols: data[0].length, duration: Date.now() - t0 };
}

function getFeedStatus() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const feed = ss.getSheetByName(FEED_SHEET_NAME);
  if (!feed) return { exists: false };
  const ts = CacheService.getScriptCache().get(FEED_REFRESH_KEY);
  return {
    exists: true,
    rows: feed.getLastRow(),
    lastRefresh: ts ? new Date(parseInt(ts)).toISOString() : null
  };
}

// ─────────────────────────────────────────────────────────────
// 8. GET PENDING CASES (main dashboard loader)
// ─────────────────────────────────────────────────────────────
function getPendingCases() {
  const t0 = Date.now();
  const diag = { stages: {} };

  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();

    let sheet = ss.getSheetByName(FEED_SHEET_NAME);
    const usingFeed = !!sheet;
    if (!sheet) {
      sheet = ss.getSheetByName('Daily Input');
      if (!sheet) {
        return _meta({
          success: false,
          error: 'Neither "Daily Input Feed" nor "Daily Input" sheet found. Run refreshFeedSheet() first.',
          stage: 'openSheet'
        }, t0, diag);
      }
    }
    diag.usingFeed = usingFeed;

    const tRead = Date.now();
    const lastRow = sheet.getLastRow();
    const lastCol = sheet.getLastColumn();
    diag.sheetRows = lastRow;
    diag.sheetCols = lastCol;

    if (lastRow < 2) {
      return _meta({ success: true, cases: [], count: 0, analytics: _emptyAnalytics() }, t0, diag);
    }

    const data = sheet.getRange(1, 1, lastRow, lastCol).getValues();
    diag.stages.readSheet = Date.now() - tRead;

    const tHeaders = Date.now();
    const headerInfo = _getInputHeaders(sheet);
    const headers = headerInfo.headers;
    diag.stages.headers = Date.now() - tHeaders;
    diag.headersCached = headerInfo.cached;

    const col      = (name) => headers.findIndex(h => h.includes(name));
    const exactCol = (name) => headers.findIndex(h => h === name);

    const cols = {
      caseId:        col('case reference id'),
      analyst:       col('employee name'),
      qcName:        col('qc name'),
      revDate:       col('review done date'),
      workDate:      col('work done date'),
      taskType:      col('task type name'),
      subteam:       col('subteam'),
      agency:        col('agency'),
      prodLine:      col('production line'),
      entity:        exactCol('entity name') > -1 ? exactCol('entity name') : col('entity name'),
      defect:        exactCol('defect')      > -1 ? exactCol('defect')      : col('defect'),
      comment:       exactCol('comment')     > -1 ? exactCol('comment')     : col('comment'),
      reviewResult:  col('review result'),
      batchId:       col('batch id'),
      lob:           exactCol('lob')         > -1 ? exactCol('lob')         : col('lob'),
      empEmail:      col('employee email'),
      region:        exactCol('entity region') > -1
                       ? exactCol('entity region')
                       : headers.findIndex(h => h.includes('entity region') && !h.includes('grouped')),
      lmEmail:       col('line manager email'),
      recs:          col('reviews recommendations'),
      appealOutcome: col('appeal outcome'),
      regionGrouped: col('entity region grouped'),
      probation:     col('is probation'),
      remediation:   col('remediation required'),
      wasAppealed:   col('was appealed')
    };

    let qcLink = exactCol('qc bo link');
    if (qcLink === -1) qcLink = exactCol('qc link');
    if (qcLink === -1) qcLink = exactCol('review id');
    if (qcLink === -1) qcLink = headers.findIndex(h =>
        h.includes('qc bo link') || h.includes('qc link') || h.includes('review link') || h.includes('review id'));

    let boLink = exactCol('bo link');
    if (boLink === -1) boLink = exactCol('qc list of reviews zeus bo link');
    if (boLink === -1) boLink = headers.findIndex(h =>
        h.includes('bo link') || h.includes('back office') || h.includes('zeus'));
    cols.qcLink = qcLink;
    cols.boLink = boLink;

    const extractDate = (val) => {
      if (!val) return '';
      if (val instanceof Date) return Utilities.formatDate(val, Session.getScriptTimeZone(), 'yyyy-MM-dd');
      const s = val.toString();
      return /^\d{4}-\d{2}-\d{2}/.test(s) ? s.slice(0, 10) : s;
    };

    const safeCell = (row, idx) =>
      (idx > -1 && row[idx] != null) ? row[idx].toString().trim() : '';

    const extractUrl = (raw) => {
      const m = String(raw).match(/https?:\/\/[^\s"')>]+/);
      return m ? m[0] : raw;
    };

    const tSubmitted = Date.now();
    const submittedInfo = _getSubmittedCases(ss);
    const submittedCases = submittedInfo.set;
    diag.stages.submitted = Date.now() - tSubmitted;
    diag.submittedCached = submittedInfo.cached;

    const tBuild = Date.now();
    const cache        = CacheService.getScriptCache();
    const today        = new Date();
    const currentUser  = Session.getActiveUser().getEmail() || '';
    const pendingCases = [];
    const analytics    = _emptyAnalytics();

    const caseIdCounts = Object.create(null);
    const lockKeys     = [];
    const rowsToProcess = [];

    for (let i = 1; i < data.length; i++) {
      const row    = data[i];
      const caseId = safeCell(row, cols.caseId);
      if (!caseId) continue;

      caseIdCounts[caseId] = (caseIdCounts[caseId] || 0) + 1;
      if (submittedCases.has(caseId)) continue;

      rowsToProcess.push({ row, index: i, caseId });
      lockKeys.push('lock_' + caseId);
    }

    const lockMap = lockKeys.length > 0 ? cache.getAll(lockKeys) : {};

    for (let i = 0; i < rowsToProcess.length; i++) {
      const item    = rowsToProcess[i];
      const row     = item.row;
      const caseId  = item.caseId;
      const lockVal = lockMap['lock_' + caseId] || '';

      const rawDefect = safeCell(row, cols.defect).toUpperCase();
      let finalDefect = 'None';
      if      (rawDefect === 'CRITICAL') finalDefect = 'Outcome';
      else if (rawDefect === 'MAJOR')    finalDefect = 'Major';
      else if (rawDefect === 'MINOR')    finalDefect = 'Minor';
      else if (rawDefect)                finalDefect = rawDefect;

      const rawTask   = safeCell(row, cols.taskType);
      const cleanTask = rawTask.replace(/^FIU_/i, '');
      const product   = rawTask.toUpperCase().includes('BUSINESS') ? 'BUSINESS' : 'RETAIL';

      const details    = safeCell(row, cols.comment);
      const hashtags   = details.match(/#[\w_]+/g) || [];
      const batchIdStr = safeCell(row, cols.batchId);
      const proactive  = (batchIdStr === '0') ? 'Yes' : 'No';

      const reviewDate = extractDate(cols.revDate > -1 ? row[cols.revDate] : null);
      const slaDays    = reviewDate ? Math.floor((today - new Date(reviewDate)) / 86400000) : null;

      pendingCases.push({
        rowNum:              item.index + 1,
        caseId:              caseId,
        lockedBy:            lockVal,
        isLockedByMe:        lockVal === currentUser,
        analyst:             safeCell(row, cols.analyst),
        qcName:              safeCell(row, cols.qcName),
        reviewResult:        safeCell(row, cols.reviewResult) || 'N/A',
        reviewDoneDate:      reviewDate,
        workDoneDate:        extractDate(cols.workDate > -1 ? row[cols.workDate] : null),
        taskType:            cleanTask,
        entityName:          safeCell(row, cols.entity) || 'N/A',
        agency:              safeCell(row, cols.agency),
        team:                safeCell(row, cols.subteam)  || 'Unknown',
        productionLine:      safeCell(row, cols.prodLine) || 'Unknown',
        product:             product,
        details:             details,
        hashtags:            hashtags,
        defect:              finalDefect,
        hasFailedOutcome:    (rawDefect === 'CRITICAL') ? 'Yes' : 'No',
        proactive:           proactive,
        isDuplicate:         caseIdCounts[caseId] > 1,
        batchId:             batchIdStr,
        slaDays:             slaDays,
        lob:                 safeCell(row, cols.lob),
        empEmail:            safeCell(row, cols.empEmail),
        entityRegion:        safeCell(row, cols.region),
        lmEmail:             safeCell(row, cols.lmEmail),
        recs:                safeCell(row, cols.recs),
        boLink:              extractUrl(safeCell(row, cols.boLink)),
        qcLink:              extractUrl(safeCell(row, cols.qcLink)),
        appealOutcome:       safeCell(row, cols.appealOutcome),
        entityRegionGrouped: safeCell(row, cols.regionGrouped),
        isProbation:         safeCell(row, cols.probation),
        remediationRequired: safeCell(row, cols.remediation),
        wasAppealed:         safeCell(row, cols.wasAppealed)
      });

      const t = pendingCases[pendingCases.length - 1].team;
      analytics.total++;
      if (product === 'BUSINESS') analytics.business++; else analytics.retail++;
      analytics.defects[finalDefect] = (analytics.defects[finalDefect] || 0) + 1;
      analytics.teams[t] = (analytics.teams[t] || 0) + 1;
      if (proactive === 'Yes') analytics.proactive++;
      if (lockVal && lockVal !== currentUser) analytics.lockedByOthers++;
      if (lockVal === currentUser) analytics.lockedByMe++;
      if (slaDays != null && slaDays > 5) analytics.slaBreached++;
      if (rawDefect === 'CRITICAL') analytics.criticalDefects++;
    }
    diag.stages.build = Date.now() - tBuild;

    const tSort = Date.now();
    pendingCases.sort((a, b) => {
      const ta = a.reviewDoneDate ? new Date(a.reviewDoneDate).getTime() : 0;
      const tb = b.reviewDoneDate ? new Date(b.reviewDoneDate).getTime() : 0;
      return tb - ta;
    });
    diag.stages.sort = Date.now() - tSort;

    analytics.teams = _topN(analytics.teams, 5);
    analytics.sheetRows = data.length;

    return _meta({ success: true, cases: pendingCases, count: pendingCases.length, analytics }, t0, diag);

  } catch (e) {
    return _meta({ success: false, error: e.stack || e.toString(), stage: 'unknown' }, t0, diag);
  }
}

// ─────────────────────────────────────────────────────────────
// 9. SUBMIT RCA
// ─────────────────────────────────────────────────────────────
function submitRCA(data) {
  const t0 = Date.now();
  if (!data || typeof data !== 'object') throw new Error('Invalid payload');
  if (!data.caseId) throw new Error('Missing caseId');

  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const resultsSheet = ss.getSheetByName('RCA Results');
    if (!resultsSheet) throw new Error('"RCA Results" sheet not found.');

    unlockCase(data.caseId);
    _invalidateSubmittedCache();

    const parseDate = (v) => {
      if (!v || v === 'N/A') return null;
      const d = new Date(v);
      return isNaN(d.getTime()) ? null : d;
    };

    const wDate = parseDate(data.workDoneDate);
    const rDate = parseDate(data.reviewDoneDate);
    const sDate = new Date();

    const days = (a, b) => {
      if (!a || !b) return '';
      const d = Math.floor((b - a) / 86400000);
      return d >= 0 ? d : 0;
    };
    const cycleWorkToQc = (wDate && rDate) ? days(wDate, rDate) : '';
    const cycleQcToRca  = rDate             ? days(rDate, sDate) : '';

    const fields = [
      sDate, Session.getActiveUser().getEmail(), data.qcName || '', data.caseId, data.product,
      data.authority, data.country, data.origin, data.p1Scope, data.duplicateIdentified,
      data.p1DuplicateAction, data.prevNote, data.escalation, data.tag, data.typology,
      data.p1MultiSuspect, data.p1AnalystIdentified, data.p2Baseline, data.p2BaselineFail,
      data.p2Osint, data.p2OsintFail, data.p2OsintDoc, data.p3Baseline, data.p3BaselineFail,
      data.p3Module, data.p3ModuleFail, data.p4ShortFull, data.p4ReqCount, data.p4RevCount,
      data.p4CorrectAll, data.p4AuDetails, data.p5Decision, data.p5ActionError, data.p5Juris,
      data.p5JurisTxt, data.p5Excep, data.p5ExcepTxt, data.p5Biz, data.p5BizTxt,
      data.p6Edd, data.p6EddTxt, data.p6Juris, data.p6JurisTxt, data.p6Template, data.p6TemplateTxt,
      data.p6Dante, data.p6DanteTxt, data.p6Tags, data.p6TagsTxt, data.p6Alerts, data.p6AlertsTxt,
      data.p6Offboard, data.p6OffboardTxt, data.p6Suspects, data.p6SuspectsTxt, data.p6Refunds,
      data.p6RefundsTxt, data.p7Vague, data.p7BrokenStrings, data.p7UpstreamFlags, data.p7ExtEnquiry,
      data.rcaOutcome, data.rcaSysFail, data.rcaSysFailTxt, data.rcaAgree, data.rcaErrSource,
      data.rcaUpdate, data.rcaComments, data.flagToTL, data.toBeAppealed, data.failAccepted,
      data.reviewDoneDate, data.workDoneDate, data.reviewResult, data.taskType, data.entityName,
      data.agency, data.team, data.analyst, data.proactive, data.outcomeDefect, data.qcKeywords,
      data.scannerRedFlags, data.lob, data.empEmail, data.entityRegion, data.batchId, data.lmEmail,
      data.recs, data.boLink, data.qcLink, data.appealOutcome, data.entityRegionGrouped,
      data.isProbation, data.remediationRequired, data.wasAppealed, cycleWorkToQc, cycleQcToRca,
      data.binaryDefectScore, data.taskTypeMatch, data.correctTaskType
    ];

    const normalised = fields.map(v => {
      if (typeof v === 'boolean') return v ? 'TRUE' : 'FALSE';
      if (v === undefined || v === null) return '';
      return v;
    });

    if (normalised.length !== CURRENT_SCHEMA.length) {
      throw new Error(
        `Schema mismatch: expected ${CURRENT_SCHEMA.length} columns, got ${normalised.length}. ` +
        `Aborting to prevent data corruption.`
      );
    }

    resultsSheet.appendRow(normalised);

    // ── Auto-remove processed case from Daily Input & Feed ──
    try {
      _removeCaseFromSource(data.caseId, parseInt(data.rowNum) || null);
    } catch (e) {
      console.warn('Auto-delete from source sheets failed (non-fatal):', e);
    }

    return _meta({ success: true, rowAppended: true }, t0);

  } catch (e) {
    return _meta({ success: false, error: e.message }, t0);
  }
}

// ── Helper: remove a case row from Daily Input + Feed after RCA submission ──
function _removeCaseFromSource(caseId, rowNum) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const out = { daily: null, feed: null };

  // Daily Input
  const daily = ss.getSheetByName('Daily Input');
  if (daily) {
    try {
      const headers = daily.getRange(1, 1, 1, daily.getLastColumn()).getValues()[0]
        .map(h => String(h || '').toLowerCase().trim());
      const caseIdCol = headers.findIndex(h => h.includes('case reference id') || h.includes('case id'));
      let deleted = false;

      if (rowNum && rowNum > 1) {
        try {
          if (caseIdCol > -1) {
            const val = daily.getRange(rowNum, caseIdCol + 1).getValue();
            if (String(val).trim() === String(caseId).trim()) {
              daily.deleteRow(rowNum);
              deleted = true;
              out.daily = { method: 'exact', rowNum };
            }
          }
        } catch (e) { /* fallback to search */ }
      }

      if (!deleted && caseIdCol > -1) {
        const lastRow = daily.getLastRow();
        if (lastRow > 1) {
          const colVals = daily.getRange(2, caseIdCol + 1, lastRow - 1, 1).getValues();
          const toDelete = [];
          for (let i = 0; i < colVals.length; i++) {
            if (String(colVals[i][0]).trim() === String(caseId).trim()) {
              toDelete.push(i + 2);
            }
          }
          if (toDelete.length) {
            for (let i = toDelete.length - 1; i >= 0; i--) {
              daily.deleteRow(toDelete[i]);
            }
            out.daily = { method: 'search', deleted: toDelete.length, rows: toDelete };
          }
        }
      }
    } catch (e) {
      out.daily = { error: e.message };
    }
  }

  // Feed sheet (1:1 row mirror at time of last refresh; try exact row first)
  const feed = ss.getSheetByName(FEED_SHEET_NAME);
  if (feed && rowNum && rowNum > 1) {
    try {
      const feedLast = feed.getLastRow();
      if (rowNum <= feedLast) {
        const headers = feed.getRange(1, 1, 1, feed.getLastColumn()).getValues()[0]
          .map(h => String(h || '').toLowerCase().trim());
        const caseIdCol = headers.findIndex(h => h.includes('case reference id') || h.includes('case id'));
        if (caseIdCol > -1) {
          const val = feed.getRange(rowNum, caseIdCol + 1).getValue();
          if (String(val).trim() === String(caseId).trim()) {
            feed.deleteRow(rowNum);
            out.feed = { method: 'exact', rowNum };
          }
        }
      }
    } catch (e) {
      out.feed = { error: e.message };
    }
  }

  // Purge stale caches so next load rebuilds correctly
  _invalidateSubmittedCache();
  CacheService.getScriptCache().remove(HEADER_CACHE_KEY);
  CacheService.getScriptCache().remove(FEED_REFRESH_KEY);

  return out;
}

// ─────────────────────────────────────────────────────────────
// 10. HELPERS
// ─────────────────────────────────────────────────────────────
function _topN(obj, n) {
  return Object.fromEntries(
    Object.entries(obj).sort((a, b) => b[1] - a[1]).slice(0, n)
  );
}

function _emptyAnalytics() {
  return {
    total: 0, retail: 0, business: 0, proactive: 0,
    criticalDefects: 0, slaBreached: 0,
    lockedByMe: 0, lockedByOthers: 0, sheetRows: 0,
    defects: {}, teams: {}
  };
}

function _meta(payload, t0, diag) {
  payload.duration = Date.now() - t0;
  if (diag) {
    payload.stages = diag.stages;
    if (diag.usingFeed !== undefined) payload.usingFeed = diag.usingFeed;
    payload.headersCached   = !!diag.headersCached;
    payload.submittedCached = !!diag.submittedCached;
    if (diag.sheetRows) payload.sheetRows = diag.sheetRows;
  }
  return payload;
}

// ─────────────────────────────────────────────────────────────
// 11. DIAGNOSTICS
// ─────────────────────────────────────────────────────────────
function diagnoseFull() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const out = {};
