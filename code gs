  function asBool(idx) { if (idx == null || idx < 0) return false; return String(row[idx]).toUpperCase() === 'TRUE'; }

  var dateCol = f.dateField || 'reviewDate'; var colForDate = colIdx[dateCol];
  if (colForDate != null && colForDate >= 0) {
    var tsRaw = row[colForDate]; var ts = tsRaw instanceof Date ? tsRaw : new Date(tsRaw);
    if (isNaN(ts.getTime())) return false;
    if (f.dateFrom) { var from = new Date(f.dateFrom); if (!isNaN(from.getTime()) && ts < from) return false; }
    if (f.dateTo) { var to = new Date(f.dateTo); if (!isNaN(to.getTime())) { to.setHours(23, 59, 59, 999); if (ts > to) return false; } }
  } else if (f.dateFrom || f.dateTo) { return false; }

  if (!eq(colIdx.conductor, f.conductor)) return false; if (!eq(colIdx.qcReviewer, f.qcReviewer)) return false; if (!eq(colIdx.analyst, f.analyst)) return false; if (!eq(colIdx.team, f.team)) return false; if (!eq(colIdx.agency, f.agency)) return false; if (!eq(colIdx.product, f.product)) return false; if (!eq(colIdx.country, f.country)) return false; if (!eq(colIdx.authority, f.authority)) return false; if (!eq(colIdx.origin, f.origin)) return false; if (!eq(colIdx.taskType, f.taskType)) return false; if (!eq(colIdx.errorSource, f.errorSource)) return false;

  if (f.rcaAgree) { var rcaIdx = colIdx.rcaAgree, stored = ''; if (rcaIdx >= 0) { var parts = String(row[rcaIdx] || '').split(/[\s\-]/); stored = parts[0] || ''; } if (stored !== f.rcaAgree) return false; }
  if (f.defect) { var raw = colIdx.outcomeDefect >= 0 ? String(row[colIdx.outcomeDefect] || '') : ''; if (raw !== f.defect) return false; }
  if (f.typology && !includesAny(colIdx.typologies, f.typology)) return false; if (f.tag && !includesAny(colIdx.riskTags, f.tag)) return false;

  if (f.flagToTL !== undefined && f.flagToTL !== null) { if (asBool(colIdx.flagToTL) !== f.flagToTL) return false; }
  if (f.toBeAppealed !== undefined && f.toBeAppealed !== null) { if (asBool(colIdx.toBeAppealed) !== f.toBeAppealed) return false; }
  if (f.failAccepted !== undefined && f.failAccepted !== null) { if (asBool(colIdx.failAccepted) !== f.failAccepted) return false; }
