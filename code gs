      for (var pi = 0; pi < PHASE_QUESTION_CONFIG.length; pi++) { var cfg = PHASE_QUESTION_CONFIG[pi]; if (cfg.phase !== phaseNum) continue; var pidx = colIdx[cfg.key]; if (pidx == null || pidx < 0) continue; if (String(row[pidx] || '') === cfg.failValue) { anyFail = true; break; } }
      if (!anyFail) return false;
    }
  }

  if (f.search) { var s = String(f.search).toLowerCase(), hay = ''; for (var hi = 0; hi < row.length; hi++) { hay += String(row[hi] == null ? '' : row[hi]) + ' '; } if (hay.toLowerCase().indexOf(s) === -1) return false; }
  return true;
}

