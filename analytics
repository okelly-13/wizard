    const llmData = a.trendDailyLlm || [];
    const labels = ['P1', 'P2', 'P3', 'P4', 'P5', 'P6'];
    const totals = labels.map((l, i) => llmData.reduce((acc, d) => acc + (d['p'+(i+1)] || 0), 0));
    charts.llmBar = new Chart(barCanvas, { type: 'bar', data: { labels, datasets: [{ label: 'Failures', data: totals, backgroundColor: cssVar('--chart-purple'), borderRadius: 4 }]}, options: chartBaseOpts({ yLabel: 'Failures', noData: llmData.length === 0 }) });

