  function renderTopConductors(a)  { setHTML('rcaTopConductors',  _leaderboard(a.topConductors)); }
  function renderTopQcReviewers(a) { setHTML('rcaTopQcReviewers', _leaderboard(a.topQcReviewers)); }
  function setHTML(id, html) { const el = $(id); if (el) el.innerHTML = html; }

  function renderLlmCharts(a) {
