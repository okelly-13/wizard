    const datasets = labels.map((l, i) => ({ label: l, data: llmData.map(d => d['p'+(i+1)] || 0), borderColor: colors[i % 6], backgroundColor: 'transparent', tension: 0.3, borderWidth: 2 }));
    charts.llmLine = new Chart(lineCanvas, { type: 'line', data: { labels: lineLabels, datasets }, options: { ...chartBaseOpts({ noData: llmData.length === 0 }), plugins: { legend: { display: true, labels: { color: cssVar('--chart-tick'), font: { size: 10 } } } } } });
