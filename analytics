  function submitActionItem(idx) {
    const item = actionCart[idx]; if (!item) return;
    google.script.run
      .withSuccessHandler(() => { showToast({ title: 'Saved to Action Items', type: 'success' }); item.status = 'saved'; renderActionDrawer(); })
      .withFailureHandler(err => showToast({ title: 'Save failed', description: err.message, type: 'error' }))
      .logActionItem(item);
  }

  function pushAllToSheet() {
    const unsaved = actionCart.filter(i => i.status !== 'saved');
    if (!unsaved.length) { showToast({ title: 'All items already saved' }); return; }
    let done = 0;
    unsaved.forEach(item => {
      google.script.run
        .withSuccessHandler(() => { done++; if (done === unsaved.length) { showToast({ title: 'All saved', type: 'success' }); renderActionDrawer(); } })
        .withFailureHandler(err => showToast({ title: 'Batch save failed', description: err.message, type: 'error' }))
        .logActionItem(item);
    });
  }

  function exportJiraCsv() {
    if (!actionCart.length) { showToast({ title: 'Cart is empty', type: 'warn' }); return; }
    google.script.run
      .withSuccessHandler(resp => {
        if (!resp.success) { showToast({ title: 'Export failed', description: resp.error, type: 'error' }); return; }
        const blob = new Blob([resp.csv], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a'); a.href = url; a.download = `RCA_Jira_Import_${new Date().toISOString().slice(0,10)}.csv`; document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
        showToast({ title: 'Jira CSV exported', description: `${resp.count} rows ready for Jira bulk import`, type: 'success' });
      })
      .withFailureHandler(err => showToast({ title: 'Export error', description: err.message, type: 'error' }))
      .exportActionsToJiraCsv();
  }

  function _barList(obj, orderKeys, limit) {
    limit = limit || 8;
    const entries = orderKeys
      ? orderKeys.filter(k => obj[k]).map(k => [k, obj[k]])
      : Object.entries(obj || {}).sort((a, b) => b[1] - a[1]).slice(0, limit);
    if (entries.length === 0) return '<div class="analytics-empty">No data</div>';
    const max = Math.max(...entries.map(([, v]) => v), 1);
    return entries.map(([k, v]) =>
      `<div class="bar-row">
         <div class="bar-label" title="${escapeHtml(k)}">${escapeHtml(k)}</div>
         <div class="bar-track"><div class="bar-fill" style="width:${(v / max) * 100}%"></div></div>
         <div class="bar-value">${v}</div>
       </div>`
    ).join('');
  }

  function _leaderboard(obj) {
    const entries = Object.entries(obj || {});
    if (entries.length === 0) return '<div class="analytics-empty">No data</div>';
    const medals = ['gold', 'silver', 'bronze'];
    return entries.map(([name, count], i) => {
      const rankCls = i < 3 ? medals[i] : '';
      const shortName = name.length > 28 ? name.slice(0, 26) + '…' : name;
      return `<div class="lb-row" data-name="${escapeHtml(name)}" data-field="conductor">
        <div class="lb-rank ${rankCls}">${i + 1}</div>
        <div class="lb-name" title="${escapeHtml(name)}">${escapeHtml(shortName)}</div>
        <div class="lb-count">${count}</div>
      </div>`;
    }).join('');
  }

  document.addEventListener('click', (e) => {
    const row = e.target.closest('.lb-row');
    if (row && row.dataset.name) quickFilterBy(row.dataset.name, row.dataset.field || 'conductor');
  });

  function quickFilterBy(value, field) {
    const map = {
      conductor: 'rcaFilterConductor', qcReviewer: 'rcaFilterQcReviewer',
      analyst:   'rcaFilterAnalyst',   team:       'rcaFilterTeam',
      agency:    'rcaFilterAgency',    product:    'rcaFilterProduct'
    };
    const id = map[field];
    if (id && document.getElementById(id)) {
      document.getElementById(id).value = value;
      loadRcaAnalytics();
      showToast({ title: 'Filter applied', description: `${field} = ${value}`, type: 'success' });
    }
  }

  function _buildPagination(currentPage, pageSize, total, fnName) {
    const totalPages = Math.max(1, Math.ceil(total / pageSize));
    const buttons = [];
    buttons.push(`<button ${currentPage === 1 ? 'disabled' : ''} onclick="${fnName}(${currentPage - 1})">‹</button>`);
    const set = new Set([1, totalPages, currentPage, currentPage - 1, currentPage + 1]);
    if (currentPage <= 3) [2, 3, 4].forEach(p => set.add(p));
    if (currentPage >= totalPages - 2) [totalPages - 3, totalPages - 2, totalPages - 1].forEach(p => set.add(p));
    const sorted = [...set].filter(p => p >= 1 && p <= totalPages).sort((a, b) => a - b);
    let last = 0;
    sorted.forEach(p => {
      if (p - last > 1) buttons.push('<button disabled>…</button>');
      buttons.push(`<button class="${p === currentPage ? 'active' : ''}" onclick="${fnName}(${p})">${p}</button>`);
      last = p;
    });
    buttons.push(`<button ${currentPage === totalPages ? 'disabled' : ''} onclick="${fnName}(${currentPage + 1})">›</button>`);
    return buttons.join('');
  }

  function chartBaseOpts({ yLabel, noData, noDataMsg } = {}) {
    return {
      responsive: true, maintainAspectRatio: false,
      animation: { duration: 250 },
      plugins: {
        legend: { display: false },
        tooltip: { mode: 'index', intersect: false },
        ...(noData && { title: { display: true, text: noDataMsg || 'No data', color: cssVar('--chart-gray'), font: { size: 13 } } })
      },
      scales: {
        x: { grid: { display: false }, ticks: { color: cssVar('--chart-tick'), maxRotation: 0, autoSkip: true, maxTicksLimit: 12 } },
        y: {
          beginAtZero: true,
          ticks: { color: cssVar('--chart-tick'), precision: 0 },
          grid: { color: cssVar('--chart-grid') },
          title: yLabel ? { display: true, text: yLabel, color: cssVar('--chart-tick') } : undefined
        }
      }
    };
  }

  window.__rcaCleanup = function () {
    Object.keys(charts).forEach(destroyChart);
  };
})();
</script>
