    const counts = entries.map(([, v]) => v);
    const total = counts.reduce((acc, b) => acc + b, 0) || 1;
    let cum = 0;
    const cumPct = counts.map(v => { cum += v; return +(cum / total * 100).toFixed(1); });
    charts.pareto = new Chart(canvas, { type: 'bar', data: { labels, datasets: [
      { label: 'Count', data: counts, backgroundColor: cssVar('--accent'), order: 2, yAxisID: 'y', borderRadius: 4 },
      { label: 'Cumulative %', data: cumPct, type: 'line', borderColor: cssVar('--chart-orange'), backgroundColor: 'transparent', borderWidth: 2, pointRadius: 3, order: 1, yAxisID: 'y1' }
    ]}, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: true, labels: { color: cssVar('--chart-tick'), font: { size: 10 } } } }, scales: {
