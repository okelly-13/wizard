  function renderPhaseAnalysis(a) {
    const container = $('phaseGrid'); if (!container) return;
    const phaseStats = a.phaseStats || {};
    const html = PHASE_CONFIG.map(phase => {
      const phaseData = phaseStats[phase.num] || { pass: 0, fail: 0, total: 0, failRate: 0 };
      const isOpen = appState.expandedPhases.has(phase.num);
      const rateCls = phaseData.failRate > 30 ? 'rate-bad' : phaseData.failRate > 15 ? 'rate-warn' : 'rate-good';
      const questionsHtml = phase.questions.map(q => {
        const qStat = phaseData.questions && phaseData.questions[q.key] || { pass: 0, fail: 0, total: 0, failRate: 0, topReason: null };
        if (qStat.total === 0) return '';
        const safeTitle = JSON.stringify(`P${phase.num} · ${q.label}`);
        const safeSource = JSON.stringify(`P${phase.num} · ${q.label}`);
        return `<div class="phase-question">
          <div class="phase-q-label">${escapeHtml(q.label)}</div>
          <div class="phase-q-stats">
            <span class="pass-pill">✓ ${fmtNum(qStat.pass)}</span>
            <span class="fail-pill">✗ ${fmtNum(qStat.fail)}</span>
            <span style="color:var(--text-muted); font-size:10px;">${qStat.failRate}% fail</span>
          </div>
          ${qStat.topReason ? `<div class="phase-q-topfail">Top: ${escapeHtml(qStat.topReason.reason)} (${qStat.topReason.count})</div>` : ''}
          <div class="phase-q-actions">
            <button onclick="window.drillToQuestion && window.drillToQuestion('${q.key}')">🔍 Drill</button>
            <button onclick='window.flagRootCause && window.flagRootCause({title: ${safeTitle}, source: ${safeSource}, category: "Process", priority: "${qStat.failRate > 30 ? 'High' : 'Medium'}"})'>🚩 Flag</button>
          </div>
        </div>`;
      }).join('');

      const safePhaseTitle = JSON.stringify(`P${phase.num} · ${phase.title} systemic issue`);
      const safePhaseSource = JSON.stringify(`P${phase.num} · ${phase.title}`);
      return `<div class="phase-card">
        <div class="phase-card-header" onclick="window.togglePhase(${phase.num})">
          <div class="phase-num">${phase.num}</div>
          <div class="phase-title">${escapeHtml(phase.title)}</div>
          <div class="phase-rate ${rateCls}">${phaseData.failRate}% fail</div>
        </div>
        <div class="phase-body" id="phaseBody${phase.num}" style="display:${isOpen ? 'block' : 'none'};">
          ${questionsHtml || '<div class="analytics-empty">No data</div>'}
          <div style="margin-top:10px; padding-top:8px; border-top:1px solid var(--border); font-size:11px; color:var(--text-secondary);">
            ${fmtNum(phaseData.pass)} pass · ${fmtNum(phaseData.fail)} fail · ${fmtNum(phaseData.total)} total
            <button style="float:right; background:var(--danger-soft); color:var(--danger); border:none; padding:2px 8px; border-radius:4px; cursor:pointer; font-size:10px; font-weight:600;" onclick='window.flagRootCause && window.flagRootCause({title: ${safePhaseTitle}, source: ${safePhaseSource}, category: "Process"})'>🚩 Flag all</button>
          </div>
        </div>
      </div>`;
    }).join('');
    container.innerHTML = html;
  }

  window.togglePhase = function(num) {
    if (appState.expandedPhases.has(num)) appState.expandedPhases.delete(num);
    else appState.expandedPhases.add(num);
    const body = $('phaseBody' + num);
    if (body) body.style.display = appState.expandedPhases.has(num) ? 'block' : 'none';
  };
  window.expandAllPhases = function(expand) {
    appState.expandedPhases.clear();
    if (expand) PHASE_CONFIG.forEach(p => appState.expandedPhases.add(p.num));
    if (appState.analytics) renderPhaseAnalysis(appState.analytics);
  };

  window.drillToQuestion = function(questionKey) {
    $('rcaFilterSearch').value = ''; 
    $('rcaFilterPhase').value = '';
    if (appState.expandedPhases.size === 0) expandAllPhases(true);
    setTimeout(() => {
      const el = document.querySelector(`[data-qkey="${questionKey}"]`);
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 200);
  };

  function renderQuestionBreakdown(a) {
    const body = $('questionBody'); if (!body) return;
    const phaseStats = a.phaseStats || {};
    const rows = [];
    PHASE_CONFIG.forEach(phase => {
      const pData = phaseStats[phase.num] || { questions: {} };
      phase.questions.forEach(q => {
        const s = (pData.questions && pData.questions[q.key]) || { pass: 0, fail: 0, total: 0, failRate: 0 };
        if (s.total === 0) return;
        rows.push({ phase, q, s });
      });
    });
    const filter = appState.questionFilter.toLowerCase();
    const filtered = filter ? rows.filter(r => r.q.label.toLowerCase().includes(filter) || `p${r.phase.num}`.includes(filter)) : rows;
    if (!filtered.length) {
      body.innerHTML = '<tr><td colspan="7" class="analytics-empty">No data in current filter</td></tr>';
      return;
    }
    body.innerHTML = filtered.map(r => {
      const s = r.s;
      const rate = s.failRate;
      const rateColor = rate > 30 ? 'var(--danger)' : rate > 15 ? 'var(--warning)' : 'var(--success)';
      const topFail = s.topReason ? s.topReason.reason : '—';
      const safeTitle = JSON.stringify(`P${r.phase.num} · ${r.q.label}`);
      const safeSource = JSON.stringify(`P${r.phase.num} · ${r.q.label}`);
      return `<tr data-qkey="${r.q.key}" onclick='window.flagRootCause && window.flagRootCause({title: ${safeTitle}, source: ${safeSource}, category: "Process"})'>
        <td class="q-phase">P${r.phase.num}</td>
        <td class="q-label">${escapeHtml(r.q.label)}</td>
        <td class="q-num" style="color:var(--success);">${fmtNum(s.pass)}</td>
        <td class="q-num" style="color:var(--danger);">${fmtNum(s.fail)}</td>
        <td class="q-rate" style="color:${rateColor};">${rate}%</td>
        <td class="q-topfail" title="${escapeHtml(topFail)}">${escapeHtml(topFail)}</td>
        <td><button class="btn btn-ghost btn-sm" onclick='event.stopPropagation(); window.flagRootCause && window.flagRootCause({title: ${safeTitle}, source: ${safeSource}, category: "Process"}); return false;'>🚩</button></td>
      </tr>`;
    }).join('');
  }

  window.loadDrillDown = function(page) {
    appState.drillDown.page = page;
    rcaFilters = gatherFilters();
    google.script.run
      .withSuccessHandler(onDrillDownLoaded)
      .withFailureHandler(err => showToast({ title: 'Table error', description: (err && err.message) || String(err), type: 'error' }))
      .getRcaResultsTable(rcaFilters, page, PAGE_SIZE);
  };

  function onDrillDownLoaded(resp) {
    if (!resp || !resp.success) {
      showToast({ title: 'Failed', description: (resp && resp.error) || 'Unknown', type: 'error' });
      return;
    }
    appState.drillDown.rows = resp.rows || [];
    appState.drillDown.total = resp.total || 0;
    appState.drillDown.page = resp.page;
    appState.drillDown.pageSize = resp.pageSize;
    renderDrillDownTable();
  }

  function renderDrillDownTable() {
    const tbody = $('rcaTableBody'); if (!tbody) return;
    $('rcaTableCount').textContent = fmtNum(appState.drillDown.total);
    $('selectedCount').textContent = appState.selectedRows.size;

    if (!appState.drillDown.rows.length) {
      tbody.innerHTML = '<tr><td colspan="13" class="analytics-empty">No rows match the current filters</td></tr>';
      $('rcaTablePaginationInfo').textContent = '0 rows';
      $('rcaPaginationControls').innerHTML = '';
      return;
    }

    const trunc = (s, n = 60) => { const str = String(s || ''); return str.length > n ? str.slice(0, n) + '…' : str; };
    tbody.innerHTML = appState.drillDown.rows.map(r => {
      const sel = appState.selectedRows.has(r.caseId) ? 'selected' : '';
      const linkCell = (url, label) => url
        ? `<a href="${escapeHtml(url)}" target="_blank" rel="noopener" class="text-link">${label} ↗</a>`
        : `<span class="text-link disabled">—</span>`;
      return `<tr class="${sel}">
        <td class="select-col"><input type="checkbox" ${sel ? 'checked' : ''} onchange="window.toggleRowSelection('${escapeJs(r.caseId)}', this.checked)"></td>
        <td>${escapeHtml(r.timestamp)}</td>
        <td><strong>${escapeHtml(r.caseId)}</strong></td>
        <td><span class="defect-pill defect-pill-${escapeHtml(r.defect || 'Unknown')}">${escapeHtml(r.defect || '—')}</span></td>
        <td>${escapeHtml(r.product)}</td>
        <td>${escapeHtml(r.analyst)}</td>
        <td>${escapeHtml(r.qcReviewer)}</td>
        <td>${escapeHtml(r.errorSource)}</td>
        <td><strong>${escapeHtml(String(r.binaryDefectScore || '0'))}</strong></td>
        <td>
          ${r.flagToTL     ? '<span class="action-pill flag">🚩 TL</span>' : ''}
          ${r.toBeAppealed ? '<span class="action-pill appeal">⚖️ Appeal</span>' : ''}
          ${r.failAccepted ? '<span class="action-pill accepted">✓ Accept</span>' : ''}
        </td>
        <td>${linkCell(r.qcLink, 'QC')} · ${linkCell(r.boLink, 'BO')}</td>
        <td>${escapeHtml(String(r.cycleWorkToQc || ''))} / ${escapeHtml(String(r.cycleQcToRca || ''))}</td>
        <td title="${escapeHtml(r.comments || '')}"><span style="max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; display:inline-block;">${escapeHtml(trunc(r.comments, 80))}</span></td>
      </tr>`;
    }).join('');

    const start = (appState.drillDown.page - 1) * appState.drillDown.pageSize + 1;
    const end   = Math.min(start + appState.drillDown.rows.length - 1, appState.drillDown.total);
    $('rcaTablePaginationInfo').textContent = `Showing ${start.toLocaleString()}–${end.toLocaleString()} of ${appState.drillDown.total.toLocaleString()}`;
    $('rcaPaginationControls').innerHTML = _buildPagination(appState.drillDown.page, appState.drillDown.pageSize, appState.drillDown.total, 'loadDrillDown');
  }

  function escapeJs(s) { return String(s).replace(/'/g, "\\'").replace(/"/g, '\\"'); }

  window.toggleRowSelection = function(caseId, selected) {
    if (selected) appState.selectedRows.add(caseId);
    else appState.selectedRows.delete(caseId);
    renderDrillDownTable();
  };
  window.toggleSelectAll = function(checked) {
    appState.drillDown.rows.forEach(r => {
      if (checked) appState.selectedRows.add(r.caseId);
      else appState.selectedRows.delete(r.caseId);
    });
    renderDrillDownTable();
  };
  window.clearRowSelection = function() { appState.selectedRows.clear(); renderDrillDownTable(); };

  window.reviewSelected = function() {
    if (appState.selectedRows.size === 0) return showToast({ title: 'No rows selected', type: 'warn' });
    showToast({ title: 'Review', description: `${appState.selectedRows.size} cases queued for review (TODO: open modal)`, type: 'info' });
  };

  window.flagSelected = function() {
    if (appState.selectedRows.size === 0) return showToast({ title: 'No rows selected', type: 'warn' });
    const cases = Array.from(appState.selectedRows);
    flagRootCause({
      title: `Review ${cases.length} flagged RCAs`,
      description: 'Cases:\n' + cases.join('\n'),
      category: 'Process',
      priority: 'Medium',
      context: { view: 'analytics', source: 'drill-down-selection', caseIds: cases, filters: rcaFilters }
    });
    showToast({ title: 'Flagged', description: `${cases.length} cases added to queue`, type: 'success' });
  };

  window.loadRcaTable = window.loadDrillDown;

  function flagRootCause(opts) {
    if (!opts || !opts.title) return;
    const ctx = opts.context || { view: 'analytics', source: opts.source || 'manual', filters: rcaFilters, timestamp: new Date().toISOString() };
    window.actionCart.push({
      id: 'a' + Date.now() + Math.floor(Math.random() * 1000),
      title: opts.title,
      description: opts.description || `Flagged from RCA Analytics\nSource: ${opts.source || 'manual'}\n\nCurrent filter context:\n${JSON.stringify(rcaFilters, null, 2)}`,
      category: opts.category || 'Process',
      priority: opts.priority || 'Medium',
      proposedOwner: opts.owner || 'Team Lead',
      jiraType: opts.jiraType || 'Subtask',
      source: opts.source || '',
      context: ctx,
      status: 'draft'
    });
    renderActionDrawer();
    updateActionBadge();
    showToast({ title: '🚩 Flagged', description: `"${opts.title}" added to queue`, type: 'success' });
  }
  window.flagRootCause = flagRootCause;
  window.flagInsight = flagRootCause;

  function renderActionDrawer() {
    const body = $('actionDrawerBody'); if (!body) return;
    if (!window.actionCart.length) {
      body.innerHTML = '<div style="padding:30px; text-align:center; color:var(--text-muted); font-size:12px;">🚩 No root causes flagged yet.<br><br>Click <strong>🚩</strong> on any chart or phase question to add items here.<br>Export as Jira subtasks when ready.</div>';
      return;
    }
    body.innerHTML = window.actionCart.map((item, idx) => `
      <div class="action-item">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
          <span style="font-weight:700; color:var(--accent); font-size:11px;">#${idx + 1} · ${escapeHtml(item.source || 'manual')}</span>
          <button class="btn btn-ghost btn-sm" style="padding:2px 6px; font-size:11px;" onclick="window.removeActionItem('${item.id}')">🗑</button>
        </div>
        <label>Summary</label>
        <input value="${escapeHtml(item.title)}" onchange="window.actionCart[${idx}].title = this.value">
        <label>Description</label>
        <textarea rows="3" onchange="window.actionCart[${idx}].description = this.value">${escapeHtml(item.description)}</textarea>
        <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:6px; margin-top:6px;">
          <div><label>Category</label><select onchange="window.actionCart[${idx}].category = this.value">
            ${['Process','Product','Training','System','Policy'].map(c => `<option ${item.category === c ? 'selected' : ''}>${c}</option>`).join('')}
          </select></div>
          <div><label>Priority</label><select onchange="window.actionCart[${idx}].priority = this.value">
            ${['High','Medium','Low'].map(c => `<option ${item.priority === c ? 'selected' : ''}>${c}</option>`).join('')}
          </select></div>
          <div><label>Owner</label><select onchange="window.actionCart[${idx}].proposedOwner = this.value">
            ${['Team Lead','Product','Ops','QA','Engineering'].map(c => `<option ${item.proposedOwner === c ? 'selected' : ''}>${c}</option>`).join('')}
          </select></div>
        </div>
      </div>`).join('');
  }
  window.renderActionDrawer = renderActionDrawer;

  function updateActionBadge() {
    const badge = $('actionBadge'); if (!badge) return;
    const count = window.actionCart.length;
    if (count === 0) badge.style.display = 'none';
    else { badge.style.display = 'grid'; badge.textContent = count > 99 ? '99+' : String(count); }
  }
  window.updateActionBadge = updateActionBadge;

  window.toggleActionDrawer = function() {
    const drawer = $('actionDrawer'); if (drawer) drawer.classList.toggle('open');
    renderActionDrawer();
  };

  window.removeActionItem = function(id) {
    window.actionCart = window.actionCart.filter(i => i.id !== id);
    renderActionDrawer();
    updateActionBadge();
  };

  window.submitActionItem = function(idx) {
    const item = window.actionCart[idx]; if (!item) return;
    google.script.run
      .withSuccessHandler(() => { showToast({ title: 'Saved to Action Items', type: 'success' }); item.status = 'saved'; renderActionDrawer(); })
      .withFailureHandler(err => showToast({ title: 'Save failed', description: err.message, type: 'error' }))
      .logActionItem(item);
  };

  window.pushAllToSheet = function() {
    const unsaved = window.actionCart.filter(i => i.status !== 'saved');
    if (!unsaved.length) return showToast({ title: 'All items already saved' });
    let done = 0, failed = 0;
    const total = unsaved.length;
    unsaved.forEach(item => {
      google.script.run
        .withSuccessHandler(() => {
          done++; item.status = 'saved';
          if (done + failed === total) {
            showToast({
              title: failed ? 'Some saved' : 'All saved',
              description: `${done} saved, ${failed} failed`,
              type: failed ? 'warn' : 'success'
            });
            renderActionDrawer();
            updateActionBadge();
          }
        })
        .withFailureHandler(err => {
          failed++;
          showToast({ title: 'Batch error', description: err.message, type: 'error' });
          if (done + failed === total) renderActionDrawer();
        })
        .logActionItem(item);
    });
  };

  window.exportJiraCsv = function() {
    if (!window.actionCart.length) return showToast({ title: 'Cart is empty', type: 'warn' });
    google.script.run
      .withSuccessHandler(resp => {
        if (!resp || !resp.success) return showToast({ title: 'Export failed', description: (resp && resp.error) || 'Unknown', type: 'error' });
        downloadCsv(resp.csv, `RCA_Jira_Import_${new Date().toISOString().slice(0, 10)}.csv`);
        showToast({ title: 'Jira CSV exported', description: `${resp.count} rows ready for Jira import`, type: 'success' });
      })
      .withFailureHandler(err => showToast({ title: 'Export error', description: err.message, type: 'error' }))
      .exportActionsToJiraCsv({ items: window.actionCart });
  };

  function downloadCsv(csv, filename) {
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  window.exportRcaCsv = function() {
    google.script.run
      .withSuccessHandler(resp => {
        if (!resp || !resp.success) return showToast({ title: 'Export failed', description: (resp && resp.error) || 'Unknown', type: 'error' });
        downloadCsv(resp.csv, `RCA_Export_${new Date().toISOString().slice(0, 10)}.csv`);
        showToast({ title: 'Exported', description: `${resp.rowCount} rows`, type: 'success' });
      })
      .withFailureHandler(err => showToast({ title: 'Export error', description: err.message, type: 'error' }))
      .exportRcaToCsv(rcaFilters);
  };

  function _buildPagination(currentPage, pageSize, total, fnName) {
    const totalPages = Math.max(1, Math.ceil(total / pageSize));
    const buttons = [];
    buttons.push(`<button ${currentPage === 1 ? 'disabled' : ''} onclick="${fnName}(${currentPage - 1})">‹</button>`);
    const set = new Set([1, totalPages, currentPage, currentPage - 1, currentPage + 1]);
    if (currentPage <= 3) [2, 3, 4].forEach(p => set.add(p));
    if (currentPage >= totalPages - 2) [totalPages - 3, totalPages - 2, totalPages - 1].forEach(p => set.add(p));
    const sorted = [...set].filter(p => p >= 1 && p <= totalPages).sort((a, b) => a - b);
    let last = 0;
    sorted.forEach(p => {
      if (p - last > 1) buttons.push('<button disabled>…</button>');
      buttons.push(`<button class="${p === currentPage ? 'active' : ''}" onclick="${fnName}(${p})">${p}</button>`);
      last = p;
    });
    buttons.push(`<button ${currentPage === totalPages ? 'disabled' : ''} onclick="${fnName}(${currentPage + 1})">›</button>`);
    return buttons.join('');
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.preset-btn').forEach(b => b.addEventListener('click', () => window.applyDatePreset(b.dataset.preset)));
    document.querySelectorAll('input[name="dateField"]').forEach(r => r.addEventListener('change', () => { updateFilterSummaries(); loadRcaAnalytics(); }));
    ['rcaFilterFrom','rcaFilterTo'].forEach(id => { const el = $(id); if (el) el.addEventListener('change', () => { document.querySelector('.preset-btn[data-preset="CUSTOM"]').classList.add('active'); document.querySelectorAll('.preset-btn:not([data-preset="CUSTOM"])').forEach(b => b.classList.remove('active')); updateFilterSummaries(); loadRcaAnalytics(); }); });
    const searchEl = $('rcaFilterSearch');
    if (searchEl) searchEl.addEventListener('input', () => debounce(() => { updateFilterSummaries(); loadRcaAnalytics(); }, 350));
    ['rcaFilterConductor','rcaFilterQcReviewer','rcaFilterAnalyst','rcaFilterTeam','rcaFilterAgency','rcaFilterProduct','rcaFilterCountry','rcaFilterAuthority','rcaFilterOrigin','rcaFilterTaskType','rcaFilterQcAgree','rcaFilterDefect','rcaFilterTypology','rcaFilterTag','rcaFilterPhase','rcaFilterFlagToTL','rcaFilterToBeAppealed','rcaFilterFailAccepted','rcaFilterAlreadyAppealed'].forEach(id => {
      const el = $(id); if (el) el.addEventListener('change', () => { updateFilterSummaries(); loadRcaAnalytics(); });
    });

    const applyBtn = $('rcaApplyBtn'); if (applyBtn) applyBtn.addEventListener('click', loadRcaAnalytics);
    const clearBtn = $('rcaClearBtn'); if (clearBtn) clearBtn.addEventListener('click', window.clearRcaFilters);

    document.querySelectorAll('#trendControls button').forEach(btn => btn.addEventListener('click', () => {
      const mode = btn.dataset.trend; if (!mode) return;
      appState.trendMode = mode;
      document.querySelectorAll('#trendControls button').forEach(b => b.classList.toggle('active', b === btn));
      if (appState.analytics) renderTrendChart(appState.analytics);
    }));

    const qs = $('questionSearch');
    if (qs) qs.addEventListener('input', () => { appState.questionFilter = qs.value; if (appState.analytics) renderQuestionBreakdown(appState.analytics); });

    updateFilterSummaries();
    updateActionBadge();
    renderActionDrawer();
  });

  window.__rcaResizeCharts = function() {
    setTimeout(() => { Object.values(charts).forEach(c => { try { c && c.resize(); } catch(e){} }); }, 50);
  };

  window.__rcaCleanup = function() { Object.keys(charts).forEach(destroyChart); };

})();
</script>
