        <label>Description</label>
        <textarea rows="2" onchange="actionCart[${idx}].description = this.value">${escapeHtml(item.description)}</textarea>
        <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:6px; margin-top:6px;">
          <div><label>Category</label><select onchange="actionCart[${idx}].category = this.value">${['Process','Product','Training','System','Policy'].map(c=>`<option ${item.category===c?'selected':''}>${c}</option>`).join('')}</select></div>
