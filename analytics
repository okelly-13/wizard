  function onRcaTableLoaded(resp) {
    setConn('online', 'Ready');
    if (!resp.success) { showToast({ title: 'Failed', description: resp.error, type: 'error' }); return; }

    document.getElementById('rcaTableCount').textContent = resp.total.toLocaleString();
    const tbody = document.getElementById('rcaTableBody');

    if (resp.rows.length === 0) {
      tbody.innerHTML = `<tr><td colspan="14" class="analytics-empty">No rows match the current filters</td></tr>`;
      document.getElementById('rcaPaginationInfo').textContent = '0 rows';
      document.getElementById('rcaPaginationControls').innerHTML = '';
      return;
    }

    const trunc = (s, n = 60) => {
      const str = String(s || '');
      return str.length > n ? str.slice(0, n) + '…' : str;
    };

    tbody.innerHTML = resp.rows.map(r => {
      const linkCell = (url, label) => url
        ? `<a href="${escapeHtml(url)}" target="_blank" rel="noopener" class="text-link">${label} ↗</a>`
        : `<span class="text-link disabled">—</span>`;

      return `<tr>
        <td>${escapeHtml(r.timestamp)}</td>
        <td><strong>${escapeHtml(r.caseId)}</strong></td>
        <td><span class="defect-pill defect-pill-${escapeHtml(r.defect)}">${escapeHtml(r.defect)}</span></td>
        <td>${escapeHtml(r.product)}</td>
        <td>${escapeHtml(r.analyst)}</td>
        <td>${escapeHtml(r.qcReviewer)}</td>
        <td>${escapeHtml(r.errorSource)}</td>
        <td><strong>${escapeHtml(String(r.binaryDefectScore || '0'))}</strong></td>
        <td>
          ${r.flagToTL     ? '<span class="action-pill active flag">🚩 TL</span>' : ''}
          ${r.toBeAppealed ? '<span class="action-pill active appeal">⚖️ Appeal</span>' : ''}
          ${r.failAccepted ? '<span class="action-pill active accepted">✓ Accept</span>' : ''}
        </td>
        <td>${linkCell(r.qcLink, 'QC')} · ${linkCell(r.boLink, 'BO')}</td>
        <td>${escapeHtml(String(r.cycleWorkToQc || ''))} / ${escapeHtml(String(r.cycleQcToRca || ''))}</td>
        <td title="${escapeHtml(r.comments || '')}"><span class="table-cell-trunc">${escapeHtml(trunc(r.comments, 80))}</span></td>
        <td title="${escapeHtml(r.sysFailTxt || '')}"><span class="table-cell-trunc">${escapeHtml(trunc(r.sysFailTxt, 80))}</span></td>
        <td title="${escapeHtml(r.suggestedUpdate || '')}"><span class="table-cell-trunc">${escapeHtml(trunc(r.suggestedUpdate, 80))}</span></td>
      </tr>`;
    }).join('');

    const start = (resp.page - 1) * resp.pageSize + 1;
    const end   = Math.min(start + resp.rows.length - 1, resp.total);
    document.getElementById('rcaPaginationInfo').textContent = `Showing ${start.toLocaleString()}–${end.toLocaleString()} of ${resp.total.toLocaleString()}`;
    document.getElementById('rcaPaginationControls').innerHTML = _buildPagination(resp.page, resp.pageSize, resp.total, 'loadRcaTable');
  }

  function exportRcaCsv() {
    if (!rcaFilters) { showToast({ title: 'No filters set', type: 'warn' }); return; }
    setConn('busy', 'Exporting…');
    google.script.run
      .withSuccessHandler(resp => {
        setConn('online', 'Ready');
        if (!resp.success) { showToast({ title: 'Export failed', description: resp.error, type: 'error' }); return; }
        const blob = new Blob([resp.csv], { type: 'text/csv;charset=utf-8;' });
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href = url;
        a.download = `RCA_Export_${new Date().toISOString().slice(0, 10)}.csv`;
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
        URL.revokeObjectURL(url);
        showToast({ title: 'Exported', description: `${resp.rowCount} rows`, type: 'success' });
      })
      .withFailureHandler(err => { setConn('offline', 'Error'); showToast({ title: 'Export error', description: err.message, type: 'error' }); })
      .exportRcaToCsv(rcaFilters);
  }

