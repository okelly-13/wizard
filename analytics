<style>
  /* ============================================================
     ANALYTICS-ONLY STYLES
     ============================================================ */
  :root, [data-theme="light"] {
    --chart-line: #5B47E0;
    --chart-fill: rgba(91, 71, 224, 0.12);
    --chart-grid: rgba(0, 0, 0, 0.05);
    --chart-tick: #6B7588;
    --chart-red: #F5365C;
    --chart-green: #14C18C;
    --chart-orange: #FFA800;
    --chart-blue: #2563EB;
    --chart-gray: #9CA3AF;
  }
  [data-theme="dark"] {
    --chart-line: #8B7FFF;
    --chart-fill: rgba(139, 127, 255, 0.18);
    --chart-grid: rgba(255, 255, 255, 0.06);
    --chart-tick: #A8B0C5;
    --chart-red: #FF5470;
    --chart-green: #14C18C;
    --chart-orange: #FFA800;
    --chart-blue: #5B8DEF;
    --chart-gray: #6B7588;
  }

  .analytics-empty { padding: 30px; text-align: center; color: var(--text-muted); font-size: 12px; }

  .chart-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
    padding: 0 20px 20px;
  }
  @media (max-width: 900px) { .chart-grid { grid-template-columns: 1fr; } }

  .chart-card {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-md); padding: 16px 20px;
    display: flex; flex-direction: column;
  }
  .chart-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .chart-card-title { font-size: 13px; font-weight: 700; color: var(--text-primary); }
  .chart-card-sub   { font-size: 11px; color: var(--text-secondary); }
  .chart-canvas-wrap { position: relative; flex: 1; min-height: 220px; }

  /* Phase failure bars */
  .phase-bar-row {
    display: grid; grid-template-columns: 130px 1fr 70px;
    align-items: center; gap: 10px; margin-bottom: 8px;
    font-size: 12px;
  }
  .phase-bar-track {
    height: 22px; background: var(--bg-app);
    border-radius: 6px; overflow: hidden; position: relative;
    border: 1px solid var(--border);
  }
  .phase-bar-pass {
    position: absolute; left: 0; top: 0; bottom: 0;
    background: var(--chart-green); transition: width 400ms var(--ease);
  }
  .phase-bar-fail {
    position: absolute; right: 0; top: 0; bottom: 0;
    background: var(--chart-red); transition: width 400ms var(--ease);
  }
  .phase-bar-label { color: var(--text-primary); font-weight: 600; }
  .phase-bar-rate  { font-weight: 700; font-size: 12px; text-align: right; }
  .phase-bar-rate.fail-high { color: var(--chart-red); }
  .phase-bar-rate.fail-mid  { color: var(--chart-orange); }
  .phase-bar-rate.fail-low  { color: var(--chart-green); }

  /* Systemic vs Human donut legend */
  .donut-legend { display: flex; flex-direction: column; gap: 6px; margin-top: 12px; }
  .donut-legend-row {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px;
  }
  .donut-legend-dot { width: 10px; height: 10px; border-radius: 3px; }
  .donut-legend-name { flex: 1; color: var(--text-primary); }
  .donut-legend-val  { font-weight: 700; color: var(--text-secondary); }

  /* Drill-down text columns */
  .table-cell-trunc {
    max-width: 280px; overflow: hidden; text-overflow: ellipsis;
    white-space: nowrap; display: inline-block; vertical-align: middle;
  }

  /* Search box */
  .analytics-search {
    flex: 1; min-width: 180px; padding: 7px 12px;
    border: 1px solid var(--border-strong); border-radius: var(--radius-sm);
    background: var(--bg-card); color: var(--text-primary);
    font-size: 12px; font-family: inherit;
  }
  .analytics-search:focus {
    outline: none; border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(91,71,224,0.15);
  }

  /* Date-range targeting chip */
  .date-target-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 8px; border-radius: var(--radius-full);
    background: var(--bg-card); border: 1px solid var(--border-strong);
    font-size: 11px; color: var(--text-secondary);
  }
  .date-target-chip select {
    border: none; background: transparent;
    font-size: 11px; font-weight: 600; color: var(--accent);
    cursor: pointer; outline: none;
  }

  /* Action pills (table) — extra for review */
  .text-link {
    color: var(--accent); text-decoration: none; font-weight: 600;
    display: inline-flex; align-items: center; gap: 3px;
  }
  .text-link:hover { text-decoration: underline; }
  .text-link.disabled { color: var(--text-muted); cursor: not-allowed; }
</style>

<!-- ============================================================
     RCA RESULTS ANALYTICS VIEW
     ============================================================ -->
<div class="card" id="rcaAnalyticsCard">
  <div class="card-header">
    <div>
      <h2 class="card-title">RCA Results Analytics</h2>
      <div class="card-subtitle" id="rcaAnalyticsSubtitle">Loading…</div>
    </div>
    <div class="flex gap-2">
      <button class="btn btn-ghost btn-sm" onclick="window.exportRcaCsv && window.exportRcaCsv()" title="Export current view to CSV">⬇ CSV</button>
      <button class="btn btn-ghost btn-sm" onclick="window.loadRcaAnalytics && window.loadRcaAnalytics()">↻ Refresh</button>
    </div>
  </div>

  <!-- ═══════════════ FILTER BAR ═══════════════ -->
  <div class="analytics-filter-bar">
    <!-- Date range with target selector -->
    <div class="filter-group" style="flex:1.4; min-width:260px;">
      <label>Date Range <span class="text-muted" style="text-transform:none;">·</span>
        <span class="date-target-chip">
          <span style="font-size:10px; color:var(--text-muted);">on</span>
          <select id="rcaFilterDateField" onchange="window.loadRcaAnalytics && window.loadRcaAnalytics()">
            <option value="timestamp">Timestamp</option>
            <option value="reviewDate">Review Date</option>
            <option value="workDate">Work Date</option>
          </select>
        </span>
      </label>
      <div class="flex gap-1">
        <input type="date" id="rcaFilterFrom" onchange="window.loadRcaAnalytics && window.loadRcaAnalytics()">
        <span style="align-self:center; color:var(--text-muted);">→</span>
        <input type="date" id="rcaFilterTo" onchange="window.loadRcaAnalytics && window.loadRcaAnalytics()">
      </div>
    </div>

    <!-- Free-text search -->
    <div class="filter-group" style="flex:1.2; min-width:200px;">
      <label>Search comments / details</label>
      <input type="search" class="analytics-search" id="rcaFilterSearch" placeholder="e.g., money laundering, OSINT fail…">
    </div>

    <!-- Categorical filters -->
    <div class="filter-group">
      <label>Conductor</label>
      <select id="rcaFilterConductor"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>QC Reviewer</label>
      <select id="rcaFilterQcReviewer"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>Analyst</label>
      <select id="rcaFilterAnalyst"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>Team</label>
      <select id="rcaFilterTeam"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>Agency</label>
      <select id="rcaFilterAgency"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>Product</label>
      <select id="rcaFilterProduct"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>Country</label>
      <select id="rcaFilterCountry"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>Authority</label>
      <select id="rcaFilterAuthority"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>UAR Origin</label>
      <select id="rcaFilterOrigin"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>Task Type</label>
      <select id="rcaFilterTaskType"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>Error Source</label>
      <select id="rcaFilterErrorSource"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>QC Agree</label>
      <select id="rcaFilterQcAgree">
        <option value="">All</option>
        <option value="Yes">Yes (Agree)</option>
        <option value="No">No (Disagree)</option>
      </select>
    </div>
    <div class="filter-group">
      <label>Defect</label>
      <select id="rcaFilterDefect">
        <option value="">All</option>
        <option value="Critical">Critical</option>
        <option value="None">None</option>
        <option value="Unknown">Unknown</option>
      </select>
    </div>
    <div class="filter-group">
      <label>Typology</label>
      <select id="rcaFilterTypology"><option value="">All</option></select>
    </div>
    <div class="filter-group">
      <label>Risk Tag</label>
      <select id="rcaFilterTag"><option value="">All</option></select>
    </div>

    <!-- Boolean flag filters -->
    <div class="filter-group">
      <label>Flagged to TL</label>
      <select id="rcaFilterFlagToTL">
        <option value="">Either</option><option value="true">Yes</option><option value="false">No</option>
      </select>
    </div>
    <div class="filter-group">
      <label>To be Appealed</label>
      <select id="rcaFilterToBeAppealed">
        <option value="">Either</option><option value="true">Yes</option><option value="false">No</option>
      </select>
    </div>
    <div class="filter-group">
      <label>Fail Accepted</label>
      <select id="rcaFilterFailAccepted">
        <option value="">Either</option><option value="true">Yes</option><option value="false">No</option>
      </select>
    </div>

    <div class="filter-actions">
      <button class="btn btn-secondary btn-sm" id="rcaApplyBtn">Apply</button>
      <button class="btn btn-ghost btn-sm" id="rcaClearBtn">Clear</button>
    </div>
  </div>

  <!-- ═══════════════ KPI CARDS ═══════════════ -->
  <div class="rca-kpi-grid" id="rcaKpiGrid"></div>

  <!-- ═══════════════ TREND CHART ═══════════════ -->
  <div style="padding: 0 20px 20px;">
    <div class="chart-card">
      <div class="chart-card-header">
        <div>
          <div class="chart-card-title">📈 Defect Volume Over Time</div>
          <div class="chart-card-sub" id="trendSubtitle">Daily / Weekly / Monthly</div>
        </div>
        <div class="trend-controls" id="trendControls">
          <button data-trend="daily"   class="active" type="button">Daily</button>
          <button data-trend="weekly"  type="button">Weekly</button>
          <button data-trend="monthly" type="button">Monthly</button>
        </div>
      </div>
      <div class="chart-canvas-wrap"><canvas id="rcaTrendChart"></canvas></div>
    </div>
  </div>

  <!-- ═══════════════ CYCLE TIME TREND ═══════════════ -->
  <div class="chart-grid">
    <div class="chart-card">
      <div class="chart-card-header">
        <div>
          <div class="chart-card-title">⏱ Cycle Time Trends (Weekly)</div>
          <div class="chart-card-sub">Work→QC vs QC→RCA average days</div>
        </div>
      </div>
      <div class="chart-canvas-wrap"><canvas id="rcaCycleChart"></canvas></div>
    </div>

    <div class="chart-card">
      <div class="chart-card-header">
        <div>
          <div class="chart-card-title">🎯 Phase Failure Breakdown</div>
          <div class="chart-card-sub">% of "No" responses per investigation phase</div>
        </div>
      </div>
      <div id="rcaPhaseFailure"></div>
    </div>
  </div>

  <!-- ═══════════════ TYPOLOGIES, TAGS, SYSTEMIC ═══════════════ -->
  <div class="chart-grid">
    <div class="chart-card">
      <div class="chart-card-header">
        <div>
          <div class="chart-card-title">🏷 Top Typologies</div>
          <div class="chart-card-sub">Across all RCAs in range</div>
        </div>
      </div>
      <div id="rcaTopTypologies"></div>
    </div>

    <div class="chart-card">
      <div class="chart-card-header">
        <div>
          <div class="chart-card-title">🚩 Top Risk Tags</div>
          <div class="chart-card-sub">Across all RCAs in range</div>
        </div>
      </div>
      <div id="rcaTopRiskTags"></div>
    </div>
  </div>

  <div class="chart-grid">
    <div class="chart-card">
      <div class="chart-card-header">
        <div>
          <div class="chart-card-title">⚖️ Systemic vs Human Error</div>
          <div class="chart-card-sub">Error Source × System Process Fail</div>
        </div>
      </div>
      <div class="chart-canvas-wrap" style="display:flex; align-items:center; gap: 16px;">
        <div style="flex: 0 0 180px;"><canvas id="rcaSystemicChart"></canvas></div>
        <div class="donut-legend" id="rcaSystemicLegend" style="flex:1;"></div>
      </div>
    </div>

    <div class="chart-card">
      <div class="chart-card-header">
        <div>
          <div class="chart-card-title">🤝 Agreement Rate</div>
          <div class="chart-card-sub">% of RCAs where reviewer agreed with QC</div>
        </div>
      </div>
      <div class="chart-canvas-wrap"><canvas id="rcaAgreementChart"></canvas></div>
    </div>
  </div>

  <!-- ═══════════════ EXISTING BREAKDOWNS ═══════════════ -->
  <div class="chart-grid">
    <div class="chart-card">
      <div class="chart-card-title" style="margin-bottom: 10px;">By Defect Type</div>
      <div id="rcaDefectBreakdown"></div>
    </div>
    <div class="chart-card">
      <div class="chart-card-title" style="margin-bottom: 10px;">🏆 Top RCA Conductors</div>
      <div id="rcaTopConductors"></div>
    </div>
  </div>

  <div class="chart-grid">
    <div class="chart-card">
      <div class="chart-card-title" style="margin-bottom: 10px;">By Team</div>
      <div id="rcaTeamBreakdown"></div>
    </div>
    <div class="chart-card">
      <div class="chart-card-title" style="margin-bottom: 10px;">🏆 Top QC Reviewers</div>
      <div id="rcaTopQcReviewers"></div>
    </div>
  </div>

  <!-- ═══════════════ DRILL-DOWN TABLE ═══════════════ -->
  <div style="padding: 0 20px 20px;">
    <div class="card-header" style="padding: 0 0 12px;">
      <h3 class="card-title" style="font-size: 14px;">📋 Drill-down · <span id="rcaTableCount">0</span> rows</h3>
      <div class="text-sm text-muted">Hover text cells to see full content · click column headers would require server sort (TODO)</div>
    </div>
    <div class="table-scroll">
      <table class="data-table rca-table">
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>Case ID</th>
            <th>Defect</th>
            <th>Product</th>
            <th>Analyst</th>
            <th>QC Reviewer</th>
            <th>Error Source</th>
            <th>Score</th>
            <th>Flags</th>
            <th>Links</th>
            <th>Cycle (d)</th>
            <th>Comments</th>
            <th>Sys/Proc Details</th>
            <th>Suggested Update</th>
          </tr>
        </thead>
        <tbody id="rcaTableBody"></tbody>
      </table>
    </div>
    <div class="pagination">
      <div class="pagination-info" id="rcaPaginationInfo">—</div>
      <div class="pagination-controls" id="rcaPaginationControls"></div>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict';

  let rcaAnalyticsData = null;
  let charts = { trend: null, cycle: null, systemic: null, agreement: null,
                 defectTrend: null, pareto: null, scatter: null, cycleHist: null };
  let rcaTrendMode  = 'daily';
  let rcaTablePage  = 1;
  const RCA_PAGE_SIZE = 25;
  let rcaFilters    = {};
  let _rcaDebounce  = null;
  let actionCart = [];

  window.loadRcaAnalytics = loadRcaAnalytics;
  window.clearRcaFilters  = clearRcaFilters;
  window.exportRcaCsv     = exportRcaCsv;
  window.quickFilterBy    = quickFilterBy;
  window.loadRcaTable       = loadRcaTable;
  window.onRcaTableLoaded   = onRcaTableLoaded;
  window.getRcaFiltersFromUi = getRcaFiltersFromUi;
  window.toggleActionDrawer = toggleActionDrawer;
  window.flagInsight = flagInsight;
  window.removeActionItem = removeActionItem;
  window.submitActionItem = submitActionItem;
  window.pushAllToSheet = pushAllToSheet;
  window.exportJiraCsv = exportJiraCsv;
  window.filterByMonth = filterByMonth;

  document.addEventListener('DOMContentLoaded', () => {
    const $ = (id) => document.getElementById(id);

    document.querySelectorAll('#trendControls button').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.trend;
        if (!mode) return;
        rcaTrendMode = mode;
        document.querySelectorAll('#trendControls button').forEach(b => b.classList.toggle('active', b === btn));
        if (rcaAnalyticsData) renderTrendChart(rcaAnalyticsData);
      });
    });

    $('rcaApplyBtn')?.addEventListener('click', loadRcaAnalytics);
    $('rcaClearBtn')?.addEventListener('click', clearRcaFilters);

    $('rcaFilterSearch')?.addEventListener('input', () => {
      clearTimeout(_rcaDebounce);
      _rcaDebounce = setTimeout(loadRcaAnalytics, 350);
    });

    ['rcaFilterFrom','rcaFilterTo','rcaFilterDateField'].forEach(id => {
      $(id)?.addEventListener('change', loadRcaAnalytics);
    });
  });

  function loadRcaAnalytics() {
    clearTimeout(_rcaDebounce);
    _rcaDebounce = setTimeout(_loadRcaAnalyticsNow, 80);
  }

  function _loadRcaAnalyticsNow() {
    setConn('busy', 'Loading analytics…');
    rcaFilters = getRcaFiltersFromUi();

    google.script.run
      .withSuccessHandler(onRcaAnalyticsLoaded)
      .withFailureHandler(err => {
        setConn('offline', 'Error');
        showToast({ title: 'Analytics error', description: (err && err.message) || String(err), type: 'error' });
      })
      .getRcaAnalytics(rcaFilters);
  }

  function onRcaAnalyticsLoaded(resp) {
    if (!resp.success) {
      setConn('offline', 'Error');
      showToast({ title: 'Failed', description: resp.error, type: 'error' });
      return;
    }
    rcaAnalyticsData = resp.analytics;
    setConn('online', 'Ready');

    document.getElementById('rcaAnalyticsSubtitle').textContent =
      `${resp.total.toLocaleString()} RCAs in range · ${rcaAnalyticsData.thisWeek} this week · ${rcaAnalyticsData.thisMonth} this month`;

    populateFilterDropdowns(rcaAnalyticsData);
    renderKpis(rcaAnalyticsData);
    renderTrendChart(rcaAnalyticsData);
    renderCycleChart(rcaAnalyticsData);
    renderPhaseFailure(rcaAnalyticsData);
    renderTypologies(rcaAnalyticsData);
    renderRiskTags(rcaAnalyticsData);
    renderSystemicChart(rcaAnalyticsData);
    renderAgreementChart(rcaAnalyticsData);
    renderBreakdowns(rcaAnalyticsData);

    renderDefectTrendChart(rcaAnalyticsData);
    renderParetoChart(rcaAnalyticsData);
    renderScatterChart(rcaAnalyticsData);
    renderCycleHistogram(rcaAnalyticsData);
    renderPhaseHeatmap(rcaAnalyticsData);

    loadRcaTable(1);
  }

  function getRcaFiltersFromUi() {
    const v = (id) => { const el = document.getElementById(id); return el ? el.value : ''; };
    const bool = (id) => {
      const x = v(id);
      if (x === '') return undefined;
      return x === 'true';
    };
    return {
      dateField:    v('rcaFilterDateField') || 'timestamp',
      dateFrom:     v('rcaFilterFrom'),
      dateTo:       v('rcaFilterTo'),
      search:       v('rcaFilterSearch'),
      conductor:    v('rcaFilterConductor'),
      qcReviewer:   v('rcaFilterQcReviewer'),
      analyst:      v('rcaFilterAnalyst'),
      team:         v('rcaFilterTeam'),
      agency:       v('rcaFilterAgency'),
      product:      v('rcaFilterProduct'),
      country:      v('rcaFilterCountry'),
      authority:    v('rcaFilterAuthority'),
      origin:       v('rcaFilterOrigin'),
      taskType:     v('rcaFilterTaskType'),
      errorSource:  v('rcaFilterErrorSource'),
      rcaAgree:     v('rcaFilterQcAgree'),
      defect:       v('rcaFilterDefect'),
      typology:     v('rcaFilterTypology'),
      tag:          v('rcaFilterTag'),
      flagToTL:     bool('rcaFilterFlagToTL'),
      toBeAppealed: bool('rcaFilterToBeAppealed'),
      failAccepted: bool('rcaFilterFailAccepted')
    };
  }

  function clearRcaFilters() {
    ['rcaFilterFrom','rcaFilterTo','rcaFilterDateField','rcaFilterSearch',
     'rcaFilterConductor','rcaFilterQcReviewer','rcaFilterAnalyst',
     'rcaFilterTeam','rcaFilterAgency','rcaFilterProduct','rcaFilterCountry',
     'rcaFilterAuthority','rcaFilterOrigin','rcaFilterTaskType',
     'rcaFilterErrorSource','rcaFilterQcAgree','rcaFilterDefect',
     'rcaFilterTypology','rcaFilterTag','rcaFilterFlagToTL',
     'rcaFilterToBeAppealed','rcaFilterFailAccepted']
      .forEach(id => { const el = document.getElementById(id); if (el) el.value = el.tagName === 'SELECT' ? '' : ''; });
    loadRcaAnalytics();
  }

  function populateFilterDropdowns(a) {
    const fill = (id, obj) => {
      const sel = document.getElementById(id); if (!sel) return;
      const cur = sel.value;
      sel.innerHTML = '<option value="">All</option>' +
        Object.keys(obj || {}).sort().map(k =>
          `<option value="${escapeHtml(k)}">${escapeHtml(k)} (${obj[k]})</option>`
        ).join('');
      sel.value = cur;
    };
    fill('rcaFilterConductor',  a.byConductor);
    fill('rcaFilterQcReviewer', a.byQcReviewer);
    fill('rcaFilterAnalyst',    a.byAnalyst);
    fill('rcaFilterTeam',       a.byTeam);
    fill('rcaFilterAgency',     a.byAgency);
    fill('rcaFilterProduct',    a.byProduct);
    fill('rcaFilterCountry',    a.byCountry);
    fill('rcaFilterAuthority',  a.byAuthority);
    fill('rcaFilterOrigin',     a.byOrigin);
    fill('rcaFilterTaskType',   a.byTaskType);
    fill('rcaFilterErrorSource',a.byErrorSource);
    fill('rcaFilterTypology',   a.topTypologies);
    fill('rcaFilterTag',        a.topRiskTags);
  }

  function renderKpis(a) {
    const kpis = [
      { label: 'Total RCAs',          value: a.total.toLocaleString(),          sub: 'cases in range',  kind: '' },
      { label: 'Avg Defect Score',    value: (a.avgDefectScore || 0).toFixed(2),sub: 'higher = more defects', kind: a.avgDefectScore > 3 ? 'critical' : a.avgDefectScore > 1 ? 'warn' : 'success' },
      { label: 'Agreement Rate',      value: (a.agreementRate || 0) + '%',      sub: `${a.agreementBreakdown.yes} yes / ${a.agreementBreakdown.no} no`, kind: a.agreementRate >= 70 ? 'success' : a.agreementRate >= 50 ? 'warn' : 'critical' },
      { label: 'Critical Rate',       value: (a.criticalRate || 0) + '%',       sub: `${a.criticalCount} critical`, kind: 'critical' },
      { label: 'Avg Work→QC',         value: (a.cycleTime.avgWorkToQc || 0).toFixed(1) + 'd', sub: 'analyst lag',  kind: a.cycleTime.avgWorkToQc > 7 ? 'warn' : '' },
      { label: 'Avg QC→RCA',          value: (a.cycleTime.avgQcToRca || 0).toFixed(1) + 'd', sub: 'feedback lag', kind: a.cycleTime.avgQcToRca > 7 ? 'warn' : '' },
      { label: 'Flag Rate',           value: (a.flagRate || 0) + '%',           sub: `${a.flagged.flagToTL} flagged`, kind: 'warn' },
