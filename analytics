  function _leaderboard(obj) {
    const entries = Object.entries(obj || {}).sort((a, b) => b[1] - a[1]).slice(0, 10);
    if (!entries.length) return '<div class="analytics-empty">No data</div>';
    const medals = ['🥇', '🥈', '🥉'];
    return entries.map(([name, count], i) => {
      return `<div class="lb-row" data-name="${escapeHtml(name)}" style="display:flex; align-items:center; gap:10px; padding:8px 10px; border-radius:6px; cursor:pointer; font-size:12px;">
        <div class="lb-rank" style="width:24px; text-align:center; font-weight:700;">${i < 3 ? medals[i] : (i + 1)}</div>
        <div class="lb-name" style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${escapeHtml(name)}">${escapeHtml(name)}</div>
        <div class="lb-count" style="font-weight:700;">${count}</div>
      </div>`;
    }).join('');
