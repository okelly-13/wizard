<script>
(function () {
  'use strict';
  window.actionCart = window.actionCart || [];
  const appState = { analytics: null, selectedRows: new Set(), drillDown: { rows: [], total: 0, page: 1, pageSize: 25 }, trendMode: 'daily', questionFilter: '', expandedPhases: new Set([1, 2]) };
  let rcaFilters = {}; let _debounce = null; let charts = {};
  const KPI_WARN_DAYS = 7; const PHASE_CONFIG = buildPhaseConfig(); const PAGE_SIZE = 25;
  
  const $ = (id) => document.getElementById(id);
  const cssVar = (n) => getComputedStyle(document.documentElement).getPropertyValue(n).trim();
  const escapeHtml = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
  const fmtPct = (n) => (n == null || isNaN(n)) ? '0%' : Math.round(n) + '%';
  const fmtNum = (n) => (n || 0).toLocaleString();
  const debounce = (fn, ms) => { clearTimeout(_debounce); _debounce = setTimeout(fn, ms); };
  const destroyChart = (k) => { if (charts[k]) { try { charts[k].destroy(); } catch(e){} charts[k] = null; } };

  function setAnalyticsConn(st, txt) { const d = $('connectionDot'), l = $('connectionLabel'); if (d) d.className = 'connection-dot ' + st; if (l) l.textContent = txt; }
  function showToast(o) { if (typeof window.showToast === 'function') return window.showToast(o); console.log('TOAST:', o.title, o.description || ''); }

  function buildPhaseConfig() {
    return [
      { num: 1, title: 'Trigger & Triage', questions: [ { key: 'p1Scope', label: 'Correctly identified Full vs Short investigation' }, { key: 'duplicateIdentified', label: 'Correctly identified duplicate UAR', hasNa: true }, { key: 'p1DuplicateAction', label: 'Offboarding status of previous account checked', hasNa: true }, { key: 'p1MultiSuspect', label: 'Multi-suspect on UAR identified', hasNa: true } ]},
      { num: 2, title: 'Baseline & OSINT', questions: [ { key: 'p2Baseline', label: 'Baseline checks (KYC, chat, name matches)', reasonKey: 'p2BaselineFail' }, { key: 'p2Osint', label: 'OSINT checks (employment, address, subject)', reasonKey: 'p2OsintFail' }, { key: 'p2OsintDoc', label: 'OSINT findings documented in RBI', hasNa: true } ]},
      { num: 3, title: 'Transaction Analysis', questions: [ { key: 'p3Baseline', label: 'Transaction baseline (thresholds, profile)', reasonKey: 'p3BaselineFail' }, { key: 'p3Module', label: 'Module checks (4EC, typology, sanctions)', reasonKey: 'p3ModuleFail' } ]},
      { num: 4, title: 'Review Associates', questions: [ { key: 'p4ShortFull', label: 'Correctly identified short vs full associate review' }, { key: 'p4CorrectAll', label: 'Correct outcome on all associates' } ]},
      { num: 5, title: 'Determine Outcome', questions: [ { key: 'p5Decision', label: 'Correct overall decision (reject / report / EDD)', reasonKey: 'p5ActionError' } ]},
      { num: 6, title: 'Post-Investigation Actions', questions: [ { key: 'p6Edd', label: 'EDD applied correctly with restrictions', hasNa: true }, { key: 'p6Juris', label: 'Jurisdictional requirements in notes', hasNa: true }, { key: 'p6Template', label: 'RBI / 4EC / remediation note template', hasNa: true }, { key: 'p6Dante', label: 'Dante questions answered correctly', hasNa: true }, { key: 'p6Tags', label: 'Manual tag removal and FIU restrictions lifted', hasNa: true }, { key: 'p6Alerts', label: 'Alerts tab clear of pending alerts' }, { key: 'p6Offboard', label: 'Offboarding applied correctly', hasNa: true }, { key: 'p6Suspects', label: 'Guilty associates added as suspects', hasNa: true }, { key: 'p6Refunds', label: 'Refunds / repatriations applied', hasNa: true } ]},
      { num: 7, title: 'Note Quality (Manual)', questions: [ { key: 'p7Vague', label: 'No vague / unsubstantiated claims' }, { key: 'p7BrokenStrings', label: 'No broken strings or missing variables', hasNa: true }, { key: 'p7UpstreamFlags', label: 'Upstream red flags explicitly addressed', hasNa: true }, { key: 'p7ExtEnquiry', label: 'External enquiries described, internal links excluded', hasNa: true } ]}
    ];
  }

  window.toggleFilterSection = function(sectionId) { const el = document.querySelector(`[data-section="${sectionId}"]`); if (!el) return; el.classList.toggle('open'); };
  window.applyDatePreset = function(preset) {
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.toggle('active', b.dataset.preset === preset));
    const today = new Date(); const fmt = d => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    const from = $('rcaFilterFrom'), to = $('rcaFilterTo'), customRow = $('customDateInputs');
    if (preset === 'ALL') { from.value = ''; to.value = ''; customRow.classList.remove('show'); }
    else if (preset === 'CUSTOM') { customRow.classList.add('show'); }
    else {
      customRow.classList.remove('show'); const start = new Date(today);
      if (preset === 'L7') start.setDate(today.getDate() - 7);
      if (preset === 'L28') start.setDate(today.getDate() - 28);
      if (preset === 'MTD') start.setDate(1);
      if (preset === 'QTD') { const q = Math.floor(today.getMonth() / 3) * 3; start.setMonth(q, 1); }
      if (preset === 'YTD') start.setMonth(0, 1);
      from.value = fmt(start); to.value = fmt(today);
    }
    loadRcaAnalytics();
  };

  function gatherFilters() {
    const v = (id) => { const el = $(id); return el ? el.value : ''; };
    const bool = (id) => { const x = v(id); if (x === '') return undefined; return x === 'true'; };
    const dateFieldEl = document.querySelector('input[name="dateField"]:checked');
    return { dateField: dateFieldEl ? dateFieldEl.value : 'reviewDate', dateFrom: v('rcaFilterFrom'), dateTo: v('rcaFilterTo'), search: v('rcaFilterSearch'),
      conductor: v('rcaFilterConductor'), qcReviewer: v('rcaFilterQcReviewer'), analyst: v('rcaFilterAnalyst'), team: v('rcaFilterTeam'), agency: v('rcaFilterAgency'),
      product: v('rcaFilterProduct'), country: v('rcaFilterCountry'), authority: v('rcaFilterAuthority'), origin: v('rcaFilterOrigin'), taskType: v('rcaFilterTaskType'),
      errorSource: v('rcaFilterErrorSource'), rcaAgree: v('rcaFilterQcAgree'), defect: v('rcaFilterDefect'), typology: v('rcaFilterTypology'), tag: v('rcaFilterTag'),
      investigationPhase: v('rcaFilterPhase'), flagToTL: bool('rcaFilterFlagToTL'), toBeAppealed: bool('rcaFilterToBeAppealed'), failAccepted: bool('rcaFilterFailAccepted'), alreadyAppealed: bool('rcaFilterAlreadyAppealed') };
  }

  function updateFilterSummaries() {
    const f = gatherFilters();
    const activePreset = document.querySelector('.preset-btn.active'); const preset = activePreset ? activePreset.dataset.preset : 'L28';
    const presetLabel = { L7:'Last 7 days', L28:'Last 28 days', MTD:'Month to date', QTD:'Quarter to date', YTD:'Year to date', ALL:'All time', CUSTOM:'Custom range' }[preset] || preset;
    const fieldLabel = { reviewDate:'Review Date', workDate:'Work Date', timestamp:'RCA Date' }[f.dateField] || 'Review Date';
    $('fs-summary-timeframe').textContent = `${presetLabel} · ${fieldLabel}`;
    $('fs-count-timeframe').textContent = (preset === 'L28' ? 0 : 1); $('fs-count-timeframe').classList.toggle('zero', preset === 'L28');
    const uarCount = ['rcaFilterProduct','rcaFilterCountry','rcaFilterAuthority','rcaFilterOrigin','rcaFilterTaskType','rcaFilterTypology'].filter(id => $(id) && $(id).value).length;
    $('fs-count-uar').textContent = uarCount; $('fs-count-uar').classList.toggle('zero', uarCount === 0);
    const teamCount = ['rcaFilterConductor','rcaFilterQcReviewer','rcaFilterAnalyst','rcaFilterTeam','rcaFilterAgency'].filter(id => $(id) && $(id).value).length;
    $('fs-count-team').textContent = teamCount; $('fs-count-team').classList.toggle('zero', teamCount === 0);
    const findingsCount = ['rcaFilterDefect','rcaFilterTag','rcaFilterPhase','rcaFilterQcAgree','rcaFilterFlagToTL','rcaFilterToBeAppealed','rcaFilterFailAccepted','rcaFilterAlreadyAppealed','rcaFilterSearch'].filter(id => $(id) && $(id).value).length;
    $('fs-count-findings').textContent = findingsCount; $('fs-count-findings').classList.toggle('zero', findingsCount === 0);
    const total = uarCount + teamCount + findingsCount + (preset === 'L28' ? 0 : 1);
    $('filterSummaryFooter').textContent = total === 0 ? 'No filters applied (defaults: L28, Review Date)' : `${total} filter${total === 1 ? '' : 's'} active`;
  }

  window.clearRcaFilters = function() {
    ['rcaFilterSearch','rcaFilterConductor','rcaFilterQcReviewer','rcaFilterAnalyst','rcaFilterTeam','rcaFilterAgency','rcaFilterProduct','rcaFilterCountry','rcaFilterAuthority','rcaFilterOrigin','rcaFilterTaskType','rcaFilterErrorSource','rcaFilterQcAgree','rcaFilterDefect','rcaFilterTypology','rcaFilterTag','rcaFilterFlagToTL','rcaFilterToBeAppealed','rcaFilterFailAccepted','rcaFilterAlreadyAppealed','rcaFilterPhase'].forEach(id => { const el = $(id); if (el) el.value = ''; });
    applyDatePreset('L28');
    const rf = document.querySelector('input[name="dateField"][value="reviewDate"]'); if (rf) rf.checked = true;
    updateFilterSummaries();
  };

  window.loadRcaAnalytics = function() {
    setAnalyticsConn('busy', 'Loading analytics…'); rcaFilters = gatherFilters(); updateFilterSummaries();
    google.script.run.withSuccessHandler(onAnalyticsLoaded).withFailureHandler(err => { setAnalyticsConn('offline', 'Error'); showToast({ title: 'Analytics error', description: (err && err.message) || String(err), type: 'error' }); }).getRcaAnalytics(rcaFilters);
  };

  function onAnalyticsLoaded(resp) {
    if (!resp || !resp.success) { setAnalyticsConn('offline', 'Error'); showToast({ title: 'Failed', description: (resp && resp.error) || 'Unknown', type: 'error' }); return; }
    appState.analytics = resp.analytics; setAnalyticsConn('online', 'Ready');
    const sub = $('rcaAnalyticsSubtitle'); if (sub) sub.textContent = `${fmtNum(resp.total)} RCAs in range · ${appState.analytics.thisWeek || 0} this week · ${appState.analytics.thisMonth || 0} this month`;
    populateFilterDropdowns(appState.analytics); renderKpis(appState.analytics); renderTrendChart(appState.analytics); renderDefectTrendChart(appState.analytics); renderDefectLineChart(appState.analytics); renderOriginChart(appState.analytics); renderOriginLineChart(appState.analytics); renderTeamChart(appState.analytics); renderTeamLineChart(appState.analytics); renderProductChart(appState.analytics); renderProductLineChart(appState.analytics); renderTypologyChart(appState.analytics); renderTypologyLineChart(appState.analytics); renderTagChart(appState.analytics); renderTagLineChart(appState.analytics); renderCycleChart(appState.analytics); renderAgreementChart(appState.analytics); renderSystemicChart(appState.analytics); renderParetoChart(appState.analytics); renderTopConductors(appState.analytics); renderTopQcReviewers(appState.analytics); renderLlmCharts(appState.analytics); renderPhaseAnalysis(appState.analytics); renderQuestionBreakdown(appState.analytics);
    loadDrillDown(1);
  }

  function populateFilterDropdowns(a) {
    const fill = (id, obj) => { const sel = $(id); if (!sel) return; const cur = sel.value; const entries = Object.entries(obj || {}).sort((x, y) => y[1] - x[1]); sel.innerHTML = '<option value="">All</option>' + entries.map(([k, v]) => `<option value="${escapeHtml(k)}">${escapeHtml(k)} (${v})</option>`).join(''); sel.value = cur; };
    fill('rcaFilterConductor', a.byConductor); fill('rcaFilterQcReviewer', a.byQcReviewer); fill('rcaFilterAnalyst', a.byAnalyst); fill('rcaFilterTeam', a.byTeam); fill('rcaFilterAgency', a.byAgency); fill('rcaFilterProduct', a.byProduct); fill('rcaFilterCountry', a.byCountry); fill('rcaFilterAuthority', a.byAuthority); fill('rcaFilterOrigin', a.byOrigin); fill('rcaFilterTaskType', a.byTaskType); fill('rcaFilterTypology', a.topTypologies); fill('rcaFilterTag', a.topRiskTags);
  }

  function renderKpis(a) {
    const ab = a.agreementBreakdown || { yes: 0, no: 0 }; const fl = a.flagged || { flagToTL: 0, toBeAppealed: 0 }; const ct = a.cycleTime || { avgWorkToQc: 0, avgQcToRca: 0 };
    const kpis = [
      { label: 'Total RCAs', value: fmtNum(a.total), sub: 'cases in range' },
      { label: 'Avg Defect Score', value: (a.avgDefectScore || 0).toFixed(2), sub: 'higher = more defects', kind: a.avgDefectScore > 3 ? 'critical' : a.avgDefectScore > 1 ? 'warn' : 'success' },
      { label: 'Agreement Rate', value: (a.agreementRate || 0) + '%', sub: `${ab.yes} yes / ${ab.no} no`, kind: a.agreementRate >= 70 ? 'success' : a.agreementRate >= 50 ? 'warn' : 'critical' },
      { label: 'Critical Rate', value: (a.criticalRate || 0) + '%', sub: `${a.criticalCount || 0} critical`, kind: 'critical' },
      { label: 'Avg Work→QC', value: (ct.avgWorkToQc || 0).toFixed(1) + 'd', sub: 'analyst lag', kind: ct.avgWorkToQc > KPI_WARN_DAYS ? 'warn' : '' },
      { label: 'Avg QC→RCA', value: (ct.avgQcToRca || 0).toFixed(1) + 'd', sub: 'feedback lag', kind: ct.avgQcToRca > KPI_WARN_DAYS ? 'warn' : '' },
      { label: 'Flag Rate', value: (a.flagRate || 0) + '%', sub: `${fl.flagToTL} flagged`, kind: 'warn' },
      { label: 'Appeals', value: (a.appealRate || 0) + '%', sub: `${fl.toBeAppealed} appealed`, kind: 'warn' }
