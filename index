<!DOCTYPE html>
<html data-theme="light">
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    /* ============================================================
       DESIGN TOKENS
       ============================================================ */
    :root, [data-theme="light"] {
      --bg-app:        #F5F7FA;
      --bg-card:       #FFFFFF;
      --bg-elevated:   #FFFFFF;
      --bg-subtle:     #F5F7FA;
      --bg-hover:      #F5F7FA;
      --bg-inverse:    #0A0E27;

      --text-primary:   #0A0E27;
      --text-secondary: #6B7588;
      --text-muted:     #9CA3AF;
      --text-inverse:   #FFFFFF;

      --border:        #E8EAF1;
      --border-strong: #D6DAE5;

      --accent:         #5B47E0;
      --accent-hover:   #4A38C7;
      --accent-soft:    #EEEAFF;
      --gradient:       linear-gradient(135deg, #5B47E0 0%, #8B5CF6 100%);
      --gradient-soft:  linear-gradient(135deg, #EEEAFF 0%, #F4EEFF 100%);

      --success: #14C18C;
      --success-soft: #E6FAF3;
      --warning: #FFA800;
      --warning-soft: #FFF5DC;
      --danger:  #F5365C;
      --danger-soft:  #FFEBEF;
      --info:    #2563EB;
      --info-soft:    #E6EFFE;

      --shadow-sm: 0 1px 2px rgba(10,14,39,0.04), 0 1px 3px rgba(10,14,39,0.06);
      --shadow-md: 0 4px 6px rgba(10,14,39,0.05), 0 2px 4px rgba(10,14,39,0.04);
      --shadow-lg: 0 10px 15px rgba(10,14,39,0.08), 0 4px 6px rgba(10,14,39,0.04);
      --ease: cubic-bezier(0.4, 0, 0.2, 1);
    }
    [data-theme="dark"] {
      --bg-app:        #0A0E27;
      --bg-card:       #131836;
      --bg-elevated:   #1A2046;
      --bg-subtle:     #1A2046;
      --bg-hover:      #212858;
      --bg-inverse:    #FFFFFF;

      --text-primary:   #F5F7FA;
      --text-secondary: #A8B0C5;
      --text-muted:     #6B7588;
      --text-inverse:   #0A0E27;

      --border:        #212858;
      --border-strong: #2E366B;

      --accent:         #8B7FFF;
      --accent-hover:   #A194FF;
      --accent-soft:    #2E2570;
      --gradient:       linear-gradient(135deg, #8B7FFF 0%, #B794F6 100%);
      --gradient-soft:  linear-gradient(135deg, #2E2570 0%, #3D2E80 100%);

      --success: #14C18C;
      --success-soft: #0F3D2F;
      --warning: #FFA800;
      --warning-soft: #3D2E0F;
      --danger:  #FF5470;
      --danger-soft:  #3D1424;
      --info:    #5B8DEF;
      --info-soft:    #0F2A4D;

      --shadow-sm: 0 1px 2px rgba(0,0,0,0.2), 0 1px 3px rgba(0,0,0,0.3);
      --shadow-md: 0 4px 6px rgba(0,0,0,0.25), 0 2px 4px rgba(0,0,0,0.2);
      --shadow-lg: 0 10px 15px rgba(0,0,0,0.4), 0 4px 6px rgba(0,0,0,0.25);
    }

    :root {
      --radius-sm:  8px;
      --radius-md:  12px;
      --radius-lg:  16px;
      --radius-xl:  24px;
      --radius-full: 999px;
    }

    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg-app); color: var(--text-primary);
      font-size: 14px; line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      transition: background-color 200ms var(--ease), color 200ms var(--ease);
    }
    button { font-family: inherit; cursor: pointer; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .app-shell { max-width: 1280px; margin: 0 auto; padding: 24px; }

    /* TOPBAR */
    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 14px 20px; margin-bottom: 20px;
      box-shadow: var(--shadow-sm);
    }
    .brand { display: flex; align-items: center; gap: 12px; font-weight: 700; font-size: 16px; }
    .brand-mark {
      width: 36px; height: 36px; border-radius: 10px;
      background: var(--gradient); display: grid; place-items: center;
      color: white; font-weight: 800; font-size: 14px;
    }
    .brand-meta { font-size: 12px; color: var(--text-secondary); font-weight: 400; }
    .topbar-actions { display: flex; align-items: center; gap: 8px; }
    .connection-dot {
      width: 8px; height: 8px; border-radius: 50%; background: var(--text-muted);
      transition: background 200ms var(--ease);
    }
    .connection-dot.online    { background: var(--success); box-shadow: 0 0 0 3px var(--success-soft); }
    .connection-dot.offline   { background: var(--danger);  box-shadow: 0 0 0 3px var(--danger-soft); }
    .connection-dot.busy      { background: var(--warning); box-shadow: 0 0 0 3px var(--warning-soft); animation: pulse 1.4s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

    /* CARDS */
    .card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);
      margin-bottom: 20px; overflow: hidden;
      transition: background-color 200ms var(--ease), border-color 200ms var(--ease);
    }
    .card-header {
      padding: 16px 20px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;
    }
    .card-title { margin: 0; font-size: 16px; font-weight: 700; letter-spacing: -0.01em; }
    .card-subtitle { font-size: 13px; color: var(--text-secondary); margin-top: 2px; }
    .card-body { padding: 20px; }

    /* ANALYTICS */
    .analytics-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px; padding: 16px 20px;
    }
    .kpi-card {
      background: var(--bg-subtle); border: 1px solid var(--border);
      border-radius: var(--radius-md); padding: 14px 16px;
      position: relative; overflow: hidden;
    }
    .kpi-card::before {
      content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
      background: var(--accent);
    }
    .kpi-card.kpi-critical::before { background: var(--danger); }
    .kpi-card.kpi-warn::before     { background: var(--warning); }
    .kpi-card.kpi-success::before  { background: var(--success); }
    .kpi-card.kpi-info::before     { background: var(--info); }
    .kpi-label { font-size: 11px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em; }
    .kpi-value { font-size: 26px; font-weight: 800; margin-top: 4px; letter-spacing: -0.02em; line-height: 1.1; }
    .kpi-sub { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

    .analytics-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; padding: 0 20px 20px; }
    @media (max-width: 768px) { .analytics-row { grid-template-columns: 1fr; } }
    .breakdown-card { background: var(--bg-subtle); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 14px 16px; }
    .breakdown-title { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-secondary); margin-bottom: 10px; }
    .bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; font-size: 12px; }
    .bar-label { flex: 0 0 110px; color: var(--text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .bar-track { flex: 1; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
    .bar-fill { height: 100%; background: var(--gradient); border-radius: 4px; transition: width 400ms var(--ease); }
    .bar-value { flex: 0 0 30px; text-align: right; font-weight: 600; }

    /* BUTTONS */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      padding: 9px 16px; border-radius: var(--radius-full);
      border: 1px solid transparent; font-weight: 600; font-size: 13px;
      transition: all 150ms var(--ease);
      background: var(--bg-card); color: var(--text-primary);
    }
    .btn:hover:not(:disabled) { transform: translateY(-1px); }
    .btn:active { transform: translateY(0); }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-primary {
      background: var(--gradient); color: white;
      box-shadow: 0 2px 8px rgba(91,71,224,0.25);
    }
    .btn-primary:hover:not(:disabled) { box-shadow: 0 4px 12px rgba(91,71,224,0.35); }
    .btn-secondary { background: var(--bg-card); border-color: var(--border-strong); color: var(--text-primary); }
    .btn-secondary:hover:not(:disabled) { background: var(--bg-hover); }
    .btn-ghost { background: transparent; color: var(--text-secondary); }
    .btn-ghost:hover:not(:disabled) { background: var(--bg-hover); color: var(--text-primary); }
    .btn-block { width: 100%; }
    .btn-sm { padding: 6px 12px; font-size: 12px; }
    .btn-lg { padding: 13px 22px; font-size: 14px; }
    .btn-icon { width: 36px; height: 36px; padding: 0; border-radius: 50%; }

    /* IMPROVED FILTERS */
    .filters-card {
      background: var(--bg-subtle);
      border-bottom: 1px solid var(--border);
      padding: 14px 20px;
    }
    .filters-card.hidden { display: none; }
    .filters-toolbar {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 10px; gap: 12px;
    }
    .filters-title {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--text-secondary);
      display: flex; align-items: center; gap: 6px;
    }
    .filter-chips {
      display: flex; flex-wrap: wrap; gap: 6px; flex: 1;
    }
    .filter-chip {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 4px 8px 4px 10px; border-radius: var(--radius-full);
      background: var(--bg-card); border: 1px solid var(--border-strong);
      font-size: 11px; font-weight: 500; color: var(--text-primary);
      cursor: pointer; transition: all 100ms var(--ease);
    }
    .filter-chip:hover { border-color: var(--accent); }
    .filter-chip select {
      border: none; background: transparent; font-family: inherit;
      font-size: 11px; font-weight: 500; color: var(--text-primary);
      cursor: pointer; padding: 0; outline: none;
    }
    .filter-chip-icon {
      width: 14px; height: 14px; border-radius: 50%;
      background: var(--accent-soft); color: var(--accent);
      display: grid; place-items: center; font-size: 8px;
    }
    .filter-chip-dates {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 4px 8px; border-radius: var(--radius-full);
      background: var(--bg-card); border: 1px solid var(--border-strong);
      font-size: 11px; color: var(--text-secondary);
    }
    .filter-chip-dates input {
      border: none; background: transparent; font-family: inherit;
      font-size: 11px; color: var(--text-primary); width: 100px; outline: none;
    }
    .filter-chip-dates input::-webkit-calendar-picker-indicator {
      cursor: pointer; opacity: 0.6;
    }
    .filter-clear-btn {
      padding: 4px 10px; border-radius: var(--radius-full);
      background: var(--danger-soft); color: var(--danger);
      border: none; font-size: 11px; font-weight: 600; cursor: pointer;
      transition: all 100ms var(--ease);
    }
    .filter-clear-btn:hover { background: var(--danger); color: white; }

    /* TABLE */
    .table-scroll { 
      overflow-x: auto; 
      max-width: 100%;
      -webkit-overflow-scrolling: touch;
    }
    .data-table { 
      width: 100%; 
      min-width: 1400px;
      border-collapse: collapse; 
      font-size: 12px; 
    }
    .data-table thead th {
      background: var(--bg-subtle); color: var(--text-secondary);
      font-weight: 600; font-size: 10px; text-transform: uppercase;
      letter-spacing: 0.04em; padding: 10px 12px; text-align: left;
      border-bottom: 1px solid var(--border); white-space: nowrap;
      position: sticky; top: 0; z-index: 1;
    }
    .data-table tbody td {
      padding: 10px 12px; 
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
      max-width: 200px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .data-table tbody tr { transition: background-color 100ms var(--ease); }
    .data-table tbody tr:hover { background: var(--bg-hover); }

    /* PAGINATION */
    .pagination {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 20px; gap: 12px; flex-wrap: wrap;
      border-top: 1px solid var(--border);
    }
    .pagination-info { font-size: 12px; color: var(--text-secondary); }
    .pagination-controls { display: flex; align-items: center; gap: 6px; }
    .pagination-controls button {
      min-width: 32px; height: 32px; padding: 0 8px;
      border-radius: var(--radius-sm); border: 1px solid var(--border-strong);
      background: var(--bg-card); color: var(--text-primary);
      font-size: 12px; font-weight: 600; transition: all 120ms var(--ease);
    }
    .pagination-controls button:hover:not(:disabled) { background: var(--bg-hover); }
    .pagination-controls button.active { background: var(--gradient); color: white; border-color: transparent; }
    .pagination-controls button:disabled { opacity: 0.4; cursor: not-allowed; }
    .page-size-select { padding: 5px 8px; font-size: 12px; border-radius: var(--radius-sm); border: 1px solid var(--border-strong); background: var(--bg-card); color: var(--text-primary); }

    /* BADGES */
    .badge {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 2px 8px; border-radius: var(--radius-full);
      font-size: 10px; font-weight: 600; line-height: 1.5;
    }
    .badge-retail   { background: var(--info-soft);    color: var(--info); }
    .badge-business { background: var(--bg-subtle);    color: var(--text-primary); border: 1px solid var(--border); }
    .badge-fail     { background: var(--danger-soft);  color: var(--danger); }
    .badge-major    { background: var(--warning-soft); color: var(--warning); }
    .badge-minor    { background: #FEF3C7;             color: #92400E; }
    .badge-success  { background: var(--success-soft); color: var(--success); }
    [data-theme="dark"] .badge-minor { background: #3D2E0F; color: #FBBF24; }

    .status-dot { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; }
    .status-dot::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--text-muted);
    }
    .status-dot-success::before { background: var(--success); }
    .status-dot-warn::before    { background: var(--warning); }
    .status-dot-danger::before  { background: var(--danger); }

    .lock-pill {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 2px 8px; border-radius: var(--radius-full);
      font-size: 10px; font-weight: 600; margin-top: 4px;
    }
    .lock-pill-mine  { background: var(--warning-soft); color: var(--warning); }
    .lock-pill-other { background: var(--danger-soft);  color: var(--danger); }
    .sla-tag {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 2px 8px; border-radius: var(--radius-full);
      font-size: 10px; font-weight: 600; margin-top: 4px;
      background: var(--danger-soft); color: var(--danger);
    }

    /* LOADING / SKELETON */
    @keyframes shimmer {
      0%   { background-position: -400px 0; }
      100% { background-position: 400px 0; }
    }
    .skeleton {
      background: linear-gradient(90deg, var(--bg-subtle) 0px, var(--bg-hover) 200px, var(--bg-subtle) 400px);
      background-size: 800px 100%;
      animation: shimmer 1.4s infinite linear;
      border-radius: var(--radius-sm);
    }
    .skeleton-row { height: 44px; margin-bottom: 8px; }
    .skeleton-text { height: 12px; margin-bottom: 6px; }

    .step-loader { padding: 24px; display: flex; flex-direction: column; gap: 10px; }
    .step {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 14px; border-radius: var(--radius-sm);
      background: var(--bg-subtle); border: 1px solid var(--border);
      transition: all 200ms var(--ease);
    }
    .step.active { border-color: var(--accent); background: var(--accent-soft); }
    .step.done   { border-color: var(--success); background: var(--success-soft); }
    .step.error  { border-color: var(--danger); background: var(--danger-soft); }
    .step-icon {
      width: 22px; height: 22px; border-radius: 50%;
      background: var(--border); color: var(--text-secondary);
      display: grid; place-items: center; font-size: 12px; font-weight: 700;
      flex-shrink: 0;
    }
    .step.active .step-icon { background: var(--accent); color: white; animation: pulse 1.4s infinite; }
    .step.done   .step-icon { background: var(--success); color: white; }
    .step.error  .step-icon { background: var(--danger);  color: white; }
    .step-label  { flex: 1; font-size: 13px; font-weight: 600; }
    .step-time   { font-size: 11px; color: var(--text-secondary); font-family: 'JetBrains Mono', monospace; }

    .stuck-banner {
      padding: 12px 16px; background: var(--warning-soft); color: var(--warning);
      border-radius: var(--radius-sm); border-left: 3px solid var(--warning);
      font-size: 13px; font-weight: 600;
      display: flex; align-items: center; gap: 10px; justify-content: space-between;
      margin: 0 24px 24px;
    }

    /* EMPTY / SUCCESS */
    .empty-state { padding: 50px 20px; text-align: center; }
    .empty-state-icon {
      width: 56px; height: 56px; border-radius: var(--radius-md);
      background: var(--gradient-soft); margin: 0 auto 14px;
      display: grid; place-items: center; font-size: 24px;
    }
    .empty-state-title { font-size: 15px; font-weight: 700; margin: 0 0 4px; }
    .empty-state-desc  { color: var(--text-secondary); font-size: 12px; }
    .success-screen { padding: 40px 20px; text-align: center; }
    .success-icon {
      width: 60px; height: 60px; border-radius: 50%;
      background: var(--success-soft); color: var(--success);
      display: grid; place-items: center; font-size: 28px; margin: 0 auto 14px;
    }

    /* TOAST / MODAL */
    .toast-container {
      position: fixed; top: 20px; right: 20px; z-index: 9999;
      display: flex; flex-direction: column; gap: 8px; max-width: 360px;
    }
    .toast {
      background: var(--bg-card); border: 1px solid var(--border);
      border-left: 4px solid var(--accent); border-radius: var(--radius-md);
      padding: 12px 14px; box-shadow: var(--shadow-lg);
      display: flex; align-items: flex-start; gap: 10px;
      animation: slideIn 200ms var(--ease);
    }
    .toast-success { border-left-color: var(--success); }
    .toast-error   { border-left-color: var(--danger); }
    .toast-warn    { border-left-color: var(--warning); }
    .toast-title { font-weight: 600; font-size: 13px; margin: 0 0 2px; }
    .toast-desc  { color: var(--text-secondary); font-size: 12px; margin: 0; }
    @keyframes slideIn { from { transform: translateX(120%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    @keyframes slideOut { to { transform: translateX(120%); opacity: 0; } }

    /* DIAGNOSTICS PANEL */
    .diag-fab {
      position: fixed; bottom: 20px; right: 20px; z-index: 9990;
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--gradient); color: white;
      box-shadow: var(--shadow-lg); border: none; cursor: pointer;
      display: grid; place-items: center; font-size: 18px;
      transition: transform 150ms var(--ease);
    }
    .diag-fab:hover { transform: scale(1.05); }
    .diag-panel {
      position: fixed; bottom: 76px; right: 20px; z-index: 9991;
      width: 380px; max-width: calc(100vw - 40px);
      max-height: 70vh; background: var(--bg-card);
      border: 1px solid var(--border); border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg); display: none; flex-direction: column;
      overflow: hidden;
    }
    .diag-panel.open { display: flex; animation: fadeIn 150ms var(--ease); }
    .diag-header {
      padding: 12px 16px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      background: var(--bg-subtle);
    }
    .diag-tabs { display: flex; border-bottom: 1px solid var(--border); background: var(--bg-subtle); }
    .diag-tab {
      flex: 1; padding: 10px; border: none; background: transparent;
      color: var(--text-secondary); font-weight: 600; font-size: 12px;
      cursor: pointer; border-bottom: 2px solid transparent;
    }
    .diag-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
    .diag-body { padding: 12px 16px; overflow-y: auto; max-height: 50vh; font-family: 'JetBrains Mono', monospace; font-size: 11px; }
    .diag-body .row { display: flex; justify-content: space-between; padding: 4px 0; border-bottom: 1px dashed var(--border); }
    .diag-body .label { color: var(--text-secondary); }
    .diag-body .value { color: var(--text-primary); font-weight: 600; }
    .diag-body .value.ok   { color: var(--success); }
    .diag-body .value.warn { color: var(--warning); }
    .diag-body .value.err  { color: var(--danger); }
    .diag-error-block {
      background: var(--danger-soft); border-left: 3px solid var(--danger);
      padding: 8px 10px; border-radius: 4px; margin: 6px 0;
      color: var(--danger); font-size: 11px; word-break: break-word;
    }
    .diag-empty { color: var(--text-muted); text-align: center; padding: 16px; font-style: italic; }
    .diag-actions { display: flex; gap: 6px; padding: 8px 12px; border-top: 1px solid var(--border); }
    .diag-actions .btn { flex: 1; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    /* FORM VIEW */
    .link-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
    @media (max-width: 640px) { .link-cards { grid-template-columns: 1fr; } }
    .link-card {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 14px; background: var(--bg-card);
      border: 1px solid var(--border); border-radius: var(--radius-md);
      color: var(--text-primary); text-decoration: none !important;
      transition: all 150ms var(--ease);
    }
    .link-card:hover { border-color: var(--accent); transform: translateY(-1px); box-shadow: var(--shadow-sm); }
    .link-card-icon {
      width: 36px; height: 36px; border-radius: var(--radius-sm);
      background: var(--accent-soft); color: var(--accent);
      display: grid; place-items: center; font-size: 18px; flex-shrink: 0;
    }
    .link-card-title { font-weight: 600; font-size: 13px; }
    .link-card-sub   { font-size: 11px; color: var(--text-secondary); }

    .readonly-box {
      background: var(--bg-subtle); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 12px 14px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px; white-space: pre-wrap; color: var(--text-primary);
      max-height: 180px; overflow-y: auto;
    }

    .form-group { margin-bottom: 16px; }
    .form-label {
      display: block; font-size: 11px; font-weight: 600; margin-bottom: 6px;
      color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em;
    }
    .form-label-required::after { content: ' *'; color: var(--danger); }
    .input, .select, .textarea {
      width: 100%; padding: 9px 12px; border: 1px solid var(--border-strong);
      border-radius: var(--radius-sm); font-family: inherit; font-size: 13px;
      background: var(--bg-card); color: var(--text-primary);
      transition: border-color 150ms var(--ease), box-shadow 150ms var(--ease);
    }
    .input:focus, .select:focus, .textarea:focus {
      outline: none; border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(91,71,224,0.15);
    }
    .input:read-only { background: var(--bg-subtle); color: var(--text-secondary); }
    .textarea { resize: vertical; min-height: 80px; }

    .row { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    @media (max-width: 768px) { .row { grid-template-columns: 1fr; } }

    .ts-wrapper { width: 100%; }
    .ts-wrapper .ts-control {
      border-radius: var(--radius-sm); border-color: var(--border-strong);
      padding: 7px 10px; min-height: 40px; font-size: 13px;
      box-shadow: none !important; background: var(--bg-card); color: var(--text-primary);
    }
    .ts-wrapper.focus .ts-control {
      border-color: var(--accent) !important;
      box-shadow: 0 0 0 3px rgba(91,71,224,0.15) !important;
    }
    .ts-dropdown { border-radius: var(--radius-sm); border-color: var(--border-strong); box-shadow: var(--shadow-lg); font-size: 13px; background: var(--bg-card); color: var(--text-primary); }

    .phase-header { display: flex; align-items: center; gap: 12px; margin: 28px 0 14px; }
    .phase-num {
      width: 30px; height: 30px; border-radius: 50%;
      background: var(--gradient); color: white;
      display: grid; place-items: center; font-weight: 700; font-size: 13px;
      flex-shrink: 0;
    }
    .phase-title { font-size: 15px; font-weight: 700; letter-spacing: -0.01em; }

    .sub-group {
      margin: 10px 0 14px; padding: 14px;
      background: var(--bg-subtle); border: 1px solid var(--border);
      border-left: 3px solid var(--accent); border-radius: var(--radius-sm);
    }

    .callout {
      display: flex; gap: 10px; padding: 12px 14px;
      border-radius: var(--radius-sm); font-size: 12px; line-height: 1.5;
      margin-bottom: 14px;
    }
    .callout-info    { background: var(--info-soft);    color: var(--info); border-left: 3px solid var(--info); }
    .callout-warn    { background: var(--warning-soft); color: var(--warning); border-left: 3px solid var(--warning); }
    .callout-success { background: var(--success-soft); color: var(--success); border-left: 3px solid var(--success); }

    .action-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 14px; }
    @media (max-width: 768px) { .action-row { grid-template-columns: 1fr; } }
    .action-card {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 12px; border-radius: var(--radius-sm);
      border: 1px solid var(--border); cursor: pointer;
      background: var(--bg-card);
    }
    .action-card:hover { border-color: var(--border-strong); }
    .action-card input { width: 16px; height: 16px; accent-color: var(--accent); cursor: pointer; }
    .action-card-label { font-weight: 600; font-size: 12px; }
    .action-card-danger  { border-left: 3px solid var(--danger); }
    .action-card-warn    { border-left: 3px solid var(--warning); }
    .action-card-success { border-left: 3px solid var(--success); }

    .scanner-card {
      background: var(--gradient-soft); border: 1px solid #E0D5FF;
      border-radius: var(--radius-md); padding: 16px; margin-bottom: 14px;
    }
    [data-theme="dark"] .scanner-card { border-color: #3D2E80; }
    .scanner-card h4 { margin: 0 0 6px; font-size: 13px; color: var(--accent); }
    .scanner-card p  { margin: 0 0 10px; font-size: 12px; color: var(--text-secondary); }
    #scanSummary {
      margin-top: 10px; padding: 12px; background: var(--bg-card);
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      font-size: 12px; line-height: 1.6;
    }

    .au-row {
      display: flex; gap: 10px; margin-bottom: 8px;
    }
    .au-row .au-url-inp  { flex: 1; }
    .au-row .au-outcome  { flex: 1; }
    @media (max-width: 640px) { .au-row { flex-direction: column; } }

    .refund-card {
      background: var(--success-soft); border: 1px solid var(--success);
      border-radius: var(--radius-md); padding: 16px; margin-bottom: 14px;
    }
    .refund-card h4 { margin: 0 0 6px; font-size: 13px; color: var(--success); }
    .refund-card p  { margin: 0 0 10px; font-size: 11px; color: var(--text-secondary); }
    .refund-grid {
      display: grid; grid-template-columns: 1fr 1fr auto; gap: 10px; align-items: end;
    }
    @media (max-width: 640px) { .refund-grid { grid-template-columns: 1fr; } }
    .refund-result {
      margin-top: 10px; padding: 10px 12px; border-radius: var(--radius-sm);
      background: var(--bg-card); border: 1px solid var(--border);
      font-weight: 600; font-size: 13px;
    }

    .callout-warn b, .callout-info b, .callout-success b { color: inherit; }
    .hidden { display: none !important; }
    .text-center { text-align: center; }
    .mt-1 { margin-top: 8px; } .mt-2 { margin-top: 16px; } .mt-3 { margin-top: 24px; }
    .mb-1 { margin-bottom: 8px; } .mb-2 { margin-bottom: 16px; } .mb-3 { margin-bottom: 24px; }
    .flex { display: flex; } .items-center { align-items: center; } .justify-between { justify-content: space-between; }
    .fw-600 { font-weight: 600; } .fw-700 { font-weight: 700; }
    .text-muted { color: var(--text-secondary); }
    .text-sm { font-size: 12px; }
    
    /* ============================================================
       VIEW ISOLATION — Force dashboard / form / analytics to be mutually exclusive
       ============================================================ */
    #dashboardView, #formView, #rcaAnalyticsView { display: none; }
    
    /* Show classes applied by JS */
    #dashboardView.show-view { display: block !important; }
    #formView.show-view { display: block !important; }
    #rcaAnalyticsView.show-view { display: block !important; }

    /* ============================================================
       IN-APP MODAL — Replaces ugly native confirm() dialogs
       ============================================================ */
    .modal-backdrop {
      position: fixed; inset: 0; z-index: 10000;
      background: rgba(10, 14, 39, 0.55);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      display: grid; place-items: center;
      padding: 20px;
      animation: modalFadeIn 150ms var(--ease);
    }
    @keyframes modalFadeIn  { from { opacity: 0; } to { opacity: 1; } }
    @keyframes modalFadeOut { from { opacity: 1; } to { opacity: 0; } }
    @keyframes modalSlideUp { from { transform: translateY(16px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    .modal-backdrop.closing { animation: modalFadeOut 150ms var(--ease) forwards; }
    .modal-backdrop.closing .modal { animation: modalSlideDown 150ms var(--ease) forwards; }
    @keyframes modalSlideDown { to { transform: translateY(16px); opacity: 0; } }

    .modal {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      padding: 24px;
      max-width: 440px;
      width: 100%;
      animation: modalSlideUp 200ms var(--ease);
    }
    .modal-title {
      margin: 0 0 8px;
      font-size: 16px;
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.01em;
      display: flex; align-items: center; gap: 8px;
    }
    .modal-desc {
      margin: 0 0 20px;
      font-size: 13px;
      line-height: 1.6;
      color: var(--text-secondary);
    }
    .modal-actions {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      flex-wrap: wrap;
    }
    [data-theme="dark"] .modal-backdrop { background: rgba(0, 0, 0, 0.7); }
    
    /* ============================================================
       RCA ANALYTICS DASHBOARD
       ============================================================ */
    .analytics-tabs {
      display: flex; gap: 4px; background: var(--bg-subtle);
      border-radius: var(--radius-full); padding: 4px;
      border: 1px solid var(--border);
    }
    .analytics-tab {
      padding: 7px 16px; border-radius: var(--radius-full);
      border: none; background: transparent;
      font-weight: 600; font-size: 12px; color: var(--text-secondary);
      cursor: pointer; transition: all 150ms var(--ease);
    }
    .analytics-tab.active {
      background: var(--bg-card); color: var(--accent);
      box-shadow: var(--shadow-sm);
    }

    .analytics-filter-bar {
      display: flex; flex-wrap: wrap; gap: 10px;
      background: var(--bg-subtle); border: 1px solid var(--border);
      border-radius: var(--radius-md); padding: 14px 16px;
      margin-bottom: 20px;
    }
    .analytics-filter-bar .filter-group {
      display: flex; flex-direction: column; gap: 4px; flex: 1; min-width: 140px;
    }
    .analytics-filter-bar .filter-group label {
      font-size: 10px; font-weight: 600; color: var(--text-secondary);
      text-transform: uppercase; letter-spacing: 0.04em;
    }
    .analytics-filter-bar .filter-group select,
    .analytics-filter-bar .filter-group input {
      padding: 7px 10px; border: 1px solid var(--border-strong);
      border-radius: var(--radius-sm); background: var(--bg-card);
      color: var(--text-primary); font-size: 12px; font-family: inherit;
    }
    .analytics-filter-bar .filter-actions {
      display: flex; align-items: flex-end; gap: 6px;
    }

    .trend-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius-md); padding: 16px 20px;
      margin-bottom: 20px;
    }
    .trend-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
    .trend-title { font-size: 13px; font-weight: 700; color: var(--text-primary); }
    .trend-controls { display: flex; gap: 6px; }
    .trend-controls button {
      padding: 5px 12px; border-radius: var(--radius-full);
      border: 1px solid var(--border-strong); background: var(--bg-card);
      color: var(--text-secondary); font-size: 11px; font-weight: 600;
      cursor: pointer;
    }
    .trend-controls button.active {
      background: var(--gradient); color: white; border-color: transparent;
    }
    .trend-canvas-wrap { position: relative; height: 240px; }

    .leaderboard {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius-md); padding: 14px 16px;
    }
    .leaderboard h4 {
      margin: 0 0 10px; font-size: 12px; font-weight: 700;
      text-transform: uppercase; color: var(--text-secondary); letter-spacing: 0.04em;
    }
    .leaderboard .lb-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 8px 10px; margin-bottom: 4px; border-radius: var(--radius-sm);
      background: var(--bg-subtle); cursor: pointer;
      transition: background 100ms var(--ease);
    }
    .leaderboard .lb-row:hover { background: var(--bg-hover); }
    .leaderboard .lb-rank {
      width: 24px; height: 24px; border-radius: 50%;
      background: var(--border); color: var(--text-secondary);
      display: grid; place-items: center; font-size: 11px; font-weight: 700;
      flex-shrink: 0;
    }
    .leaderboard .lb-rank.gold   { background: linear-gradient(135deg, #FFD700, #FFA500); color: white; }
    .leaderboard .lb-rank.silver { background: linear-gradient(135deg, #C0C0C0, #808080); color: white; }
    .leaderboard .lb-rank.bronze { background: linear-gradient(135deg, #CD7F32, #8B4513); color: white; }
    .leaderboard .lb-name {
      flex: 1; margin: 0 10px; font-size: 12px; font-weight: 500;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      color: var(--text-primary);
    }
    .leaderboard .lb-count {
      font-size: 14px; font-weight: 700; color: var(--accent);
    }

    .rca-kpi-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px; padding: 16px 20px;
    }

    .rca-row-grid {
      display: grid; grid-template-columns: 2fr 1fr; gap: 20px;
      padding: 0 20px 20px;
    }
    @media (max-width: 900px) { .rca-row-grid { grid-template-columns: 1fr; } }

    .rca-table th { font-size: 10px; }
    .rca-table td { font-size: 11px; padding: 8px 10px; }

    .defect-pill {
      display: inline-block; padding: 2px 8px; border-radius: var(--radius-full);
      font-size: 10px; font-weight: 600;
    }
    .defect-pill-Critical { background: var(--danger-soft); color: var(--danger); }
    .defect-pill-None     { background: var(--success-soft); color: var(--success); }
    .defect-pill-Unknown  { background: var(--bg-subtle); color: var(--text-secondary); }

    .action-pill {
      display: inline-block; padding: 1px 6px; margin-right: 2px;
      border-radius: var(--radius-full); font-size: 9px; font-weight: 700;
      background: var(--bg-subtle); color: var(--text-secondary);
    }
    .action-pill.active.flag     { background: var(--danger-soft); color: var(--danger); }
    .action-pill.active.appeal   { background: var(--warning-soft); color: var(--warning); }
    .action-pill.active.accepted { background: var(--success-soft); color: var(--success); }

    :root, [data-theme="light"] {
      --chart-line: #5B47E0;
      --chart-fill: rgba(91, 71, 224, 0.12);
      --chart-grid: rgba(0, 0, 0, 0.05);
      --chart-tick: #6B7588;
      --chart-red: #F5365C;
      --chart-green: #14C18C;
      --chart-orange: #FFA800;
      --chart-blue: #2563EB;
      --chart-gray: #9CA3AF;
    }
    [data-theme="dark"] {
      --chart-line: #8B7FFF;
      --chart-fill: rgba(139, 127, 255, 0.18);
      --chart-grid: rgba(255, 255, 255, 0.06);
      --chart-tick: #A8B0C5;
      --chart-red: #FF5470;
      --chart-green: #14C18C;
      --chart-orange: #FFA800;
      --chart-blue: #5B8DEF;
      --chart-gray: #6B7588;
    }

    .analytics-empty { padding: 30px; text-align: center; color: var(--text-muted); font-size: 12px; }

    .chart-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
      padding: 0 20px 20px;
    }
    @media (max-width: 900px) { .chart-grid { grid-template-columns: 1fr; } }

    .chart-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius-md); padding: 16px 20px;
      display: flex; flex-direction: column;
    }
    .chart-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .chart-card-title { font-size: 13px; font-weight: 700; color: var(--text-primary); }
    .chart-card-sub   { font-size: 11px; color: var(--text-secondary); }
    .chart-canvas-wrap { position: relative; flex: 1; min-height: 220px; }

    .phase-bar-row {
      display: grid; grid-template-columns: 130px 1fr 70px;
      align-items: center; gap: 10px; margin-bottom: 8px;
      font-size: 12px;
    }
    .phase-bar-track {
      height: 22px; background: var(--bg-app);
      border-radius: 6px; overflow: hidden; position: relative;
      border: 1px solid var(--border);
    }
    .phase-bar-pass {
      position: absolute; left: 0; top: 0; bottom: 0;
      background: var(--chart-green); transition: width 400ms var(--ease);
    }
    .phase-bar-fail {
      position: absolute; right: 0; top: 0; bottom: 0;
      background: var(--chart-red); transition: width 400ms var(--ease);
    }
    .phase-bar-label { color: var(--text-primary); font-weight: 600; }
    .phase-bar-rate  { font-weight: 700; font-size: 12px; text-align: right; }
    .phase-bar-rate.fail-high { color: var(--chart-red); }
    .phase-bar-rate.fail-mid  { color: var(--chart-orange); }
    .phase-bar-rate.fail-low  { color: var(--chart-green); }

    .donut-legend { display: flex; flex-direction: column; gap: 6px; margin-top: 12px; }
    .donut-legend-row {
      display: flex; align-items: center; gap: 8px;
      font-size: 12px;
    }
    .donut-legend-dot { width: 10px; height: 10px; border-radius: 3px; }
    .donut-legend-name { flex: 1; color: var(--text-primary); }
    .donut-legend-val  { font-weight: 700; color: var(--text-secondary); }

    .table-cell-trunc {
      max-width: 280px; overflow: hidden; text-overflow: ellipsis;
      white-space: nowrap; display: inline-block; vertical-align: middle;
    }

    .analytics-search {
      flex: 1; min-width: 180px; padding: 7px 12px;
      border: 1px solid var(--border-strong); border-radius: var(--radius-sm);
      background: var(--bg-card); color: var(--text-primary);
      font-size: 12px; font-family: inherit;
    }
    .analytics-search:focus {
      outline: none; border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(91,71,224,0.15);
    }

    .date-target-chip {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 8px; border-radius: var(--radius-full);
      background: var(--bg-card); border: 1px solid var(--border-strong);
      font-size: 11px; color: var(--text-secondary);
    }
    .date-target-chip select {
      border: none; background: transparent;
      font-size: 11px; font-weight: 600; color: var(--accent);
      cursor: pointer; outline: none;
    }

    .text-link {
      color: var(--accent); text-decoration: none; font-weight: 600;
      display: inline-flex; align-items: center; gap: 3px;
    }
    .text-link:hover { text-decoration: underline; }
    .text-link.disabled { color: var(--text-muted); cursor: not-allowed; }
  </style>
</head>
<body>

<div class="toast-container" id="toastContainer"></div>

<button class="diag-fab" id="diagFab" onclick="toggleDiag()" title="Diagnostics (D)">⚙</button>
<div class="diag-panel" id="diagPanel">
  <div class="diag-header">
    <strong style="font-size: 13px;">Diagnostics</strong>
    <button class="btn btn-ghost btn-sm" onclick="toggleDiag()">✕</button>
  </div>
  <div class="diag-tabs">
    <button class="diag-tab active" data-tab="perf">Performance</button>
    <button class="diag-tab" data-tab="errors">Errors</button>
    <button class="diag-tab" data-tab="system">System</button>
  </div>
  <div class="diag-body" id="diagBody"></div>
  <div class="diag-actions">
    <button class="btn btn-secondary btn-sm" onclick="copyDiagnostics()">Copy log</button>
    <button class="btn btn-secondary btn-sm" onclick="clearDiagnostics()">Clear</button>
    <button class="btn btn-primary btn-sm" onclick="loadCases(true); toggleDiag();">Re-test</button>
  </div>
</div>

<div class="app-shell">

 <div class="topbar">
  <div class="brand">
    <div class="brand-mark">F</div>
    <div>
      <div>FIU RCA Wizard</div>
      <div class="brand-meta" id="topbarMeta">Connecting…</div>
    </div>
  </div>
  <div class="topbar-actions">
    <div class="analytics-tabs">
      <button class="analytics-tab active" id="tabPending" onclick="switchTab('pending')">📋 Pending Cases</button>
      <button class="analytics-tab" id="tabRcaAnalytics" onclick="switchTab('analytics')">📊 RCA Analytics</button>
    </div>
    <div class="flex items-center gap-2" title="Connection status">
      <span class="connection-dot" id="connectionDot"></span>
      <span class="text-sm text-muted" id="connectionLabel">Idle</span>
    </div>
    <button class="btn btn-ghost btn-sm" id="refreshBtn" onclick="refreshCurrentTab()">
      <span id="refreshIcon">↻</span> Refresh
    </button>
    <button class="btn btn-ghost btn-icon" id="themeBtn" onclick="toggleTheme()" title="Toggle theme">
      <span id="themeIcon">🌙</span>
    </button>
  </div>
</div>

  <div id="dashboardView" class="show-view">
    <div class="card" id="analyticsCard" style="display:none;">
      <div class="card-header">
        <div>
          <h2 class="card-title">Analytics</h2>
          <div class="card-subtitle" id="analyticsSubtitle"></div>
        </div>
      </div>
      <div class="analytics-grid" id="kpiGrid"></div>
      <div class="analytics-row">
        <div class="breakdown-card">
          <div class="breakdown-title">By Defect</div>
          <div id="defectBreakdown"></div>
        </div>
        <div class="breakdown-card">
          <div class="breakdown-title">Top Teams</div>
          <div id="teamBreakdown"></div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div>
          <h2 class="card-title">Pending Cases</h2>
          <div class="card-subtitle" id="dashboardSubtitle">Loading…</div>
