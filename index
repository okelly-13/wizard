<script>
  // ============================================================
  // GLOBAL STATE
  // ============================================================
  let globalCases        = [];
  let caseIndexMap       = new Map();
  let currentCaseId      = null;
  let tomSelectInstances = {};
  let _suppressDraft     = false;
  let _lockRefreshTimer  = null;
  let _stuckTimer        = null;
  let _currentLoadToken  = 0;
  let currentPage        = 1;
  let pageSize           = 50;
  let filteredCases      = [];
  let currentTab         = 'pending'; // 'pending' or 'analytics'
  let currentTrendScale  = 'daily'; // daily, weekly, monthly

  // RCA Analytics State
  let rcaCurrentPage = 1;
  let rcaPageSize = 25;
  let rcaData = null; // Store fetched analytics data

  // Chart Instances
  let rcaTrendChartObj = null;
  let rcaCycleChartObj = null;
  let rcaSystemicChartObj = null;
  let rcaAgreementChartObj = null;
  let paretoChartObj = null;
  let analystMatrixChartObj = null;
  let phaseHeatmapChartObj = null;

  const diag = {
    startedAt: null,
    steps: { ping: 0, fetch: 0, process: 0, build: 0, render: 0 },
    lastSuccess: null, lastError: null,
    history: [], errors: [],
    cacheHits: 0, cacheMiss: 0, apiCalls: 0
  };

  // ============================================================
  // DOM UTILITIES
  // ============================================================
  const $  = (id) => document.getElementById(id);
  const safeGet        = (id) => $(id) ? $(id).value : '';
  const safeGetChecked = (id) => $(id) ? $(id).checked : false;

  function escapeHtml(s) {
    return String(s == null ? '' : s).replace(/[&<>"']/g, m => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[m]));
  }

  // ============================================================
  // VIEW SWITCHING (Tabs & Forms)
  // ============================================================
  function switchTab(tabId) {
    currentTab = tabId;
    document.querySelectorAll('.analytics-tab').forEach(btn => btn.classList.remove('active'));
    
    const dashboard = $('dashboardView');
    const form = $('formView');
    const analytics = $('rcaAnalyticsView');
    
    // Hide all
    if (dashboard) dashboard.classList.remove('show-view');
    if (form) form.classList.remove('show-view');
    if (analytics) analytics.classList.remove('show-view');
    document.body.classList.remove('form-open');

    if (tabId === 'pending') {
      $('tabPending').classList.add('active');
      if (dashboard) dashboard.classList.add('show-view');
    } else if (tabId === 'analytics') {
      $('tabRcaAnalytics').classList.add('active');
      if (analytics) analytics.classList.add('show-view');
      loadRcaAnalytics(); // Fetch data when switched
    }
  }

  function showForm() {
    // Hide dashboard and analytics, show form
    $('dashboardView').classList.remove('show-view');
    $('rcaAnalyticsView').classList.remove('show-view');
    $('formView').classList.add('show-view');
    document.body.classList.add('form-open');
    window.scrollTo(0, 0);
  }

  function returnToQueue() {
    if (currentCaseId) {
      google.script.run.unlockCase(currentCaseId);
      currentCaseId = null;
    }
    clearInterval(_lockRefreshTimer);
    
    $('formView').classList.remove('show-view');
    $('dashboardView').classList.add('show-view');
    document.body.classList.remove('form-open');
    
    loadCases(true); // Soft refresh
  }

  // ============================================================
  // UI COMPONENTS (Toasts, Modals, Diagnostics)
  // ============================================================
  function showToast({ title, description = '', type = 'info', duration = 4000 }) {
    const c = $('toastContainer');
    if (!c) return;
    const t = document.createElement('div');
    t.className = `toast toast-${type}`;
    t.innerHTML = `
      <div style="flex:1;">
        <div class="toast-title">${escapeHtml(title)}</div>
        ${description ? `<div class="toast-desc">${escapeHtml(description)}</div>` : ''}
      </div>
      <button class="btn btn-ghost btn-sm" onclick="this.parentElement.remove()">×</button>
    `;
    c.appendChild(t);
    setTimeout(() => {
      t.style.animation = 'slideOut 200ms forwards';
      setTimeout(() => t.remove(), 200);
    }, duration);
  }

  function showModal({ title, description, confirmText = 'Confirm', cancelText = 'Cancel', danger = false }) {
    return new Promise((resolve) => {
      const backdrop = document.createElement('div');
      backdrop.className = 'modal-backdrop';
      backdrop.innerHTML = `
        <div class="modal">
          <h3 class="modal-title">${escapeHtml(title)}</h3>
          <p class="modal-desc">${escapeHtml(description)}</p>
          <div class="modal-actions">
            <button class="btn btn-secondary" data-act="cancel">${escapeHtml(cancelText)}</button>
            <button class="btn ${danger ? 'btn-primary' : 'btn-primary'}" data-act="confirm"
                    style="${danger ? 'background:var(--danger);box-shadow:0 2px 8px rgba(245,54,92,0.25);' : ''}">
              ${escapeHtml(confirmText)}
            </button>
          </div>
        </div>
      `;
      document.body.appendChild(backdrop);

      let resolved = false;
      const close = (val) => {
        if (resolved) return;
        resolved = true;
        document.removeEventListener('keydown', escHandler);
        backdrop.classList.add('closing');
        setTimeout(() => { backdrop.remove(); resolve(val); }, 150);
      };
      const escHandler = (e) => { if (e.key === 'Escape') close(false); };
      document.addEventListener('keydown', escHandler);

      backdrop.addEventListener('click', (e) => {
        if (e.target === backdrop) return close(false);
        const act = e.target.dataset && e.target.dataset.act;
        if (act === 'confirm') close(true);
        if (act === 'cancel')  close(false);
      });
      setTimeout(() => {
        const cancelBtn = backdrop.querySelector('[data-act="cancel"]');
        if (cancelBtn) cancelBtn.focus();
      }, 50);
    });
  }

  function toggleDiag() {
    $('diagPanel').classList.toggle('open');
    if ($('diagPanel').classList.contains('open')) renderDiag();
  }
  function renderDiag() {
    const tab = document.querySelector('.diag-tab.active')?.dataset.tab || 'perf';
    const body = $('diagBody');
    if (!body) return;
    if (tab === 'perf') {
      const s = diag.steps;
      body.innerHTML = `
        <div class="row"><span class="label">Last load total</span><span class="value">${diag.lastSuccess?.duration ?? '—'} ms</span></div>
        <div class="row"><span class="label">Step 1 · Ping</span><span class="value">${s.ping || '—'} ms</span></div>
        <div class="row"><span class="label">Step 2 · Fetch</span><span class="value">${s.fetch || '—'} ms</span></div>
        <div class="row"><span class="label">Step 3 · Process</span><span class="value">${s.process || '—'} ms</span></div>
        <div class="row"><span class="label">Step 4 · Build</span><span class="value">${s.build || '—'} ms</span></div>
        <div class="row"><span class="label">Step 5 · Render</span><span class="value">${s.render || '—'} ms</span></div>
      `;
    } else if (tab === 'errors') {
      body.innerHTML = diag.errors.length === 0 ? '<div class="diag-empty">No errors recorded.</div>' : diag.errors.map(e => `
        <div class="diag-error-block"><strong>${escapeHtml(e.stage || '?')}</strong> · ${escapeHtml(e.when)}<br>${escapeHtml(e.message)}</div>
      `).join('');
    } else {
      body.innerHTML = `
        <div class="row"><span class="label">User</span><span class="value">${escapeHtml(diag.lastSuccess?.user || '—')}</span></div>
        <div class="row"><span class="label">Theme</span><span class="value">${document.documentElement.getAttribute('data-theme')}</span></div>
      `;
    }
  }
  document.querySelectorAll('.diag-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.diag-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      renderDiag();
    });
  });

  // ============================================================
  // DATA LOADING (PENDING CASES)
  // ============================================================
  document.addEventListener('DOMContentLoaded', () => {
    initTomSelects();
    loadCases();
  });

  function refreshCurrentTab() {
    if (currentTab === 'pending') {
      loadCases(true);
    } else {
      loadRcaAnalytics();
    }
  }

  function setConn(state, text) {
    $('connectionDot').className = `connection-dot ${state}`;
    $('connectionLabel').textContent = text;
  }
  function startStep(name) {
    const el = $(`step-${name}`);
    if (el) { el.classList.add('active'); el.dataset.t0 = performance.now(); }
  }
  function completeStep(name) {
    const el = $(`step-${name}`);
    if (!el) return;
    el.classList.replace('active', 'done');
    const ms = Math.round(performance.now() - parseFloat(el.dataset.t0 || performance.now()));
    diag.steps[name] = ms;
    const t = $(`time-${name}`);
    if (t) t.textContent = `${ms} ms`;
  }
  function failStep(name, err) {
    const el = $(`step-${name}`);
    if (el) el.classList.replace('active', 'error');
    console.error(err);
    showToast({ title: 'Error', description: err.message || err.toString(), type: 'error' });
  }

  function loadCases(silent = false) {
    const myToken = ++_currentLoadToken;
    diag.apiCalls++;
    setConn('busy', 'Syncing');

    if (!silent) {
      $('tableWrap').classList.add('hidden');
      $('emptyState').classList.add('hidden');
      $('loadingPanel').classList.remove('hidden');
      ['ping','fetch','process','build','render'].forEach(s => {
        const el = $(`step-${s}`);
        if(el) { el.className='step'; $(`time-${s}`).textContent=''; }
      });
      startStep('ping');
    }

    google.script.run
      .withSuccessHandler(pingRes => {
        if (myToken !== _currentLoadToken) return;
        if (!silent) completeStep('ping');
        $('topbarMeta').textContent = pingRes.user;
        
        if (!silent) startStep('fetch');
        google.script.run
          .withSuccessHandler(res => {
            if (myToken !== _currentLoadToken) return;
            handleCasesData(res, silent);
          })
          .withFailureHandler(err => {
            if (myToken !== _currentLoadToken) return;
            if (!silent) failStep('fetch', err);
            setConn('offline', 'Failed');
          })
          .getPendingCases();
      })
      .withFailureHandler(err => {
        if (myToken !== _currentLoadToken) return;
        if (!silent) failStep('ping', err);
        setConn('offline', 'Disconnected');
      })
      .ping();
  }

  function handleCasesData(res, silent) {
    if (!res.success) {
      if (!silent) failStep('fetch', res.error);
      setConn('offline', 'Error');
      return;
    }
    if (!silent) completeStep('fetch');

    globalCases = res.cases || [];
    caseIndexMap.clear();
    globalCases.forEach(c => caseIndexMap.set(c.caseId, c));

    if (!silent) startStep('process');
    filteredCases = [...globalCases];
    if (!silent) completeStep('process');

    if (!silent) startStep('build');
    buildDashboardAnalytics(res.analytics);
    if (!silent) completeStep('build');

    if (!silent) startStep('render');
    renderTable();
    if (!silent) {
      completeStep('render');
      setTimeout(() => {
        $('loadingPanel').classList.add('hidden');
        if (filteredCases.length === 0) {
          $('emptyState').classList.remove('hidden');
        } else {
          $('tableWrap').classList.remove('hidden');
          $('analyticsCard').style.display = 'block';
        }
      }, 300);
    }
    setConn('online', 'Live');
    diag.lastSuccess = { duration: res.duration, user: $('topbarMeta').textContent };
  }

  function buildDashboardAnalytics(a) {
    if (!a) return;
    $('dashboardSubtitle').textContent = `${a.total} pending · ${a.proactive} proactive · ${a.lockedByOthers} locked`;

    // Simple cards
    $('kpiGrid').innerHTML = `
      <div class="kpi-card kpi-info">
        <div class="kpi-label">Retail / Business</div>
        <div class="kpi-value">${a.retail} / ${a.business}</div>
      </div>
      <div class="kpi-card kpi-critical">
        <div class="kpi-label">Critical Defects</div>
        <div class="kpi-value">${a.criticalDefects}</div>
        <div class="kpi-sub">Needs immediate RCA</div>
      </div>
      <div class="kpi-card kpi-warn">
        <div class="kpi-label">SLA Breached (>5d)</div>
        <div class="kpi-value">${a.slaBreached}</div>
      </div>
    `;

    const renderBars = (obj) => {
      const max = Math.max(...Object.values(obj), 1);
      return Object.entries(obj)
        .sort((a,b) => b[1]-a[1]).slice(0,5)
        .map(([k,v]) => `
          <div class="bar-row">
            <div class="bar-label" title="${escapeHtml(k)}">${escapeHtml(k)}</div>
            <div class="bar-track"><div class="bar-fill" style="width:${(v/max)*100}%"></div></div>
            <div class="bar-value">${v}</div>
          </div>
        `).join('');
    };
    $('defectBreakdown').innerHTML = renderBars(a.defects);
    $('teamBreakdown').innerHTML = renderBars(a.teams);
  }

  function renderTable() {
    const tbody = $('casesBody');
    tbody.innerHTML = '';
    
    if (filteredCases.length === 0) {
      $('tableWrap').classList.add('hidden');
      $('emptyState').classList.remove('hidden');
      return;
    }
    $('tableWrap').classList.remove('hidden');
    $('emptyState').classList.add('hidden');

    const start = (currentPage - 1) * pageSize;
    const slice = filteredCases.slice(start, start + pageSize);

    slice.forEach(c => {
      const tr = document.createElement('tr');
      const isMe = c.isLockedByMe;
      const isOther = c.lockedBy && !isMe;
      
      let lockHtml = '';
      if (isMe) lockHtml = `<div class="lock-pill lock-pill-mine">🔒 Me</div>`;
      else if (isOther) lockHtml = `<div class="lock-pill lock-pill-other">🔒 ${escapeHtml(c.lockedBy.split('@')[0])}</div>`;
      
      let defClass = 'badge-minor';
      if (c.defect === 'Outcome' || c.defect === 'Critical') defClass = 'badge-fail';
      else if (c.defect === 'Major') defClass = 'badge-major';

      let prodClass = c.product === 'BUSINESS' ? 'badge-business' : 'badge-retail';

      tr.innerHTML = `
        <td>
          <button class="btn btn-primary btn-sm" onclick="investigateCase('${c.caseId}')" ${isOther ? 'disabled' : ''}>
            ${isMe ? 'Resume' : 'Start RCA'}
          </button>
          ${lockHtml}
        </td>
        <td><span class="badge ${defClass}">${escapeHtml(c.defect)}</span></td>
        <td><span class="badge ${prodClass}">${escapeHtml(c.product)}</span></td>
        <td>${escapeHtml(c.taskType)}</td>
        <td class="table-cell-trunc" title="${escapeHtml(c.entityName)}">${escapeHtml(c.entityName)}</td>
        <td>${escapeHtml(c.agency)}</td>
        <td>${escapeHtml(c.productionLine)}</td>
        <td>${escapeHtml(c.team)}</td>
        <td>${escapeHtml(c.analyst)}</td>
        <td>${c.proactive === 'Yes' ? '<span class="status-dot status-dot-warn">Proactive</span>' : '<span class="status-dot status-dot-success">Reactive</span>'}</td>
        <td style="white-space:nowrap;">${escapeHtml(c.reviewDoneDate)}</td>
        <td style="white-space:nowrap;">${escapeHtml(c.workDoneDate)}</td>
        <td class="table-cell-trunc" title="${escapeHtml(c.hashtags.join(' '))}">${escapeHtml(c.hashtags.join(' '))}</td>
      `;
      tbody.appendChild(tr);
    });

    // Pagination
    const totalPages = Math.ceil(filteredCases.length / pageSize);
    $('paginationInfo').textContent = `Showing ${start + 1}-${Math.min(start + pageSize, filteredCases.length)} of ${filteredCases.length}`;
    
    let btns = '';
    btnClass = (p) => `class="${p === currentPage ? 'active' : ''}" onclick="goToPage(${p})"`;
    if (currentPage > 1) btns += `<button onclick="goToPage(${currentPage-1})">«</button>`;
    
    let pStart = Math.max(1, currentPage - 2);
    let pEnd = Math.min(totalPages, currentPage + 2);
    for (let i = pStart; i <= pEnd; i++) btns += `<button ${btnClass(i)}>${i}</button>`;
    
    if (currentPage < totalPages) btns += `<button onclick="goToPage(${currentPage+1})">»</button>`;
    $('paginationControls').innerHTML = btns;
  }

  function goToPage(p) { currentPage = p; renderTable(); }
  function changePageSize() { pageSize = parseInt($('pageSizeSelect').value, 10); currentPage = 1; renderTable(); }

  // ============================================================
  // START RCA (Lock & Load Form)
  // ============================================================
  async function investigateCase(caseId) {
    const c = caseIndexMap.get(caseId);
    if (!c) return showToast({ title: 'Case not found', type: 'error' });

    setConn('busy', 'Locking...');
    try {
      const res = await new Promise((resolve, reject) => {
        google.script.run.withSuccessHandler(resolve).withFailureHandler(reject).lockCase(caseId);
      });
      if (!res.success) {
        setConn('online', 'Live');
        showModal({ title: 'Case Locked', description: `This case is currently locked by ${res.lockedBy}.`});
        loadCases(true); // Refresh
        return;
      }
      currentCaseId = caseId;
      populateRcaForm(c);
      showForm();
      
      _lockRefreshTimer = setInterval(() => {
        if (currentCaseId) google.script.run.refreshLock(currentCaseId);
      }, 10 * 60 * 1000); // refresh lock every 10m
      
      setConn('online', 'Live');
    } catch (e) {
      setConn('offline', 'Error');
      showToast({ title: 'Failed to lock case', description: e.message, type: 'error' });
    }
  }

  function populateRcaForm(c) {
    $('rcaForm').reset();
    Object.keys(tomSelectInstances).forEach(k => tomSelectInstances[k].clear());
    $('auQuestionsContainer').innerHTML = '';
    
    // Header & Meta
    $('formSubtitle').textContent = `Analyst: ${c.analyst} · Defect: ${c.defect} · Team: ${c.team}`;
    $('caseIdField').value = c.caseId;
    $('productField').value = c.product;
    $('qcComment').textContent = c.details;

    // Links
    if (c.qcLink) { $('btnQcLink').href = c.qcLink; $('btnQcLink').classList.remove('hidden'); } else { $('btnQcLink').classList.add('hidden'); }
    if (c.boLink) { $('btnBoLink').href = c.boLink; $('btnBoLink').classList.remove('hidden'); } else { $('btnBoLink').classList.add('hidden'); }

    // Hidden payload fields
    $('rowNum').value = c.rowNum;
    $('qcName').value = c.qcName;
    $('reviewDoneDate').value = c.reviewDoneDate;
    $('workDoneDate').value = c.workDoneDate;
    $('reviewResult').value = c.reviewResult;
    $('taskType').value = c.taskType;
    $('entityName').value = c.entityName;
    $('agency').value = c.agency;
    $('team').value = c.team;
    $('analyst').value = c.analyst;
    $('proactive').value = c.proactive;
    $('outcomeDefect').value = c.defect;
    $('qcKeywords').value = c.hashtags.join(', ');
    
    $('h_lob').value = c.lob;
    $('h_empEmail').value = c.empEmail;
    $('h_entityRegion').value = c.entityRegion;
    $('h_batchId').value = c.batchId;
    $('h_lmEmail').value = c.lmEmail;
    $('h_recs').value = c.recs;
    $('h_boLink').value = c.boLink;
    $('h_qcLink').value = c.qcLink;
    $('h_appealOutcome').value = c.appealOutcome;
    $('h_entityRegionGrouped').value = c.entityRegionGrouped;
    $('h_isProbation').value = c.isProbation;
    $('h_remediationRequired').value = c.remediationRequired;
    $('h_wasAppealed').value = c.wasAppealed;

    // Restore Draft logic (omitted for brevity, assume simple form reset for now)
    
    // Ensure conditional fields are hidden
    document.querySelectorAll('.sub-group').forEach(g => {
      if (g.id !== 'auQuestionsContainer' && g.id !== 'rcaLogicGroup') g.classList.add('hidden');
    });
    $('rcaLogicGroup').classList.add('hidden');
  }

  function initTomSelects() {
    document.querySelectorAll('.main-select').forEach(el => {
      tomSelectInstances[el.id] = new TomSelect(el, {
        create: el.id === 'prevNote' || el.id === 'escalation' || el.id === 'tag' || el.id === 'typology',
