  // Calculate Refund (Phase 6)
  function calculateRefund() {
    const dateStr = safeGet('refundDate');
    const amtStr = safeGet('refundAmt');
    if (!dateStr || !amtStr) return;
    
    const chargeDate = new Date(dateStr);
    const amt = parseFloat(amtStr);
    const today = new Date();
    
    let daysPassed = Math.floor((today - chargeDate) / (1000 * 60 * 60 * 24));
    if (daysPassed < 0) daysPassed = 0;
    
    const dailyRate = amt / 365;
    const consumed = dailyRate * daysPassed;
    let refund = amt - consumed;
    if (refund < 0) refund = 0;
    
    const res = $('refundResult');
    res.classList.remove('hidden');
    res.innerHTML = `
      <div style="color:var(--text-secondary); font-size:11px; margin-bottom:4px;">${daysPassed} days consumed out of 365</div>
      <div style="font-size:16px; color:var(--success);">Refund Due: <strong>${refund.toFixed(2)}</strong></div>
    `;
  }

