            callbacks: {
              label: function(ctx) {
                const d = ctx.raw;
                return `${d.label}: Score ${d.y}, Cycle ${d.x}d`;
              }
            }
          }
        },
        scales: {
          x: { title: { display: true, text: 'Avg Cycle Time (Days)', color: textColor }, ticks: { color: textColor }, grid: { color: gridColor } },
          y: { title: { display: true, text: 'Avg Defect Score', color: textColor }, ticks: { color: textColor }, grid: { color: gridColor } }
        }
      }
    });

    // 10. Phase Heatmap (Multi-Line/Bar)
    const hmLabels = a.phaseHeatmap.map(x => x.month);
    const p2Data = a.phaseHeatmap.map(x => x.p2);
    const p3Data = a.phaseHeatmap.map(x => x.p3);
    const p5Data = a.phaseHeatmap.map(x => x.p5);

    phaseHeatmapChartObj = new Chart($('phaseHeatmapChart'), {
      type: 'bar',
      data: {
        labels: hmLabels,
        datasets: [
          { label: 'P2 Fail %', data: p2Data, backgroundColor: '#5B8DEF' },
          { label: 'P3 Fail %', data: p3Data, backgroundColor: '#FFA800' },
          { label: 'P5 Fail %', data: p5Data, backgroundColor: '#F5365C' }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          x: { stacked: true, ticks: { color: textColor }, grid: { display: false } },
          y: { stacked: true, title: { display: true, text: 'Failure Rate %' }, ticks: { color: textColor }, grid: { color: gridColor } }
        }
      }
    });
  }

  // ============================================================
  // DRILL-DOWN TABLE (RCA Analytics View)
  // ============================================================
  function fetchRcaTableRows(filters, page) {
    rcaCurrentPage = page;
    $('rcaPaginationInfo').textContent = 'Loading...';
    
    google.script.run
      .withSuccessHandler(res => {
        if(!res.success) return;
        renderRcaTableRows(res);
      })
      .getRcaResultsTable(filters, page, rcaPageSize);
  }

  function renderRcaTableRows(res) {
    const tbody = $('rcaTableBody');
    tbody.innerHTML = '';
    
    res.rows.forEach(r => {
      const tr = document.createElement('tr');
      
      let defPill = `defect-pill-${r.defect}`;
      let flags = '';
      if(r.flagToTL) flags += `<span class="action-pill active flag">TL</span>`;
      if(r.toBeAppealed) flags += `<span class="action-pill active appeal">APP</span>`;
      if(r.failAccepted) flags += `<span class="action-pill active accepted">ACC</span>`;

      let links = '';
      if(r.boLink) links += `<a href="${r.boLink}" target="_blank" class="text-link" title="BO">BO</a> `;
      if(r.qcLink) links += `<a href="${r.qcLink}" target="_blank" class="text-link" title="QC">QC</a>`;

      tr.innerHTML = `
        <td style="white-space:nowrap">${r.timestamp}</td>
        <td>${escapeHtml(r.caseId.substring(0,8))}...</td>
        <td><span class="defect-pill ${defPill}">${escapeHtml(r.defect)}</span></td>
        <td>${escapeHtml(r.product)}</td>
        <td>${escapeHtml(r.analyst.split('@')[0])}</td>
        <td>${escapeHtml(r.qcReviewer.split('@')[0])}</td>
        <td>${escapeHtml(r.errorSource)}</td>
        <td><b>${r.binaryDefectScore}</b></td>
        <td>${flags}</td>
        <td>${links}</td>
        <td>${r.cycleWorkToQc} / ${r.cycleQcToRca}</td>
        <td class="table-cell-trunc" title="${escapeHtml(r.comments)}">${escapeHtml(r.comments)}</td>
        <td class="table-cell-trunc" title="${escapeHtml(r.sysFailTxt)}">${escapeHtml(r.sysFailTxt)}</td>
        <td class="table-cell-trunc" title="${escapeHtml(r.suggestedUpdate)}">${escapeHtml(r.suggestedUpdate)}</td>
      `;
      tbody.appendChild(tr);
    });

    // Pagination
    const totalPages = Math.ceil(res.total / rcaPageSize);
    const start = (rcaCurrentPage - 1) * rcaPageSize;
    $('rcaTableCount').textContent = res.total;
    $('rcaPaginationInfo').textContent = `Showing ${start + 1}-${Math.min(start + rcaPageSize, res.total)} of ${res.total}`;
    
    let btns = '';
    btnClass = (p) => `class="${p === rcaCurrentPage ? 'active' : ''}" onclick="changeRcaPage(${p})"`;
    if (rcaCurrentPage > 1) btns += `<button onclick="changeRcaPage(${rcaCurrentPage-1})">«</button>`;
    
    let pStart = Math.max(1, rcaCurrentPage - 2);
    let pEnd = Math.min(totalPages, rcaCurrentPage + 2);
    for (let i = pStart; i <= pEnd; i++) btns += `<button ${btnClass(i)}>${i}</button>`;
    
    if (rcaCurrentPage < totalPages) btns += `<button onclick="changeRcaPage(${rcaCurrentPage+1})">»</button>`;
    $('rcaPaginationControls').innerHTML = btns;
  }

  function changeRcaPage(p) {
    const filters = {
      dateField: safeGet('rcaFilterDateField'),
      dateFrom: safeGet('rcaFilterFrom'),
      dateTo: safeGet('rcaFilterTo'),
      search: safeGet('rcaFilterSearch'),
      conductor: safeGet('rcaFilterConductor'),
      qcReviewer: safeGet('rcaFilterQcReviewer'),
      analyst: safeGet('rcaFilterAnalyst'),
      team: safeGet('rcaFilterTeam'),
      agency: safeGet('rcaFilterAgency'),
      product: safeGet('rcaFilterProduct'),
      country: safeGet('rcaFilterCountry'),
      authority: safeGet('rcaFilterAuthority'),
      origin: safeGet('rcaFilterOrigin'),
      taskType: safeGet('rcaFilterTaskType'),
      errorSource: safeGet('rcaFilterErrorSource'),
      rcaAgree: safeGet('rcaFilterQcAgree'),
      typology: safeGet('rcaFilterTypology'),
      tag: safeGet('rcaFilterTag'),
      flagToTL: safeGet('rcaFilterFlagToTL'),
      toBeAppealed: safeGet('rcaFilterToBeAppealed'),
      failAccepted: safeGet('rcaFilterFailAccepted')
    };
    fetchRcaTableRows(filters, p);
  }

  // Export
  function exportRcaCsv() {
    setConn('busy', 'Generating CSV...');
    const filters = {
      dateField: safeGet('rcaFilterDateField'),
      dateFrom: safeGet('rcaFilterFrom'),
      dateTo: safeGet('rcaFilterTo'),
      search: safeGet('rcaFilterSearch')
      // ... expand if needed
    };
    google.script.run
      .withSuccessHandler(res => {
        setConn('online', 'Live');
        if(!res.success) return showToast({title:'Export Failed', description:res.error, type:'error'});
        
        const blob = new Blob([res.csv], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.setAttribute("href", url);
        link.setAttribute("download", `RCA_Export_${new Date().toISOString().slice(0,10)}.csv`);
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      })
      .exportRcaToCsv(filters);
  }
</script>
