        <div id="successMsg" class="hidden success-screen"><div class="success-icon">&#10003;</div><h2 class="card-title">RCA Submitted</h2><p class="text-muted mb-3">The case has been logged to the spreadsheet successfully.</p><button class="btn btn-primary" onclick="window.returnToQueue &amp;&amp; window.returnToQueue()">Return to Queue</button></div>
      </div>
    </div>
  </div>

  <div id="rcaAnalyticsView" class="hidden"><?!= include("Analytics"); ?></div>
</div>

<script>
window.actionCart = window.actionCart || [];
window.addEventListener('error', function(e){ try{ console.error('ERR:', e.message); }catch(_){} });
var $ = function(id){ return document.getElementById(id); };
function escapeHtml(s){ if(s==null) return ''; return String(s).replace(/[&<>"']/g, function(m){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]; }); }
function safeGet(id){ var el=$(id); return el?el.value:''; }
function safeGetChecked(id){ var el=$(id); return el?!!el.checked:false; }
function getMultiSelectValues(id){ var el=$(id); if(!el) return []; if(window.tomSelectInstances && window.tomSelectInstances[id]) { var vals = window.tomSelectInstances[id].getValue(); return Array.isArray(vals) ? vals : [vals]; } return Array.prototype.slice.call(el.selectedOptions||[]).map(function(o){return o.value;}).filter(Boolean); }
window.$=$; window.escapeHtml=escapeHtml; window.safeGet=safeGet; window.safeGetChecked=safeGetChecked; window.getMultiSelectValues=getMultiSelectValues;

var globalCases=[], caseIndexMap=new Map(), currentCaseId=null, tomSelectInstances={}, _lockRefreshTimer=null, _currentLoadToken=0, currentPage=1, pageSize=50, filteredCases=[], currentTab='pending';
var diag={ startedAt:null, steps:{ping:0,fetch:0,process:0,build:0,render:0}, lastSuccess:null, lastError:null, history:[], errors:[] };

function toggleTheme(){ try{ var cur=document.documentElement.getAttribute('data-theme'); var next=cur==='dark'?'light':'dark'; document.documentElement.setAttribute('data-theme',next); var icon=$('themeIcon'); if(icon) icon.textContent=next==='dark'?'\u2600':'\uD83C\uDF19'; try{localStorage.setItem('theme',next);}catch(_){} }catch(e){} }
(function restoreTheme(){ try{ var saved=localStorage.getItem('theme'); if(saved){ document.documentElement.setAttribute('data-theme',saved); var icon=$('themeIcon'); if(icon) icon.textContent=saved==='dark'?'\u2600':'\uD83C\uDF19'; } }catch(_){} })();
window.toggleTheme=toggleTheme;

function switchTab(tabId){
  try {
    currentTab = tabId; document.querySelectorAll('.analytics-tab').forEach(function(t){ t.classList.remove('active'); });
    var d=$('dashboardView'), f=$('formView'), a=$('rcaAnalyticsView'); [d,f,a].forEach(function(v){ if(v) v.classList.remove('show-view'); }); document.body.classList.remove('form-open');
    if (tabId === 'pending') { var tp = $('tabPending'); if(tp) tp.classList.add('active'); if(d) d.classList.add('show-view'); startPendingPoller(); } 
    else if (tabId === 'analytics') { var ta = $('tabRcaAnalytics'); if(ta) ta.classList.add('active'); if(a) a.classList.add('show-view'); stopPendingPoller(); if (typeof window.loadRcaAnalytics === 'function') window.loadRcaAnalytics(); if (typeof window.__rcaResizeCharts === 'function') setTimeout(window.__rcaResizeCharts, 80); }
  } catch(e) { console.error('switchTab:', e); }
}
function startPendingPoller(){ stopPendingPoller(); window._pendingPoller = setInterval(function(){ if (currentTab === 'pending' && !document.hidden) loadCases(true); }, 30000); }
function stopPendingPoller(){ if (window._pendingPoller) { clearInterval(window._pendingPoller); window._pendingPoller = null; } }
function showForm(){ try{ var d=$('dashboardView'), f=$('formView'), a=$('rcaAnalyticsView'); if(d) d.classList.remove('show-view'); if(a) a.classList.remove('show-view'); if(f) f.classList.add('show-view'); document.body.classList.add('form-open'); window.scrollTo(0,0); }catch(e){} }
function returnToQueue(){ try{ if(currentCaseId){ google.script.run.unlockCase(currentCaseId); currentCaseId=null; } if(_lockRefreshTimer){ clearInterval(_lockRefreshTimer); _lockRefreshTimer=null; } var f=$('formView'), d=$('dashboardView'); if(f) f.classList.remove('show-view'); if(d) d.classList.add('show-view'); document.body.classList.remove('form-open'); loadCases(true); }catch(e){} }
window.switchTab=switchTab; window.showForm=showForm; window.returnToQueue=returnToQueue;

function showToast(o){ try{ o=o||{}; var c=$('toastContainer'); if(!c) return; var t=document.createElement('div'); t.className='toast toast-'+(o.type||'info'); var html='<div style="flex:1;"><div class="toast-title">'+escapeHtml(o.title||'')+'</div>'+(o.description?'<div class="toast-desc">'+escapeHtml(o.description)+'</div>':'')+'</div><button class="btn btn-ghost btn-sm" onclick="this.parentElement.remove()">&times;</button>'; t.innerHTML=html; c.appendChild(t); setTimeout(function(){try{t.remove();}catch(_){}}, o.duration||4000); }catch(e){} }
function showModal(o){ return new Promise(function(resolve){ try{ o=o||{}; var b=document.createElement('div'); b.className='modal-backdrop'; b.innerHTML='<div class="modal"><h3 class="modal-title">'+escapeHtml(o.title||'')+'</h3><p class="modal-desc">'+escapeHtml(o.description||'')+'</p><div class="modal-actions"><button class="btn btn-secondary" data-act="cancel">'+escapeHtml(o.cancelText||'Cancel')+'</button><button class="btn btn-primary" data-act="confirm">'+escapeHtml(o.confirmText||'Confirm')+'</button></div></div>'; document.body.appendChild(b); var done=false; function close(v){ if(done) return; done=true; try{b.remove();}catch(_){} resolve(v); } b.addEventListener('click',function(e){ var a=e.target&&e.target.dataset&&e.target.dataset.act; if(a==='confirm') close(true); else if(a==='cancel') close(false); else if(e.target===b) close(false); }); }catch(e){ resolve(false); } }); }
function toggleDiag(){ try{ var p=$('diagPanel'); if(p){ p.classList.toggle('open'); if(p.classList.contains('open')&&typeof window.renderDiag==='function') window.renderDiag(); } }catch(e){} }
function renderDiag(){ try{ var body=$('diagBody'); if(!body) return; var active=document.querySelector('.diag-tab.active'); var tab=active?active.getAttribute('data-tab'):'perf'; var s=diag.steps||{}; var html=''; if(tab==='perf'){ html='<div class="row"><span class="label">Last load</span><span class="value">'+(diag.lastSuccess&&diag.lastSuccess.duration!=null?diag.lastSuccess.duration:'-')+' ms</span></div><div class="row"><span class="label">Ping</span><span class="value">'+(s.ping||'-')+' ms</span></div><div class="row"><span class="label">Fetch</span><span class="value">'+(s.fetch||'-')+' ms</span></div><div class="row"><span class="label">Process</span><span class="value">'+(s.process||'-')+' ms</span></div><div class="row"><span class="label">Build</span><span class="value">'+(s.build||'-')+' ms</span></div><div class="row"><span class="label">Render</span><span class="value">'+(s.render||'-')+' ms</span></div>'; } else if(tab==='errors'){ html=(!diag.errors||!diag.errors.length)?'<div class="diag-empty">No errors</div>':diag.errors.map(function(e){return '<div class="diag-error-block"><strong>'+escapeHtml(e.stage||'?')+'</strong> '+escapeHtml(e.when||'')+'<br>'+escapeHtml(e.message||'')+'</div>';}).join(''); } else { html='<div class="row"><span class="label">User</span><span class="value">'+escapeHtml((diag.lastSuccess&&diag.lastSuccess.user)||'-')+'</span></div><div class="row"><span class="label">Theme</span><span class="value">'+escapeHtml(document.documentElement.getAttribute('data-theme')||'-')+'</span></div>'; } body.innerHTML=html; }catch(e){} }
function copyDiagnostics(){ try{ if(navigator.clipboard) navigator.clipboard.writeText(JSON.stringify(diag,null,2)); showToast({title:'Copied',type:'success'}); }catch(e){ showToast({title:'Copy failed',description:e.message,type:'error'}); } }
function clearDiagnostics(){ diag.history=[]; diag.errors=[]; diag.steps={ping:0,fetch:0,process:0,build:0,render:0}; diag.lastSuccess=null; renderDiag(); }
window.toggleDiag=toggleDiag; window.renderDiag=renderDiag; window.copyDiagnostics=copyDiagnostics; window.clearDiagnostics=clearDiagnostics;

function setConn(state,text){ var d=$('connectionDot'), l=$('connectionLabel'); if(d) d.className='connection-dot '+state; if(l) l.textContent=text; }
function startStep(n){ var el=$('step-'+n); if(el){ el.classList.add('active'); el.dataset.t0=String(performance.now()); } }
function completeStep(n){ var el=$('step-'+n); if(!el) return; el.classList.replace('active','done'); var ms=Math.round(performance.now()-parseFloat(el.dataset.t0||performance.now())); diag.steps[n]=ms; var t=$('time-'+n); if(t) t.textContent=ms+' ms'; }
function failStep(n,err){ var el=$('step-'+n); if(el) el.classList.replace('active','error'); var msg=(err&&err.message)?err.message:String(err); diag.errors.push({stage:n,when:new Date().toISOString(),message:msg}); showToast({title:'Error',description:msg,type:'error'}); }

function loadCases(silent){ if(silent===undefined) silent=false; var myToken=++_currentLoadToken; setConn('busy','Syncing'); if(!silent){ var tw=$('tableWrap'); if(tw) tw.classList.add('hidden'); var es=$('emptyState'); if(es) es.classList.add('hidden'); var lp=$('loadingPanel'); if(lp) lp.classList.remove('hidden'); ['ping','fetch','process','build','render'].forEach(function(s){ var el=$('step-'+s); if(el) el.className='step'; var t=$('time-'+s); if(t) t.textContent=''; }); startStep('ping'); } google.script.run.withSuccessHandler(function(p){ if(myToken!==_currentLoadToken) return; if(!silent) completeStep('ping'); var tm=$('topbarMeta'); if(tm) tm.textContent=p.user; if(!silent) startStep('fetch'); google.script.run.withSuccessHandler(function(r){ if(myToken!==_currentLoadToken) return; handleCasesData(r,silent); }).withFailureHandler(function(e){ if(myToken!==_currentLoadToken) return; if(!silent) failStep('fetch',e); setConn('offline','Failed'); }).getPendingCases(); }).withFailureHandler(function(e){ if(myToken!==_currentLoadToken) return; if(!silent) failStep('ping',e); setConn('offline','Disconnected'); }).ping(); }
function handleCasesData(res, silent){
  if(!res || !res.success){ return; }
  if(!silent) completeStep('fetch');
  globalCases = res.cases || []; caseIndexMap.clear(); globalCases.forEach(function(c){ caseIndexMap.set(c.caseId, c); });
  Object.keys(columnFilters).forEach(function(k){ var val = columnFilters[k]; if(!val) return; var exists = globalCases.some(function(r){ var cell = (k === 'keywords') ? (r.hashtags || []).join(' ') : String(r[k] || ''); return cell === val; }); if(!exists) delete columnFilters[k]; });
  if(!silent) startStep('process'); filteredCases = globalCases.slice(); if(!silent) completeStep('process');
  if(!silent) startStep('build'); buildDashboardAnalytics(res.analytics); if(!silent) completeStep('build');
  if(!silent) startStep('render'); onFiltersChanged(); 
  if(!silent){ completeStep('render'); setTimeout(function(){ var lp = $('loadingPanel'); if(lp) lp.classList.add('hidden'); if(filteredCases.length === 0){ var es = $('emptyState'); if(es) es.classList.remove('hidden'); } else { var tw = $('tableWrap'); if(tw) tw.classList.remove('hidden'); var ac = $('analyticsCard'); if(ac) ac.style.display = 'block'; } }, 300); }
  setConn('online', 'Live'); diag.lastSuccess = { duration: (res.duration || 0), user: (($('topbarMeta') && $('topbarMeta').textContent) || '') };
}
function buildDashboardAnalytics(a) {
  if (!a) return; var sub = $('dashboardSubtitle'); if (sub) { sub.textContent = (a.total || 0) + ' pending - ' + (a.proactive || 0) + ' proactive - ' + (a.lockedByOthers || 0) + ' locked'; }
  var kg = $('kpiGrid'); if (!kg) return; var appealUrl = a.appealTrackerUrl || '#'; var hasAppeals = (a.appealsPending || 0) > 0;
  kg.innerHTML = '<a href="' + escapeHtml(appealUrl) + '" target="_blank" rel="noopener" class="kpi-card kpi-appeal" title="Open the Appeals tracker"><div class="kpi-label">&#9878;&#65039; Appeals Pending</div><div class="kpi-value">' + (a.appealsPending || 0) + '</div><div class="kpi-sub">' + (hasAppeals ? 'Click to open tracker' : 'No appeals') + '</div><div class="kpi-link">Open tracker</div></a>' + '<div class="kpi-card kpi-info"><div class="kpi-label">Retail / Business</div><div class="kpi-value">' + (a.retail || 0) + ' / ' + (a.business || 0) + '</div></div>' + '<div class="kpi-card kpi-critical"><div class="kpi-label">Critical Defects</div><div class="kpi-value">' + (a.criticalDefects || 0) + '</div><div class="kpi-sub">Needs immediate RCA</div></div>' + '<div class="kpi-card kpi-warn"><div class="kpi-label">SLA Breached (&gt;5d)</div><div class="kpi-value">' + (a.slaBreached || 0) + '</div></div>';
  function renderBars(obj) { var ks = Object.keys(obj || {}); if (!ks.length) return '<div class="diag-empty">No data</div>'; var max = Math.max.apply(null, ks.map(function(k) { return obj[k]; }).concat([1])); return ks.sort(function(x, y) { return obj[y] - obj[x]; }).slice(0, 5).map(function(k) { return '<div class="bar-row"><div class="bar-label" title="' + escapeHtml(k) + '">' + escapeHtml(k) + '</div><div class="bar-track"><div class="bar-fill" style="width:' + ((obj[k] / max) * 100) + '%"></div></div><div class="bar-value">' + obj[k] + '</div></div>'; }).join(''); }
  var db = $('defectBreakdown'); if (db) db.innerHTML = renderBars(a.defects); var tb = $('teamBreakdown'); if (tb) tb.innerHTML = renderBars(a.teams);
}

var columnFilters = {};
var DASHBOARD_COLUMNS = [ { key:'action', label:'Action', sortable:false, filterable:false }, { key:'defect', label:'Defect', filterable:true }, { key:'product', label:'Product', filterable:true }, { key:'taskType', label:'Task', filterable:true }, { key:'agency', label:'Agency', filterable:true }, { key:'productionLine', label:'Line', filterable:true }, { key:'team', label:'Team', filterable:true }, { key:'analyst', label:'Analyst', filterable:true }, { key:'proactive', label:'Proactive', filterable:true }, { key:'reviewDate', label:'Review', filterable:true }, { key:'workDate', label:'Work', filterable:true }, { key:'keywords', label:'Keywords', filterable:true } ];

function renderTableHeaders(){ var head = $('dashboardTableHead'); if(!head) return; head.innerHTML = DASHBOARD_COLUMNS.map(function(col){ var isFiltered = columnFilters[col.key] != null && columnFilters[col.key] !== ''; var btn = col.filterable ? '<button class="th-filter-btn '+(isFiltered?'active':'')+'" data-col="'+col.key+'" type="button">&#9660;</button>' : ''; return '<th data-col="'+col.key+'"><div class="th-inner"><span class="th-label">'+escapeHtml(col.label)+'</span>'+btn+'</div></th>'; }).join(''); attachFilterButtonHandlers(); }
function attachFilterButtonHandlers(){ document.querySelectorAll('.th-filter-btn').forEach(function(btn){ btn.addEventListener('click', function(e){ e.stopPropagation(); openColumnFilter(btn.dataset.col, btn); }); }); }
function openColumnFilter(col, btn){
  document.querySelectorAll('.th-filter-dropdown.open').forEach(function(d){ if(d.dataset.col !== col) d.classList.remove('open'); });
  var th = btn.closest('th'); var dropdown = th.querySelector('.th-filter-dropdown');
  if(!dropdown){ dropdown = document.createElement('div'); dropdown.className = 'th-filter-dropdown'; dropdown.dataset.col = col; dropdown.innerHTML = '<input class="th-filter-search" placeholder="Search values..."><div class="th-filter-options"></div><button class="th-filter-clear-btn" type="button">Clear filter</button>'; th.appendChild(dropdown); if (!window._closeOnOutsideBound) { document.addEventListener('click', closeOnOutside); window._closeOnOutsideBound = true; } dropdown.querySelector('.th-filter-search').addEventListener('input', function(e){ var q = e.target.value.toLowerCase(); dropdown.querySelectorAll('.th-filter-option').forEach(function(opt){ opt.style.display = (opt.dataset.value || '').toLowerCase().indexOf(q) > -1 ? '' : 'none'; }); }); dropdown.querySelector('.th-filter-clear-btn').addEventListener('click', function(){ delete columnFilters[col]; onFiltersChanged(); dropdown.classList.remove('open'); }); }
  var sourceRows = applyFiltersExcluding(col); var values = new Set(); sourceRows.forEach(function(row){ var v = (col === 'keywords') ? (row.hashtags || []).join(' ') : String(row[col] || '').trim(); if(v) values.add(v); });
  var sorted = Array.from(values).sort(function(a,b){ return a.localeCompare(b); });
  var optContainer = dropdown.querySelector('.th-filter-options'); optContainer.innerHTML = sorted.length ? sorted.map(function(v){ var isSel = columnFilters[col] === v; return '<div class="th-filter-option '+(isSel?'selected':'')+'" data-value="'+escapeHtml(v)+'">'+escapeHtml(v)+'</div>'; }).join('') : '<div class="th-filter-empty">No values</div>';
  optContainer.querySelectorAll('.th-filter-option').forEach(function(opt){ opt.addEventListener('click', function(){ columnFilters[col] = opt.dataset.value; currentPage = 1; onFiltersChanged(); document.querySelectorAll('.th-filter-dropdown.open').forEach(function(d){ d.classList.remove('open'); }); }); });
  dropdown.querySelector('.th-filter-search').value = ''; dropdown.classList.toggle('open');
}
function closeOnOutside(e){ if(e.target.closest('.th-filter-dropdown') || e.target.closest('.th-filter-btn')) return; document.querySelectorAll('.th-filter-dropdown.open').forEach(function(d){ d.classList.remove('open'); }); }
function applyColumnFilters(){ var keys = Object.keys(columnFilters).filter(function(k){ return columnFilters[k] != null && columnFilters[k] !== ''; }); if(!keys.length) return globalCases.slice(); return globalCases.filter(function(row){ return keys.every(function(k){ var cell = (k === 'keywords') ? (row.hashtags || []).join(' ') : String(row[k] || ''); return cell === columnFilters[k]; }); }); }
function applyFiltersExcluding(excludeCol){ var keys = Object.keys(columnFilters).filter(function(k){ if(k === excludeCol) return false; return columnFilters[k] != null && columnFilters[k] !== ''; }); if(!keys.length) return globalCases.slice(); return globalCases.filter(function(row){ return keys.every(function(k){ var cell = (k === 'keywords') ? (row.hashtags || []).join(' ') : String(row[k] || ''); return cell === columnFilters[k]; }); }); }
function clearAllColumnFilters(){ columnFilters = {}; currentPage = 1; onFiltersChanged(); }
window.clearAllColumnFilters = clearAllColumnFilters;
function onFiltersChanged(){ renderTableHeaders(); renderTable(); }
function renderTable(){
  var tbody = $('casesBody'); if(!tbody) return; filteredCases = applyColumnFilters(); tbody.innerHTML = '';
  if(!filteredCases.length){ var tw = $('tableWrap'); if(tw) tw.classList.add('hidden'); var es = $('emptyState'); if(es) es.classList.remove('hidden'); return; }
  var tw2 = $('tableWrap'); if(tw2) tw2.classList.remove('hidden'); var es2 = $('emptyState'); if(es2) es2.classList.add('hidden');
  var start = (currentPage - 1) * pageSize; var slice = filteredCases.slice(start, start + pageSize);
  slice.forEach(function(c){
    var tr = document.createElement('tr'); var isMe = c.isLockedByMe; var isOther = c.lockedBy && !isMe;
    var lockBadge = isMe ? '<span class="lock-pill lock-pill-mine" style="margin-top:2px; font-size:9px; padding:1px 5px;">Me</span>' : isOther ? '<span class="lock-pill lock-pill-other" style="margin-top:2px; font-size:9px; padding:1px 5px;">'+escapeHtml(String(c.lockedBy).split('@')[0])+'</span>' : '';
    var defClass = 'badge-minor'; if(c.defect === 'Critical') defClass = 'badge-fail'; else if(c.defect === 'Major') defClass = 'badge-major';
    var flagEmoji = c.isAppeal ? '<span class="defect-flag" title="Appeal flag from source">&#x1F6A9;</span>' : '';
    var defectCell = '<span class="defect-cell">'+flagEmoji+'<span class="badge ' + defClass + '">' + escapeHtml(c.defect) + '</span></span>';
    var prodClass = c.product === 'BUSINESS' ? 'badge-business' : 'badge-retail'; var tags = (c.hashtags || []).join(' ');
    var proactiveCell = c.proactive === 'Yes' ? '<span class="status-dot status-dot-warn">Yes</span>' : '<span class="status-dot status-dot-success">No</span>';
    tr.innerHTML = '<td><button class="btn btn-primary btn-sm" onclick="window.investigateCase &amp;&amp; window.investigateCase(\''+escapeHtml(c.caseId)+'\')" '+(isOther?'disabled':'')+' style="padding:4px 8px; font-size:11px;">'+(isMe?'Resume':'Start')+'</button>'+lockBadge+'</td><td>'+defectCell+'</td><td><span class="badge '+prodClass+'">'+escapeHtml(c.product)+'</span></td><td title="'+escapeHtml(c.taskType)+'">'+escapeHtml(c.taskType)+'</td><td title="'+escapeHtml(c.agency)+'">'+escapeHtml(c.agency)+'</td><td title="'+escapeHtml(c.productionLine)+'">'+escapeHtml(c.productionLine)+'</td><td title="'+escapeHtml(c.team)+'">'+escapeHtml(c.team)+'</td><td title="'+escapeHtml(c.analyst)+'">'+escapeHtml(c.analyst)+'</td><td>'+proactiveCell+'</td><td class="date-cell">'+escapeHtml(c.reviewDoneDate)+'</td><td class="date-cell">'+escapeHtml(c.workDoneDate)+'</td><td class="keywords-cell" title="'+escapeHtml(tags)+'">'+escapeHtml(tags)+'</td>';
    tbody.appendChild(tr);
  });
  var totalPages = Math.max(1, Math.ceil(filteredCases.length / pageSize));
  var pi = $('paginationInfo'); if(pi){ var s = start + 1; var e = Math.min(start + pageSize, filteredCases.length); pi.textContent = 'Showing '+s+'-'+e+' of '+filteredCases.length; }
  var btns = ''; if(currentPage > 1) btns += '<button onclick="window.goToPage &amp;&amp; window.goToPage('+(currentPage-1)+')">&laquo;</button>';
  var pStart = Math.max(1, currentPage - 2); var pEnd = Math.min(totalPages, currentPage + 2);
  for(var i = pStart; i <= pEnd; i++){ btns += '<button class="'+(i === currentPage ? 'active' : '')+'" onclick="window.goToPage &amp;&amp; window.goToPage('+i+')">'+i+'</button>'; }
  if(currentPage < totalPages) btns += '<button onclick="window.goToPage &amp;&amp; window.goToPage('+(currentPage+1)+')">&raquo;</button>';
  var pc = $('paginationControls'); if(pc) pc.innerHTML = btns;
}
function goToPage(p){ currentPage=p; renderTable(); }
function changePageSize(){ var sel = $('pageSizeSelect'); pageSize = sel ? parseInt(sel.value, 10) : 50; currentPage = 1; renderTable(); }
window.loadCases=loadCases; window.changePageSize=changePageSize; window.goToPage=goToPage; window.handleCasesData=handleCasesData;
window.refreshCurrentTab=function(){ if(currentTab==='pending') loadCases(true); else if(typeof window.loadRcaAnalytics==='function') window.loadRcaAnalytics(); };

async function investigateCase(caseId){ try{ var c=caseIndexMap.get(caseId); if(!c) return showToast({title:'Case not found',type:'error'}); setConn('busy','Locking...'); var res=await new Promise(function(resolve,reject){ google.script.run.withSuccessHandler(resolve).withFailureHandler(reject).lockCase(caseId); }); if(!res.success){ setConn('online','Live'); await showModal({title:'Case Locked',description:'This case is locked by '+res.lockedBy+'.'}); loadCases(true); return; } currentCaseId=caseId; populateRcaForm(c); showForm(); _lockRefreshTimer=setInterval(function(){ if(currentCaseId) google.script.run.refreshLock(currentCaseId); }, 10*60*1000); setConn('online','Live'); }catch(e){ setConn('offline','Error'); showToast({title:'Failed to lock case',description:e.message,type:'error'}); } }
function populateRcaForm(c){ try{ var form=$('rcaForm'); if(form) form.reset(); Object.keys(tomSelectInstances).forEach(function(k){try{tomSelectInstances[k].clear();}catch(_){}}); var au=$('auQuestionsContainer'); if(au) au.innerHTML=''; $('formSubtitle').textContent='Analyst: '+c.analyst+' - Defect: '+c.defect+' - Team: '+c.team; $('caseIdField').value=c.caseId||''; $('productField').value=c.product||''; $('qcComment').textContent=c.details||''; if(c.qcLink){$('btnQcLink').href=c.qcLink;$('btnQcLink').classList.remove('hidden');} else $('btnQcLink').classList.add('hidden'); if(c.boLink){$('btnBoLink').href=c.boLink;$('btnBoLink').classList.remove('hidden');} else $('btnBoLink').classList.add('hidden'); function set(id,val){var el=$(id);if(el)el.value=(val==null?'':val);} set('rowNum',c.rowNum);set('qcName',c.qcName);set('reviewDoneDate',c.reviewDoneDate);set('workDoneDate',c.workDoneDate);set('reviewResult',c.reviewResult);set('taskType',c.taskType);set('entityName',c.entityName);set('agency',c.agency);set('team',c.team);set('analyst',c.analyst);set('proactive',c.proactive);set('outcomeDefect',c.defect);set('qcKeywords',(c.hashtags||[]).join(', '));set('h_lob',c.lob);set('h_empEmail',c.empEmail);set('h_entityRegion',c.entityRegion);set('h_batchId',c.batchId);set('h_lmEmail',c.lmEmail);set('h_recs',c.recs);set('h_boLink',c.boLink);set('h_qcLink',c.qcLink);set('h_appealOutcome',c.appealOutcome);set('h_entityRegionGrouped',c.entityRegionGrouped);set('h_isProbation',c.isProbation);set('h_remediationRequired',c.remediationRequired);set('h_wasAppealed',c.wasAppealed); document.querySelectorAll('.sub-group').forEach(function(g){if(g.id!=='auQuestionsContainer'&&g.id!=='rcaLogicGroup') g.classList.add('hidden');}); var rlg=$('rcaLogicGroup'); if(rlg) rlg.classList.add('hidden'); }catch(e){ console.error('populateRcaForm:',e); } }
function initTomSelects(){ try{ document.querySelectorAll('.main-select').forEach(function(el){ try{ tomSelectInstances[el.id]=new TomSelect(el,{ create:false, maxItems:el.multiple?null:1, plugins:el.multiple?['remove_button']:[], placeholder:(el.options[0]&&el.options[0].text)||'Select...', sortField:{field:'text',direction:'asc'}, onChange:function(value){ var ev=new Event('change',{bubbles:true}); el.dispatchEvent(ev); var grp = el.parentElement.querySelector('.other-text-group'); var isOther = value === 'Other' || (Array.isArray(value) && value.includes('Other')); if (isOther) { if (!grp) { grp = document.createElement('div'); grp.className = 'other-text-group sub-group'; grp.innerHTML = '<label class="form-label">Please specify:</label><input class="input other-text-input" type="text" data-parent-id="'+el.id+'">'; el.parentElement.appendChild(grp); } grp.classList.remove('hidden'); } else { if (grp) grp.classList.add('hidden'); } } }); }catch(e){ console.error('TomSelect '+el.id+':',e); } }); window.tomSelectInstances=tomSelectInstances; }catch(e){} }
function toggleBox(sid,tv,bid){ var v=safeGet(sid); var b=$(bid); if(b) b.classList.toggle('hidden', v!==tv); }
function toggleRcaLogic(){ try{ var a=safeGet('rcaAgree'); var grp=$('rcaLogicGroup'); if(grp) grp.classList.toggle('hidden', !(a&&a!=='Yes (Agree with fail)')); var perf=$('perfMsg'); var sugg=$('suggestedUpdateGroup'); var e=safeGet('errorSource'); if(e==='Performance'){ if(perf) perf.classList.remove('hidden'); if(sugg) sugg.classList.add('hidden'); } else if(e==='Process/Product'){ if(perf) perf.classList.add('hidden'); if(sugg) sugg.classList.remove('hidden'); } else { if(perf) perf.classList.add('hidden'); if(sugg) sugg.classList.add('hidden'); } }catch(e){} }
function toggleActionDrawer(){ try{ var d=$('actionDrawer'); if(d) d.classList.toggle('open'); if(typeof renderActionDrawer==='function') renderActionDrawer(); }catch(e){} }
function updateActionBadge(){ try { var badge = $('actionBadge'); if (!badge) return; var cart = (typeof window !== 'undefined' && window.actionCart) || []; if (cart.length === 0) { badge.style.display = 'none'; } else { badge.style.display = 'grid'; badge.textContent = String(cart.length); } } catch (e) {} }
function aiSearch(provider){ try{ var caseId=safeGet('caseIdField'); if(!caseId) return showToast({title:'No Case ID',type:'warn'}); var url=''; if(provider==='gemini') url='https://gemini.google.com/app?q='+encodeURIComponent('Summarize transaction risks for case '+caseId); else if(provider==='rovo') url='https://chat.revolut.com/rovo/search?q='+encodeURIComponent(caseId); if(url) window.open(url,'_blank'); }catch(e){} }
function buildAuQuestions(){ try{ var count=parseInt(safeGet('p4RevCount'),10); var cAll=safeGet('p4CorrectAll'); var cont=$('auQuestionsContainer'); if(!cont) return; if(isNaN(count)||count<=0||cAll!=='No'){ cont.innerHTML=''; cont.classList.add('hidden'); return; } cont.classList.remove('hidden'); var html='<label class="form-label">Associate Failure Details</label>'; var opts=['OWS when should Reject','Report when should Reject','EDD when should Reject','Reject when should Report','Reject when should OWS','OWS when should Report','Report when should OWS','EDD when should OWS','EDD when should Report','Missed - Report','Missed - Reject','Missed - OWS','Missed - EDD','Other']; for(var i=0;i<count;i++){ var inner='<option value="">-- Incorrect Action --</option>'; for(var j=0;j<opts.length;j++) inner+='<option>'+opts[j]+'</option>'; html+='<div class="au-row"><input type="text" class="input au-url-inp" placeholder="Profile URL or Name" data-idx="'+i+'"><select class="select au-outcome" data-idx="'+i+'">'+inner+'</select></div>'; } cont.innerHTML=html; }catch(e){} }
function calculateRefund(){ try{ var ds=safeGet('refundDate'); var amt=safeGet('refundAmt'); if(!ds||!amt) return showToast({title:'Missing inputs',type:'warn'}); var charge=new Date(ds); var amtN=parseFloat(amt); var today=new Date(); if(isNaN(charge)||isNaN(amtN)) return; var days=Math.floor((today-charge)/86400000); if(days<0) days=0; var rate=amtN/365; var consumed=rate*days; var refund=Math.max(amtN-consumed,0); var res=$('refundResult'); if(res){ res.classList.remove('hidden'); res.innerHTML='<div style="color:var(--text-secondary); font-size:11px; margin-bottom:4px;">'+days+' days consumed out of 365</div><div style="font-size:16px; color:var(--success);">Refund Due: <strong>'+refund.toFixed(2)+'</strong></div>'; } }catch(e){} }

function generateComments(){ try { var txt = 'RCA Review Summary:\n'; var phases = {'1':'p1Scope','2':'p2Baseline','3':'p3Baseline','4':'p4ShortFull','5':'p5Decision','6':'p6Edd','7':'p7Vague'}; for (var p in phases) { var val = safeGet(phases[p]); if (val === 'No' || val === 'Yes (Defect)') { txt += '- Phase ' + p + ': Failed.\n'; } } var agree = safeGet('rcaAgree'); if (agree.startsWith('No')) { txt += '\nRecommendation: Appeal.'; } else { txt += '\nRecommendation: Accept Fail.'; } var qcLink = safeGet('h_qcLink'); if (qcLink) txt += '\n\nQC Review Link: ' + qcLink; var c = $('rcaComments'); if (c) c.value = txt; } catch(e) { console.error(e); } }

function scanStatement(){ try { var text = safeGet('rawStatementInput'); if(!text) return showToast({title:'No data', type:'warn'}); var lines = text.split('\n').filter(function(l){ return l.trim() !== ''; }); var flags = []; var amounts = []; lines.forEach(function(line) { if (/crypto|bitcoin|btc|eth|usdt|trump/i.test(line.toLowerCase())) flags.push('Crypto Activity'); if (/gambling|casino|bet/i.test(line.toLowerCase())) flags.push('Gambling'); if (/p2p|transfer to|received from/i.test(line.toLowerCase())) flags.push('P2P Transfers'); if (/refund|chargeback/i.test(line.toLowerCase())) flags.push('Refunds/Chargebacks'); var match = line.match(/[-+]?\d+\.?\d*/); if (match) amounts.push(parseFloat(match[0])); }); var summary = 'Detected Potential Typologies: ' + (flags.length ? Array.from(new Set(flags)).join(', ') : 'None detected') + '\n'; summary += 'Transactions Analyzed: ' + lines.length + '\n'; if (amounts.length) { var max = Math.max.apply(null, amounts); var min = Math.min.apply(null, amounts); summary += 'Max Amount: ' + max + ', Min Amount: ' + min; } $('scanSummary').textContent = summary; $('scanSummary').classList.remove('hidden'); showToast({title:'Scan Complete', type:'success'}); } catch(e) { showToast({title:'Scanner Error', description:e.message, type:'error'}); } }

async function executeRcaSubmission(){
  try {
    var form = $('rcaForm'); if (!form || !form.checkValidity()) { showToast({ title: 'Validation Error', description: 'Please fill all required fields.', type: 'error' }); if (form) form.reportValidity(); return; }
    var confirm = await showModal({ title: 'Submit RCA', description: 'Are you sure you want to log this RCA?', confirmText: 'Submit' }); if (!confirm) return; setConn('busy', 'Saving...');
    
    function val(id){ var v = safeGet(id); if (v === 'Other') { var grp = $(id).parentElement.querySelector('.other-text-group'); if (grp) { var inp = grp.querySelector('.other-text-input'); if (inp && inp.value) return 'Other: ' + inp.value; } } return v; }
    function mval(id){ var v = getMultiSelectValues(id); var out = []; v.forEach(function(x) { if (x === 'Other') { var grp = $(id).parentElement.querySelector('.other-text-group'); if (grp) { var inp = grp.querySelector('.other-text-input'); if (inp && inp.value) out.push('Other: ' + inp.value); else out.push('Other'); } else out.push('Other'); } else out.push(x); }); return out.join(', '); }

    var p = {
      caseId: safeGet('caseIdField'), product: safeGet('productField'), qcName: safeGet('qcName'), reviewDoneDate: safeGet('reviewDoneDate'), workDoneDate: safeGet('workDoneDate'),
      taskType: safeGet('taskType'), entityName: safeGet('entityName'), agency: safeGet('agency'), team: safeGet('team'), analyst: safeGet('analyst'), proactive: safeGet('proactive'), outcomeDefect: safeGet('outcomeDefect'), qcKeywords: safeGet('qcKeywords'),
      authority: val('authority'), country: val('country'), origin: val('origin'), p1Scope: val('p1Scope'), duplicateIdentified: val('duplicateIdentified'), p1DuplicateAction: val('p1DuplicateAction'),
      prevNote: mval('prevNote'), escalation: mval('escalation'), tag: mval('tag'), typology: mval('typology'),
      p1MultiSuspect: val('p1MultiSuspect'), p1AnalystIdentified: val('p1AnalystIdentified'), p1LlmOutput: val('p1LlmOutput'), p1LlmFail: val('p1LlmFail'),
      p2Baseline: val('p2Baseline'), p2BaselineFail: val('p2BaselineFail'), p2Osint: val('p2Osint'), p2OsintFail: val('p2OsintFail'), p2OsintDoc: val('p2OsintDoc'), p2LlmOutput: val('p2LlmOutput'), p2LlmFail: val('p2LlmFail'),
      p3Baseline: val('p3Baseline'), p3BaselineFail: val('p3BaselineFail'), p3Module: val('p3Module'), p3ModuleFail: val('p3ModuleFail'), p3LlmOutput: val('p3LlmOutput'), p3LlmFail: val('p3LlmFail'),
      p4ShortFull: val('p4ShortFull'), p4ReqCount: val('p4ReqCount'), p4RevCount: val('p4RevCount'), p4CorrectAll: val('p4CorrectAll'), p4LlmOutput: val('p4LlmOutput'), p4LlmFail: val('p4LlmFail'),
      p5Decision: val('p5Decision'), p5ActionError: val('p5ActionError'), p5Juris: val('p5Juris'), p5JurisTxt: val('p5JurisTxt'), p5Excep: val('p5Excep'), p5ExcepTxt: val('p5ExcepTxt'), p5Biz: val('p5Biz'), p5BizTxt: val('p5BizTxt'), p5LlmOutput: val('p5LlmOutput'), p5LlmFail: val('p5LlmFail'),
      p6Edd: val('p6Edd'), p6EddTxt: val('p6EddTxt'), p6Juris: val('p6Juris'), p6JurisTxt: val('p6JurisTxt'), p6Template: val('p6Template'), p6TemplateTxt: val('p6TemplateTxt'), p6Dante: val('p6Dante'), p6DanteTxt: val('p6DanteTxt'), p6Tags: val('p6Tags'), p6TagsTxt: val('p6TagsTxt'), p6Alerts: val('p6Alerts'), p6AlertsTxt: val('p6AlertsTxt'), p6Offboard: val('p6Offboard'), p6OffboardTxt: val('p6OffboardTxt'), p6Suspects: val('p6Suspects'), p6SuspectsTxt: val('p6SuspectsTxt'), p6Refunds: val('p6Refunds'), p6RefundsTxt: val('p6RefundsTxt'), p6LlmOutput: val('p6LlmOutput'), p6LlmFail: val('p6LlmFail'),
      p7Vague: val('p7Vague'), p7BrokenStrings: val('p7BrokenStrings'), p7UpstreamFlags: val('p7UpstreamFlags'), p7ExtEnquiry: val('p7ExtEnquiry'),
      taskTypeMatch: val('taskTypeMatch'), correctTaskType: val('correctTaskType'), rcaOutcome: val('rcaOutcome'), negativeImpact: val('negativeImpact'),
      rcaSysFail: val('rcaSysFail'), rcaSysFailTxt: val('rcaSysFailTxt'), rcaAgree: val('rcaAgree'), errorSource: val('errorSource'), rcaUpdate: val('suggestedUpdate'), rcaComments: val('rcaComments'),
      flagToTL: safeGetChecked('flagToTL'), toBeAppealed: safeGetChecked('toBeAppealed'), failAccepted: safeGetChecked('failAccepted'), remediationStatus: val('remediationStatus'), remediationDisagreement: val('remediationDisagreement'),
      lob: safeGet('h_lob'), empEmail: safeGet('h_empEmail'), entityRegion: safeGet('h_entityRegion'), batchId: safeGet('h_batchId'), lmEmail: safeGet('h_lmEmail'), recs: safeGet('h_recs'), boLink: safeGet('h_boLink'), qcLink: safeGet('h_qcLink'),
      appealOutcome: safeGet('h_appealOutcome'), entityRegionGrouped: safeGet('h_entityRegionGrouped'), isProbation: safeGet('h_isProbation'), remediationRequired: safeGet('h_remediationRequired'), wasAppealed: safeGet('h_wasAppealed')
    };
    
    var score = 0; if (p.rcaOutcome === 'No') score++; if (p.p2Baseline === 'No') score++; if (p.p2Osint === 'No') score++; if (p.p3Baseline === 'No') score++; if (p.p3Module === 'No') score++; if (p.p4ShortFull === 'No') score++; if (p.p4CorrectAll === 'No') score++; if (p.p5Decision === 'No') score++; p.binaryDefectScore = score;
    var auArr = []; document.querySelectorAll('.au-row').forEach(function(row) { var u = row.querySelector('.au-url-inp'), o = row.querySelector('.au-outcome'); if (!u || !o) return; var uv = u.value, ov = o.value; if (uv || ov) auArr.push(uv + ' [' + ov + ']'); }); p.p4AuDetails = auArr.join('\n');
    
    google.script.run.withSuccessHandler(function(res) {
      if (res && res.success) { setConn('online', 'Live'); var f = $('rcaForm'); if (f) f.classList.add('hidden'); var sm = $('successMsg'); if (sm) sm.classList.remove('hidden'); currentCaseId = null; if (_lockRefreshTimer) { clearInterval(_lockRefreshTimer); _lockRefreshTimer = null; } showToast({ title: 'RCA submitted', type: 'success' }); } 
      else { setConn('offline', 'Error'); showToast({ title: 'Submission failed', description: (res && res.error) || 'Unknown', type: 'error' }); }
    }).withFailureHandler(function(err) { setConn('offline', 'Error'); showToast({ title: 'Server error', description: err.message, type: 'error' }); }).submitRCA(p);
  } catch(e) { setConn('offline', 'Error'); showToast({ title: 'Submit error', description: e.message, type: 'error' }); }
}

window.investigateCase=investigateCase; window.populateRcaForm=populateRcaForm; window.initTomSelects=initTomSelects; window.toggleBox=toggleBox; window.toggleRcaLogic=toggleRcaLogic; window.toggleActionDrawer=toggleActionDrawer; window.updateActionBadge=updateActionBadge; window.aiSearch=aiSearch; window.buildAuQuestions=buildAuQuestions; window.calculateRefund=calculateRefund; window.generateComments=generateComments; window.scanStatement=scanStatement; window.executeRcaSubmission=executeRcaSubmission; window.showToast=showToast; window.showModal=showModal;
document.addEventListener('DOMContentLoaded', function(){ try{ initTomSelects(); loadCases(); document.querySelectorAll('.diag-tab').forEach(function(tab){ tab.addEventListener('click',function(){ document.querySelectorAll('.diag-tab').forEach(function(t){t.classList.remove('active');}); tab.classList.add('active'); renderDiag(); }); }); }catch(e){ console.error('Init:',e); } });
</script>
